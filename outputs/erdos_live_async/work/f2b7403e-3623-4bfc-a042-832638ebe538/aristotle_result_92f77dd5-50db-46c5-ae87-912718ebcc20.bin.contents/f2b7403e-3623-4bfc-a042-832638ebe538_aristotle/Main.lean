theorem fragile_variant_false :
    ¬ (∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      IsDComplete (PowTripleSet a b c)) := by
  by_contra! h_contra;
  -- Let's choose any $a = b = c = 2$.
  have h_specific : IsDComplete (PowTripleSet 2 2 2) := by
    grind +splitIndPred;
  -- By definition of `IsDComplete`, there exists some $N$ such that for all $n \geq N$, there exists a division antichain sum representation for $n$.
  obtain ⟨N, hN⟩ : ∃ N, ∀ n ≥ N, ∃ s : Finset ℕ, ((s : (Set ℕ)) ⊆ (PowTripleSet 2 2 2) ∧ (IsDivisionAntichain s) ∧ s.sum id = n) := by
    exact Filter.eventually_atTop.mp h_specific;
  -- Consider $n = 2N + 3$. This number is odd and greater than $2N$, so it cannot be a power of 2.
  have h_odd : ¬∃ m : ℕ, 2 * N + 3 = 2 ^ m := by
    rintro ⟨ m, hm ⟩ ; have := congr_arg Even hm ; norm_num [ Nat.even_add, Nat.even_pow ] at this ; aesop;
  obtain ⟨ s, hs₁, hs₂, hs₃ ⟩ := hN ( 2 * N + 3 ) ( by linarith ) ; have := antichain_sum_pow2 s hs₁ hs₂ ; aesop;

