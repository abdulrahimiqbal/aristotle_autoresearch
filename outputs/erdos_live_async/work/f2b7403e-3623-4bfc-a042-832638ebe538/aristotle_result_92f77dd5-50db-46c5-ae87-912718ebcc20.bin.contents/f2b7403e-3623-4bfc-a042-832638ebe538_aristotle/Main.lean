import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-- A workspace-local Lean 4 stub for Erdos Problem 123. The formal-conjectures repo
contains a current statement very close to this one together with solved variants. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-!
## Counterexample for the "most fragile variant"

The most fragile variant of the theorem drops the `PairwiseCoprime3` hypothesis. We show
this variant is *false* by exhibiting the witness `a = b = c = 2`.

**Key insight**: `PowTripleSet 2 2 2 = {2^n | n : ℕ}`. Among powers of 2, any two
distinct elements satisfy a divisibility relation (`2^a ∣ 2^b` whenever `a ≤ b`), so
every division antichain drawn from this set has at most one element. Therefore the only
integers representable as antichain sums from this set are 0 and the powers of 2
themselves, and in particular 3 is never representable.
-/

/-
PROBLEM
Every element of `PowTripleSet 2 2 2` is a power of 2.

PROVIDED SOLUTION
Unfold PowTripleSet. Show set equality by ext. Forward: given 2^i * 2^j * 2^k, rewrite as 2^(i+j+k). Backward: given 2^m, take i=m, j=0, k=0.
-/
lemma powTripleSet_222_eq :
    PowTripleSet 2 2 2 = {n | ∃ m : ℕ, n = 2 ^ m} := by
  exact Set.ext fun n => ⟨ fun ⟨ i, j, k, h ⟩ => ⟨ i + j + k, by rw [ h, pow_add, pow_add ] ⟩, fun ⟨ m, h ⟩ => ⟨ m, 0, 0, by rw [ h ] ; ring ⟩ ⟩

/-
PROBLEM
Among powers of 2, any two distinct elements have a divisibility relation.

PROVIDED SOLUTION
Obtain a, b with x = 2^a, y = 2^b. Since x ≠ y, a ≠ b. WLOG a ≤ b (use le_or_le). If a ≤ b then 2^a ∣ 2^b so x ∣ y. Otherwise y ∣ x.
-/
lemma pow2_divides_of_ne {x y : ℕ} (hx : ∃ a, x = 2 ^ a) (hy : ∃ b, y = 2 ^ b)
    (hne : x ≠ y) : x ∣ y ∨ y ∣ x := by
  rcases hx with ⟨ a, rfl ⟩ ; rcases hy with ⟨ b, rfl ⟩ ; cases le_total a b <;> simp +decide [ *, pow_dvd_pow ] ;

/-
PROBLEM
A division antichain drawn from powers of 2 has at most one element.

PROVIDED SOLUTION
By contradiction, assume s.card ≥ 2. Then there exist two distinct elements x, y ∈ s. By hs, both are powers of 2. By pow2_divides_of_ne, either x ∣ y or y ∣ x. But ha (IsDivisionAntichain) says neither divides the other when they're distinct. Contradiction.
-/
lemma antichain_pow2_card_le_one (s : Finset ℕ) (hs : (↑s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m})
    (ha : IsDivisionAntichain s) : s.card ≤ 1 := by
  -- By contradiction, assume s has at least two elements.
  by_contra h_contra;
  obtain ⟨x, y, hx, hy, hxy⟩ : ∃ x y, x ∈ s ∧ y ∈ s ∧ x ≠ y := by
    simpa using Finset.one_lt_card.1 ( lt_of_not_ge h_contra );
  exact ha hx hy hxy <| pow2_divides_of_ne ( hs hx ) ( hs hy ) hxy |> Or.resolve_right <| by aesop;

/-
PROBLEM
Summing an antichain from `PowTripleSet 2 2 2` yields 0 or a power of 2.

PROVIDED SOLUTION
By antichain_pow2_card_le_one (using powTripleSet_222_eq to convert hs), s has at most 1 element. Case split: if s.card = 0 then s is empty and sum is 0 (Left). If s.card = 1, then s = {x} for some x, and x ∈ PowTripleSet 2 2 2, so by powTripleSet_222_eq, x = 2^m for some m. The sum of {x} is x = 2^m (Right).
-/
lemma antichain_sum_pow2 (s : Finset ℕ) (hs : (↑s : Set ℕ) ⊆ PowTripleSet 2 2 2)
    (ha : IsDivisionAntichain s) : s.sum id = 0 ∨ ∃ m : ℕ, s.sum id = 2 ^ m := by
  by_cases h : s.card = 0;
  · aesop;
  · -- Since $s$ has at least one element, we can write $s$ as $\{x\}$ for some $x$.
    obtain ⟨x, hx⟩ : ∃ x, s = {x} := by
      exact Finset.card_eq_one.mp ( le_antisymm ( antichain_pow2_card_le_one s ( by simpa only [ powTripleSet_222_eq ] using hs ) ha ) ( Nat.pos_of_ne_zero h ) ) |> Exists.imp fun x hx => by aesop;
    obtain ⟨ i, j, k, rfl ⟩ := hs ( hx.symm ▸ Finset.mem_singleton_self _ ) ; exact Or.inr ⟨ i + j + k, by simp +decide [ pow_add, hx ] ⟩ ;

/-
PROBLEM
3 is not a power of 2 and not 0, so it cannot be an antichain sum.

PROVIDED SOLUTION
Assume ⟨s, hs, ha, hsum⟩. By antichain_sum_pow2, s.sum id = 0 or s.sum id = 2^m. But s.sum id = 3. 3 ≠ 0 and 3 is not a power of 2 (since 2^0=1, 2^1=2, 2^2=4 > 3, and powers of 2 are monotone). Contradiction.
-/
lemma three_not_antichain_sum :
    ¬ ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowTripleSet 2 2 2 ∧
      IsDivisionAntichain s ∧ s.sum id = 3 := by
  by_contra h_contra
  obtain ⟨s, hs⟩ := h_contra
  have h_sum : s.sum id = 0 ∨ ∃ m : ℕ, s.sum id = 2 ^ m := by
    apply antichain_sum_pow2 s hs.left hs.right.left
  cases' h_sum with h_bound h_eq
  ·
    aesop
  ·
    rcases h_eq with ⟨ m, hm ⟩ ; linarith [ Nat.pow_le_pow_right ( by decide : 1 ≤ 2 ) ( show m ≥ 2 by contrapose! hm; interval_cases m <;> simp_all +decide ) ] ;

