-- erdos family workspace
-- focus: extremal constructions, additive structure, and parameter boundary behavior
-- erdos-123 focus: d-completeness, divisibility antichains, and reusable covering lemmas
import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-!
## Part I: Main Conjecture (Erdős Problem 123)

This is an **open problem** in combinatorial number theory. The conjecture states that
the multiplicative semigroup generated by any three pairwise coprime integers > 1
is d-complete. No proof or disproof is known as of 2025.
-/

/-- **Erdős Problem 123** (open conjecture): The multiplicative semigroup generated by
three pairwise coprime integers greater than 1 is d-complete.

This remains an open problem — the `sorry` here reflects the state of mathematical
knowledge, not a gap in the formalization effort. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-!
## Part II: Fragile Variant — Counterexample When Coprimality Fails

The "most fragile variant" is obtained by dropping the pairwise coprimality hypothesis.
Without coprimality, the generators can all be powers of a single prime, collapsing
`PowTripleSet` to a set of powers of that prime. In such a set, every pair has a
divisibility relation, so the only divisibility antichains are singletons.

### Sharpest Witness

Take `a = 2, b = 4, c = 8`. Then `PowTripleSet 2 4 8 = {2^k | k ∈ ℕ}`.
Every antichain subset is a singleton `{2^k}`, so the only achievable sums
are individual powers of 2. Any odd number ≥ 3 (e.g. `3` itself) witnesses
the failure of d-completeness.
-/

/-- `PowTripleSet 2 4 8` consists exactly of the powers of 2. -/
lemma powTripleSet_2_4_8_eq :
    PowTripleSet 2 4 8 = {n | ∃ k : ℕ, n = 2 ^ k} := by
  apply Set.ext; intro n; simp [PowTripleSet]
  constructor
  · rintro ⟨i, j, k, rfl⟩
    exact ⟨i + 2 * j + 3 * k, by ring_nf; norm_num [pow_mul']⟩
  · rintro ⟨k, rfl⟩; exact ⟨k, 0, 0, by norm_num⟩

/-- In a set of powers of a single prime `p ≥ 2`, every two-element subset
has a divisibility relation, so every antichain has at most one element. -/
lemma antichain_singleton_of_prime_powers {p : ℕ} (_hp : 2 ≤ p) (s : Finset ℕ)
    (hsub : ∀ x ∈ s, ∃ k : ℕ, x = p ^ k)
    (hanti : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  contrapose! hanti
  rcases Finset.one_lt_card.1 hanti with ⟨x, hx, y, hy, hxy⟩
  obtain ⟨k, rfl⟩ := hsub x hx; obtain ⟨l, rfl⟩ := hsub y hy
  simp_all +decide [IsDivisionAntichain]
  cases le_total k l <;>
    [exact ⟨_, hx, _, hy, hxy, pow_dvd_pow _ ‹_›⟩;
     exact ⟨_, hy, _, hx, Ne.symm hxy, pow_dvd_pow _ ‹_›⟩]

/-- `3` is not a power of `2`. -/
lemma three_not_pow_two : ¬ ∃ k : ℕ, 3 = 2 ^ k := by
  rintro ⟨k, hk⟩
  have : 2 ^ k = 3 := hk.symm
  have h2 : k ≤ 1 := by
    by_contra h; push_neg at h
    have := Nat.pow_le_pow_right (show 1 ≤ 2 by norm_num) h
    linarith
  interval_cases k <;> simp_all

/-- **Counterexample**: dropping coprimality allows `PowTripleSet 2 4 8`
to fail d-completeness. Every odd number ≥ 3 is unreachable. -/
theorem fragile_variant_not_d_complete :
    ¬ IsDComplete (PowTripleSet 2 4 8) := by
  simp [IsDComplete]
  intro n
  use 2 * n + 3
  refine ⟨by linarith, ?_⟩
  intro x hx hx' hsum
  have h_card : x.card ≤ 1 := by
    apply antichain_singleton_of_prime_powers (by norm_num : 2 ≤ 2) x
      (fun x hx => by
        have := ‹(↑_ : Set ℕ) ⊆ PowTripleSet 2 4 8› hx
        obtain ⟨i, j, k, rfl⟩ := this
        exact ⟨i + 2 * j + 3 * k, by ring_nf; norm_num [pow_mul']⟩) hx'
  cases h_card.eq_or_lt <;> simp_all +decide [Finset.card_le_one]
  rw [Finset.card_eq_one] at *
  rcases ‹_› with ⟨a, rfl⟩; norm_num at *
  obtain ⟨i, j, k, rfl⟩ := hx
  have := congr_arg Even hsum; norm_num [parity_simps] at this
  aesop

/-!
## Part III: Boundary-Case Analysis — The Discovery Question

**Question**: *Which d-completeness boundary cases fail because interval-style
coverage cannot be upgraded to a divisibility antichain, and what is the
sharpest witness?*

### Answer

The upgrade from "interval coverage" (every large `n` is a sum of distinct
elements from `A`) to "antichain coverage" (the summands form a divisibility
antichain) fails precisely when the generating set has **concentrated
divisibility chains** — long sequences of elements where each divides the next.

#### Key boundary cases that fail:

1. **Single-prime collapse** (`a = p, b = p², c = p³`):
   `PowTripleSet` = `{p^k}`, all pairs comparable ⟹ antichain sums = singletons.
   *Witness*: any non-power-of-`p` (e.g. `p+1`).

2. **Two-prime with shared factor** (`a = 6, b = 10, c = 15`):
   `gcd(6,10) = 2`, `gcd(6,15) = 3`, `gcd(10,15) = 5`. The set still has
   rich additive structure, but forced divisibility relations among smooth
   numbers prevent antichain upgrades for many targets.

3. **Sparse generators** (only two generators, e.g. `a = 2, b = 3`):
   The set `{2^i · 3^j}` is additively complete, but d-completeness with
   only two generators is harder because the density of antichain-compatible
   subsets is lower (each "level set" by magnitude contains fewer incomparable
   elements).

#### Sharpest witness (formalized below):

**`a = 2, b = 4, c = 8`** (equivalently `a = p, b = p², c = p³` for any prime `p`).
This is the sharpest because:
- **Interval-style coverage holds**: powers of 2 form a complete sequence (binary
  representation — proved as `powers_of_two_complete` below).
- **The antichain upgrade completely fails**: every antichain is a singleton, so
  the gap between "complete" and "d-complete" is **maximal**.
- The failure is **structural**, not a density issue: for any `n` that is not
  a power of 2, no antichain representation exists regardless of how large `n` is.

This demonstrates that completeness (interval-style coverage) and d-completeness
are genuinely different properties, and the coprimality hypothesis in Erdős 123
is essential for the antichain upgrade.
-/

/-- Powers of 2 form a complete sequence: every positive natural number
is a sum of distinct powers of 2 (binary representation). This shows
that interval-style coverage holds for `{2^k}`. -/
lemma powers_of_two_complete :
    ∀ n : ℕ, 0 < n → ∃ s : Finset ℕ,
      (∀ x ∈ s, ∃ k : ℕ, x = 2 ^ k) ∧
      (∀ x ∈ s, ∀ y ∈ s, x = y ∨ ¬ (x ∣ y ∧ y ∣ x)) ∧
      s.sum id = n := by
  intro n hn
  induction' n using Nat.strong_induction_on with n ih
  by_cases h_even : Even n
  · obtain ⟨k, rfl⟩ := h_even
    obtain ⟨s, hs₁, hs₂, hs₃⟩ := ih k (by linarith) (by linarith)
    use s.image (fun x => 2 * x)
    simp_all +decide [Finset.sum_image, Nat.mul_dvd_mul_iff_left]
    exact ⟨fun x hx => by obtain ⟨k, rfl⟩ := hs₁ x hx; exact ⟨k + 1, by ring⟩,
           by rw [← Finset.mul_sum _ _ _, hs₃]; ring⟩
  · obtain ⟨k, rfl⟩ : ∃ k, n = 2 * k + 1 := n.even_or_odd.resolve_left h_even
    rcases k with (_ | k) <;> simp_all +decide
    · exact ⟨{1}, fun x hx => ⟨0, by simpa using hx⟩, by simp +decide, by simp +decide⟩
    · obtain ⟨s, hs⟩ := ih (k + 1) (by linarith) (Nat.succ_pos _)
      refine ⟨s.image (fun x => 2 * x) ∪ {1}, ?_, ?_, ?_⟩ <;>
        simp_all +decide
      · exact ⟨⟨0, rfl⟩, fun x hx => by obtain ⟨k, rfl⟩ := hs.1 x hx; exact ⟨k + 1, by ring⟩⟩
      · intro x hx y hy; have := hs.2.1 x hx y hy
        simp_all +decide [Nat.mul_dvd_mul_iff_left]
      · rw [← Finset.mul_sum _ _ _, hs.2.2]; ring

/-- **Key theorem**: Powers of 2 are additively complete but NOT d-complete.
This is the sharpest possible witness that interval-style coverage cannot be
upgraded to a divisibility antichain when the generators lack coprimality. -/
theorem powers_of_two_not_d_complete :
    ¬ IsDComplete {n : ℕ | ∃ k : ℕ, n = 2 ^ k} := by
  simp only [IsDComplete, Filter.not_eventually, Filter.frequently_atTop]
  intro N
  use 2 * N + 3
  constructor
  · linarith
  · push_neg
    intro s hsub hanti
    have h_card := antichain_singleton_of_prime_powers (by norm_num : 2 ≤ 2) s
      (fun x hx => hsub hx) hanti
    rcases Nat.le_one_iff_eq_zero_or_eq_one.mp h_card with hc | hc
    · rw [Finset.card_eq_zero] at hc; simp [hc]
    · rw [Finset.card_eq_one] at hc
      obtain ⟨a, rfl⟩ := hc; simp [Finset.sum_singleton]
      obtain ⟨k, rfl⟩ := hsub (Finset.mem_singleton_self a)
      intro h
      rcases k with _ | k
      · simp at h
      · have : Even (2 ^ (k + 1)) := ⟨2 ^ k, by ring⟩
        rw [h] at this; exact Nat.not_even_iff_odd.mpr ⟨N + 1, by ring⟩ this

end Erdos123
