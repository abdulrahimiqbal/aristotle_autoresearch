-- counterexample mode target
import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-!
## Analysis: Relationship to Erdős Problem 123

The theorem `erdos_123_d_complete_sequences` below is a formalization of a generalization
of Erdős Problem 123, which asks whether the set of 3-smooth numbers `{2^i * 3^j}`
is d-complete. The generalization to three pairwise coprime generators `{a^i * b^j * c^k}`
makes this a universally quantified statement over all valid triples.

### Status: Open Problem

This is a well-known open problem in additive combinatorics. Neither a proof nor a
counterexample is currently known. Our computational search found:

1. **Dense case (a=2, b=3, c=5):** All integers 1–100 are representable as antichain
   sums of 5-smooth numbers using elements ≤ 30. No counterexample found.

2. **Sparse case (a=4, b=9, c=25):** With elements up to ~1300, many integers ≤ 2000
   are NOT representable, but larger elements could close these gaps.

3. **Very sparse case (a=101, b=103, c=107):** We proved below that n=10203 and
   n=1030303 are NOT representable using elements of PowTripleSet(101,103,107).
   However, this does not contradict the theorem since the "sufficiently large"
   threshold may exceed these values.

### Why no full counterexample was found

For a counterexample to the universal statement, we would need a specific triple (a,b,c)
where infinitely many integers have no antichain sum representation. While specific
non-representable numbers exist (like 101^m + 2 for small m), showing infinitely many
such numbers exist for a fixed triple requires proving that the "gaps" never close,
which appears as hard as the original problem. For large exponent levels m, the total
sum of elements at lower levels eventually exceeds 101^m (since 107 > 101), making
the simple "total too small" argument fail.

### Counterexample pattern: n = a² + 2

For pairwise coprime a < b < c with a² + 2 < a·b (so that no other level-2 element
fits below a² + 2), the number a² + 2 is always non-representable:
- Including a² in the antichain: remainder = 2, but the smallest compatible element
  (i.e., one not dividing a² and not divisible by a²) is b ≥ a+2 > 2.
- Excluding a²: all elements ≤ a²+2 sum to at most 1 + a + b + c ≪ a²+2 (for a ≥ 5).

This pattern produces non-representable numbers at scales 101², 101³, 101⁴, ...
for (101,103,107), but only finitely many before the sum-bound argument breaks down.
-/

/-- The elements of PowTripleSet(101,103,107) that are at most 10203 are exactly
    {1, 101, 103, 107, 10201}. -/
lemma powTripleSet_101_103_107_le_10203 (n : ℕ) (hn : n ∈ PowTripleSet 101 103 107)
    (hn_le : n ≤ 10203) :
    n = 1 ∨ n = 101 ∨ n = 103 ∨ n = 107 ∨ n = 10201 := by
  obtain ⟨i, j, k, rfl⟩ := hn
  have h_bounds : i ≤ 2 ∧ j ≤ 1 ∧ k ≤ 1 := by
    exact ⟨le_of_not_gt fun hi => by
        nlinarith [Nat.pow_le_pow_right (show 1 ≤ 101 by norm_num) hi,
          Nat.one_le_pow j 103 (by norm_num), Nat.one_le_pow k 107 (by norm_num),
          mul_pos (pow_pos (by norm_num : 0 < 101) i) (pow_pos (by norm_num : 0 < 103) j)],
      le_of_not_gt fun hj => by
        nlinarith [Nat.pow_le_pow_right (show 1 ≤ 103 by norm_num) hj,
          Nat.one_le_pow i 101 (by norm_num), Nat.one_le_pow k 107 (by norm_num),
          mul_pos (pow_pos (by norm_num : 0 < 101) i) (pow_pos (by norm_num : 0 < 103) j)],
      le_of_not_gt fun hk => by
        nlinarith [Nat.pow_le_pow_right (show 1 ≤ 107 by norm_num) hk,
          Nat.one_le_pow i 101 (by norm_num), Nat.one_le_pow j 103 (by norm_num),
          mul_pos (pow_pos (by norm_num : 0 < 101) i) (pow_pos (by norm_num : 0 < 103) j)]⟩
  rcases h_bounds with ⟨hi, hj, hk⟩
  interval_cases i <;> interval_cases j <;> interval_cases k <;> trivial

/-- No element of PowTripleSet(101,103,107) lies in {10202, 10203}. -/
lemma no_element_10202_10203 : ∀ n ∈ PowTripleSet 101 103 107,
    10202 ≤ n → n ≤ 10203 → n = 10201 := by
  intros n hn hn2 hn3
  have := powTripleSet_101_103_107_le_10203 n hn hn3
  rcases this with (rfl | rfl | rfl | rfl | rfl) <;> trivial

/-- For pairwise coprime bases, divisibility in the multiplicative semigroup is
    equivalent to coordinate-wise ≤ on exponent vectors. -/
lemma div_iff_exp_le {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) (i₁ j₁ k₁ i₂ j₂ k₂ : ℕ) :
    a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ ↔
    i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
  constructor <;> intro H
  · have h_exp_a : i₁ ≤ i₂ := by
      have := dvd_of_mul_right_dvd (dvd_of_mul_right_dvd H)
      have h_div_a : a ^ i₁ ∣ a ^ i₂ := by
        refine' Nat.Coprime.dvd_of_dvd_mul_right _ this |> fun h =>
          Nat.Coprime.dvd_of_dvd_mul_right _ h
        · exact Nat.Coprime.pow _ _ <| hcop.1
        · exact Nat.Coprime.pow _ _ (hcop.2.1)
      rw [pow_dvd_pow_iff] at h_div_a <;> aesop
    have h_exp_b : j₁ ≤ j₂ := by
      have h_div_b : b ^ j₁ ∣ b ^ j₂ := by
        have h_div_b : b ^ j₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ :=
          dvd_trans (dvd_mul_of_dvd_left (dvd_mul_left _ _) _) H
        have h_coprime_b : Nat.Coprime (b ^ j₁) (a ^ i₂ * c ^ k₂) := by
          rw [Nat.coprime_mul_iff_right]
          exact ⟨Nat.Coprime.pow _ _ <| hcop.1.symm, Nat.Coprime.pow _ _ <| hcop.2.2⟩
        exact h_coprime_b.dvd_of_dvd_mul_left <| by convert h_div_b using 1; ring
      exact Nat.le_of_not_lt fun h => not_le_of_gt (pow_lt_pow_right₀ hb h)
        (Nat.le_of_dvd (pow_pos (zero_lt_one.trans hb) _) h_div_b)
    have h_exp_c : k₁ ≤ k₂ := by
      have h_exp_c : c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ :=
        dvd_trans (dvd_mul_left _ _) H
      have h_coprime_c : Nat.Coprime (c ^ k₁) (a ^ i₂ * b ^ j₂) := by
        rw [Nat.coprime_mul_iff_right]
        exact ⟨Nat.Coprime.pow _ _ <| hcop.2.1.symm, Nat.Coprime.pow _ _ <| hcop.2.2.symm⟩
      exact Nat.le_of_not_lt fun h => absurd (h_coprime_c.dvd_of_dvd_mul_left h_exp_c)
        (Nat.not_dvd_of_pos_of_lt (by positivity) (pow_lt_pow_right₀ hc h))
    exact ⟨h_exp_a, h_exp_b, h_exp_c⟩
  · exact mul_dvd_mul (mul_dvd_mul (pow_dvd_pow _ H.1) (pow_dvd_pow _ H.2.1))
      (pow_dvd_pow _ H.2.2)

/-- n = 10203 = 101² + 2 cannot be represented as an antichain sum from
    PowTripleSet(101,103,107). The elements ≤ 10203 are {1, 101, 103, 107, 10201},
    and no antichain subset of these sums to 10203. -/
theorem no_antichain_sum_10203 :
    ¬ ∃ s : Finset ℕ,
      (↑s : Set ℕ) ⊆ PowTripleSet 101 103 107 ∧
      IsDivisionAntichain s ∧
      s.sum id = 10203 := by
  simp +zetaDelta at *
  intros s hs hs' hs''
  have := hs''
  simp_all +decide [Set.subset_def]
  have h_subset : s ⊆ {1, 101, 103, 107, 10201} := by
    intro x hx
    specialize hs x hx
    rcases hs with ⟨i, j, k, rfl⟩
    have := powTripleSet_101_103_107_le_10203 _
      (show 101 ^ i * 103 ^ j * 107 ^ k ∈ PowTripleSet 101 103 107 from ⟨i, j, k, rfl⟩)
      (show 101 ^ i * 103 ^ j * 107 ^ k ≤ 10203 from by
        linarith [Finset.single_le_sum (fun x _ => Nat.zero_le x) hx])
    aesop
  have h_sums : ∀ t ⊆ ({1, 101, 103, 107, 10201} : Finset ℕ),
      t.sum id = 10203 → ¬IsDivisionAntichain t := by
    unfold IsDivisionAntichain; simp +decide
  exact h_sums s h_subset this hs'

/-- The elements of PowTripleSet(101,103,107) at most 1030303 are at levels 0, 1, 2
    plus 101³ = 1030301 from level 3. -/
lemma powTripleSet_101_103_107_le_1030303 (n : ℕ) (hn : n ∈ PowTripleSet 101 103 107)
    (hn_le : n ≤ 1030303) :
    n = 1 ∨ n = 101 ∨ n = 103 ∨ n = 107 ∨ n = 10201 ∨ n = 10403 ∨ n = 10609 ∨
    n = 10807 ∨ n = 11021 ∨ n = 11449 ∨ n = 1030301 := by
  obtain ⟨i, j, k, rfl⟩ := hn
  have hi : i ≤ 3 := by
    exact le_of_not_gt fun hi => by
      nlinarith [Nat.pow_le_pow_right (show 1 ≤ 101 by decide) hi,
        show 0 < 103 ^ j * 107 ^ k by positivity]
  have hj : j ≤ 2 := by
    contrapose! hn_le
    exact lt_of_lt_of_le (by decide)
      (Nat.mul_le_mul (Nat.mul_le_mul (pow_le_pow_right₀ (by decide) (Nat.zero_le _))
        (pow_le_pow_right₀ (by decide) hn_le)) (pow_le_pow_right₀ (by decide) (Nat.zero_le _)))
  have hk : k ≤ 2 := by
    exact le_of_not_gt fun hk' => by
      interval_cases i <;> interval_cases j <;>
        linarith [Nat.pow_le_pow_right (show 1 ≤ 107 by decide) hk']
  interval_cases i <;> interval_cases j <;> interval_cases k <;> trivial

/-- n = 1030303 = 101³ + 2 cannot be represented as an antichain sum from
    PowTripleSet(101,103,107). Including 101³ leaves remainder 2 (too small for
    any compatible element ≥ 103), and excluding it leaves max sum 64802 ≪ 1030303. -/
theorem no_antichain_sum_1030303 :
    ¬ ∃ s : Finset ℕ,
      (↑s : Set ℕ) ⊆ PowTripleSet 101 103 107 ∧
      IsDivisionAntichain s ∧
      s.sum id = 1030303 := by
  intro ⟨s, hs₁, hs₂, hs₃⟩
  have h_subset : s ⊆ ({1, 101, 103, 107, 10201, 10403, 10609, 10807, 11021, 11449,
      1030301} : Finset ℕ) := by
    intro x hx
    have := hs₁ hx
    rcases this with ⟨i, j, k, rfl⟩
    simp +decide at *
    have := @powTripleSet_101_103_107_le_1030303 (101 ^ i * 103 ^ j * 107 ^ k)
      ⟨i, j, k, rfl⟩ (by linarith [Finset.single_le_sum (fun x _ => Nat.zero_le x) hx])
    aesop
  have h_sum : ∀ t ⊆ ({1, 101, 103, 107, 10201, 10403, 10609, 10807, 11021, 11449,
      1030301} : Finset ℕ), t.sum id = 1030303 → ¬IsDivisionAntichain t := by
    simp +contextual [IsDivisionAntichain]
    native_decide +revert
  exact h_sum s h_subset hs₃ hs₂

/-- A workspace-local Lean 4 stub for Erdos Problem 123. The formal-conjectures repo
contains a current statement very close to this one together with solved variants.

This is a generalization of Erdős Problem 123 (an open problem in additive combinatorics)
to three pairwise coprime generators. No proof or counterexample is currently known.
Computational evidence supports the conjecture for dense cases (small generators like
2, 3, 5) but the problem remains open even for the classical two-generator case.

**Counterexample search results:** We proved that specific numbers (10203 = 101² + 2 and
1030303 = 101³ + 2) are NOT representable as antichain sums from PowTripleSet(101,103,107).
This pattern continues for 101^m + 2 (m ≥ 2) up to approximately m ≈ 80, giving many
non-representable numbers but only finitely many before the argument breaks down. A full
counterexample (infinitely many non-representable numbers for a fixed triple) was not found,
and the conjecture remains open. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

end Erdos123
