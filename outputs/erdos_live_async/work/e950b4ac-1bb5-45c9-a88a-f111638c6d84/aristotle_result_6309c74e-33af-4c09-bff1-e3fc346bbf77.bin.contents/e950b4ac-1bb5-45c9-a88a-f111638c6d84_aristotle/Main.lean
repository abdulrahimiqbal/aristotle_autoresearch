-- counterexample mode target
import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-- A workspace-local Lean 4 stub for Erdos Problem 123. The formal-conjectures repo
contains a current statement very close to this one together with solved variants. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-!
## Counterexample: the most fragile variant

The **pairwise coprimality** hypothesis is the most fragile condition in the
statement above. Dropping it immediately breaks d-completeness.

**Witness:** `a = 2, b = 4, c = 8`.

Then `PowTripleSet 2 4 8 = {2^n | n ∈ ℕ}` because `2^i · 4^j · 8^k = 2^(i+2j+3k)`.
Among powers of 2, any two *distinct* elements satisfy one dividing the other,
so the only `IsDivisionAntichain` subsets of this set are singletons (and ∅).
Consequently, the only representable antichain sums are individual powers of 2
(and 0 for the empty sum). In particular, `3` (and infinitely many other
integers) cannot be represented, so the set is **not** d-complete.
-/

/-
PROBLEM
The fragile variant: same as `erdos_123_d_complete_sequences` but with the
pairwise coprimality hypothesis removed. We show this is **false**.

PROVIDED SOLUTION
Introduce the universal statement, specialize to a=2, b=4, c=8 (all > 1), then apply not_d_complete_248 to get a contradiction.
-/
theorem erdos_123_fragile_variant_is_false :
    ¬ (∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      IsDComplete (PowTripleSet a b c)) := by
  intro h; specialize h 2 4 8; simp_all +decide [ IsDComplete ] ;
  obtain ⟨ a, ha ⟩ := h ; specialize ha ( 2 * a + 3 ) ( by linarith ) ; rcases ha with ⟨ s, hs₁, hs₂, hs₃ ⟩ ; simp_all +decide [ IsDivisionAntichain ] ;
  -- Since $s$ is a subset of $\{2^n \mid n \in \mathbb{N}\}$, all elements of $s$ are powers of 2.
  have h_powers_of_two : ∀ x ∈ s, ∃ n : ℕ, x = 2 ^ n := by
    intro x hx; specialize hs₁ hx; rcases hs₁ with ⟨ i, j, k, rfl ⟩ ; use i + 2 * j + 3 * k; ring;
    norm_num [ pow_mul', ← mul_pow ];
  -- Since $s$ is a subset of $\{2^n \mid n \in \mathbb{N}\}$, all elements of $s$ are distinct powers of 2.
  have h_distinct_powers_of_two : ∀ x ∈ s, ∀ y ∈ s, x ≠ y → x < y ∨ y < x := by
    exact fun x hx y hy hxy => lt_or_gt_of_ne hxy
  have h_sum_powers_of_two : ∑ x ∈ s, x = ∑ n ∈ Finset.image (fun x => Nat.log 2 x) s, 2 ^ n := by
    rw [ Finset.sum_image ];
    · exact Finset.sum_congr rfl fun x hx => by obtain ⟨ n, rfl ⟩ := h_powers_of_two x hx; rw [ Nat.log_pow ( by decide ) ] ;
    · intro x hx y hy; cases h_powers_of_two x hx; cases h_powers_of_two y hy; aesop;
  have h_sum_powers_of_two_lt : ∑ n ∈ Finset.image (fun x => Nat.log 2 x) s, 2 ^ n < 2 * (∑ n ∈ Finset.image (fun x => Nat.log 2 x) s, 2 ^ n) + 3 := by
    bv_omega
  have h_sum_powers_of_two_eq : ∑ n ∈ Finset.image (fun x => Nat.log 2 x) s, 2 ^ n = 2 * a + 3 := by
    grind
  have h_contradiction : ∑ n ∈ Finset.image (fun x => Nat.log 2 x) s, 2 ^ n = 2 * (∑ n ∈ Finset.image (fun x => Nat.log 2 x) s, 2 ^ n) + 3 := by
    have h_contradiction : Finset.card (Finset.image (fun x => Nat.log 2 x) s) = 1 := by
      have h_contradiction : ∀ x ∈ s, ∀ y ∈ s, x ≠ y → False := by
        intros x hx y hy hxy; specialize h_distinct_powers_of_two x hx y hy hxy; rcases h_distinct_powers_of_two with ( h | h ) <;> [ exact hs₂ hx hy hxy ( Nat.dvd_of_mod_eq_zero <| by rw [ Nat.mod_eq_zero_of_dvd ] ; obtain ⟨ n, rfl ⟩ := h_powers_of_two x hx; obtain ⟨ m, rfl ⟩ := h_powers_of_two y hy; exact pow_dvd_pow _ <| Nat.le_of_lt <| Nat.lt_of_not_ge fun hnm => by linarith [ pow_le_pow_right₀ ( show 1 ≤ 2 by decide ) hnm ] ) ; exact hs₂ hy hx ( Ne.symm hxy ) ( Nat.dvd_of_mod_eq_zero <| by rw [ Nat.mod_eq_zero_of_dvd ] ; obtain ⟨ n, rfl ⟩ := h_powers_of_two y hy; obtain ⟨ m, rfl ⟩ := h_powers_of_two x hx; exact pow_dvd_pow _ <| Nat.le_of_lt <| Nat.lt_of_not_ge fun hnm => by linarith [ pow_le_pow_right₀ ( show 1 ≤ 2 by decide ) hnm ] ) ] ;
      generalize_proofs at *; simp_all +decide [ Finset.card_eq_one ] ; (
      exact ⟨ Nat.log 2 ( Classical.choose ( Finset.nonempty_of_ne_empty ( by aesop_cat ) ) ), Finset.eq_singleton_iff_unique_mem.mpr ⟨ Finset.mem_image_of_mem _ ( Classical.choose_spec ( Finset.nonempty_of_ne_empty ( by aesop_cat ) ) ), fun x hx => by obtain ⟨ y, hy, rfl ⟩ := Finset.mem_image.mp hx; exact congr_arg _ ( h_contradiction _ hy _ ( Classical.choose_spec ( Finset.nonempty_of_ne_empty ( by aesop_cat ) ) ) ) ⟩ ⟩ ;)
    obtain ⟨ n, hn ⟩ := Finset.card_eq_one.mp h_contradiction
    simp_all +decide [ Finset.sum_image ];
    have := congr_arg Even hs₃; norm_num [ Nat.even_add, Nat.even_pow ] at this; aesop;
  linarith [h_sum_powers_of_two_lt, h_contradiction]

/-
PROBLEM
============================================================
Helper lemmas for the counterexample
============================================================

Every element of `PowTripleSet 2 4 8` is a power of 2.

PROVIDED SOLUTION
Every element n of PowTripleSet 2 4 8 satisfies n = 2^i * 4^j * 8^k = 2^i * (2^2)^j * (2^3)^k = 2^(i + 2*j + 3*k). So n = 2^m where m = i + 2*j + 3*k.
-/
lemma PowTripleSet_248_subset_pow2 :
    PowTripleSet 2 4 8 ⊆ {n | ∃ m : ℕ, n = 2 ^ m} := by
  intro n hn; obtain ⟨ i, j, k, rfl ⟩ := hn; use i + 2 * j + 3 * k; norm_num [ pow_add, pow_mul, mul_assoc ] ;

/-
PROBLEM
Among powers of 2, any division-antichain has at most one element.

PROVIDED SOLUTION
Suppose s has two distinct elements x, y with x = 2^a, y = 2^b. WLOG a ≤ b (if a = b then x = y, contradicting distinctness). Then x = 2^a divides y = 2^b since a ≤ b and a ≠ b means a < b. This contradicts the antichain property. So s.card ≤ 1 (by contradiction: if card ≥ 2, pick two distinct elements).
-/
lemma antichain_pow2_card_le_one (s : Finset ℕ)
    (hs : (↑s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m})
    (ha : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  -- Assume there are two distinct elements x and y in s.
  by_contra h_contra
  obtain ⟨x, y, hx, hy, hxy⟩ : ∃ x y : ℕ, x ∈ s ∧ y ∈ s ∧ x ≠ y := by
    simpa using Finset.one_lt_card.1 ( lt_of_not_ge h_contra );
  obtain ⟨ a, rfl ⟩ := hs hx; obtain ⟨ b, rfl ⟩ := hs hy; cases le_total a b <;> [ exact ha hx hy hxy ( pow_dvd_pow _ ‹_› ) ; exact ha hy hx ( Ne.symm hxy ) ( pow_dvd_pow _ ‹_› ) ] ;

/-
PROBLEM
3 is not a power of 2.

PROVIDED SOLUTION
By induction/case analysis on m. 2^0=1≠3, 2^1=2≠3, and for m≥2 we have 2^m ≥ 4 > 3.
-/
lemma three_ne_pow2 : ∀ m : ℕ, 3 ≠ 2 ^ m := by
  intro m hm; linarith [ Nat.pow_le_pow_right ( show 1 ≤ 2 by norm_num ) ( show m ≥ 2 by contrapose! hm; interval_cases m <;> trivial ) ] ;

/-
PROBLEM
3 has no antichain sum representation in `PowTripleSet 2 4 8`.

PROVIDED SOLUTION
Suppose s ⊆ PowTripleSet 2 4 8 is an antichain with sum 3. By PowTripleSet_248_subset_pow2, s ⊆ {2^m}. By antichain_pow2_card_le_one, s.card ≤ 1. If s is empty, sum = 0 ≠ 3. If s = {x} for some x = 2^m, then sum = 2^m = 3, contradicting three_ne_pow2.
-/
lemma three_not_antichain_sum_in_248 :
    ¬ ∃ s : Finset ℕ,
      (↑s : Set ℕ) ⊆ PowTripleSet 2 4 8 ∧
        IsDivisionAntichain s ∧ s.sum id = 3 := by
  rintro ⟨ s, hs ⟩ ; have := hs.1 ; simp_all +arith +decide [ IsDivisionAntichain ] ;
  -- Since `s` is a subset of `PowTripleSet 2 4 8`, by `PowTripleSet_248_subset_pow2`, `s` is also a subset of `{2^m | m : ℕ}`.
  have hs_subset_pow2 : (s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m} := by
    exact Set.Subset.trans this ( by exact? );
  -- By `antichain_pow2_card_le_one`, `s` has at most one element.
  have hs_card_le_one : s.card ≤ 1 := by
    exact antichain_pow2_card_le_one s hs_subset_pow2 hs.1;
  interval_cases _ : s.card <;> simp_all +decide [ Set.subset_def ];
  obtain ⟨ x, hx ⟩ := Finset.card_eq_one.mp ‹_›; simp_all +decide [ Finset.sum_singleton ] ;
  exact absurd hs_subset_pow2 ( by rintro ⟨ m, hm ⟩ ; linarith [ Nat.pow_le_pow_right ( show 1 ≤ 2 by norm_num ) ( show m ≥ 2 by contrapose! hm; interval_cases m <;> trivial ) ] ) ;

/-
PROBLEM
`PowTripleSet 2 4 8` is not d-complete.

PROVIDED SOLUTION
Unfold IsDComplete. We need to show that the filter condition ∀ᶠ n in atTop, ... fails. In other words, there exist arbitrarily large n with no antichain sum representation. Use three_not_antichain_sum_in_248 to get that 3 has no representation. Then the eventually condition requires that 3 satisfies the property (since 3 is ≥ any threshold), but it doesn't. More precisely, the negation of ∀ᶠ n in atTop, P n means ∃ᶠ n in atTop, ¬P n, i.e., there are arbitrarily large n with ¬P n. But actually we just need one counterexample: since the filter statement says ∃ N, ∀ n ≥ N, P n, it suffices to show ¬P 3 (since for any N ≤ 3 we have ¬P 3, and for N > 3 the statement is vacuously about n ≥ N > 3 but we need n=3... Actually we need to be more careful.

Actually, ∀ᶠ n in atTop, P n means ∃ N, ∀ n ≥ N, P n. So ¬(∀ᶠ n in atTop, P n) means ∀ N, ∃ n ≥ N, ¬P n. We need infinitely many counterexamples.

Better approach: for any n that is NOT a power of 2, there's no antichain sum representation. Since s.card ≤ 1, the sum is either 0 (empty) or a single power of 2. So the only representable values are 0 and powers of 2. Any odd number ≥ 3 (like 2k+1 for k ≥ 1, giving 3, 5, 7, ...) is not representable. These are arbitrarily large.

So: intro h, unfold IsDComplete at h, rw [Filter.eventually_atTop] at h, obtain ⟨N, hN⟩ := h. Apply hN to n = max N 3 or the first odd number ≥ N. Then show that odd number has no representation. Use three_not_antichain_sum_in_248 style argument generalized, or just pick 2*(max N 2)+1 which is odd and ≥ N.

Actually, the simplest: pick n = 2*N + 3. This is ≥ N and is odd and ≥ 3. Show it's not a power of 2 (since it's odd and > 1). Show it can't be 0. So it has no antichain representation.
-/
lemma not_d_complete_248 : ¬ IsDComplete (PowTripleSet 2 4 8) := by
  -- Assume for contradiction that `PowTripleSet 2 4 8` is d-complete.
  by_contra h_contra

  -- Then there exists an $N$ such that for all $n \geq N$, $n$ can be represented as an antichain sum.
  obtain ⟨N, hN⟩ : ∃ N, ∀ n ≥ N, ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowTripleSet 2 4 8 ∧ IsDivisionAntichain s ∧ s.sum id = n := by
    exact?;
  -- Consider the number $n = 2N + 3$. This number is odd and greater than or equal to $N$.
  set n := 2 * N + 3 with hn_def
  have hn_ge_N : n ≥ N := by
    grind +ring
  have hn_odd : Odd n := by
    grind +ring
  have hn_ne_pow2 : ¬∃ m : ℕ, n = 2 ^ m := by
    grind
  have hn_zero : ¬∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m} ∧ IsDivisionAntichain s ∧ s.sum id = n := by
    rintro ⟨ s, hs₁, hs₂, hs₃ ⟩ ; have := antichain_pow2_card_le_one s hs₁ hs₂; interval_cases _ : s.card <;> simp_all +decide ;
    rw [ Finset.card_eq_one ] at * ; aesop;
  have hn_contradiction : ¬∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowTripleSet 2 4 8 ∧ IsDivisionAntichain s ∧ s.sum id = n := by
    exact fun ⟨ s, hs₁, hs₂, hs₃ ⟩ => hn_zero ⟨ s, fun x hx => by have := hs₁ hx; exact (by
    obtain ⟨ i, j, k, rfl ⟩ := this; exact ⟨ i + 2 * j + 3 * k, by ring_nf; norm_num [ pow_mul' ] ⟩ ;), hs₂, hs₃ ⟩ ;
  have hn_contradiction' : ¬∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ {2^m | m : ℕ} ∧ IsDivisionAntichain s ∧ s.sum id = n := by
    simpa only [ eq_comm ] using hn_zero
  obtain ⟨s, hs⟩ := hN n hn_ge_N
  have hs_subset : (↑s : Set ℕ) ⊆ {2^m | m : ℕ} := by
    exact fun x hx => by obtain ⟨ i, j, k, hi ⟩ := hs.1 hx; exact ⟨ i + 2 * j + 3 * k, by rw [ hi ] ; ring_nf; norm_num [ Nat.pow_add, Nat.pow_mul' ] ⟩ ;
  have hs_antichain : IsDivisionAntichain s := by
    exact hs.2.1
  have hs_sum : s.sum id = n := by
    exact hs.2.2
  exact hn_contradiction' ⟨s, hs_subset, hs_antichain, hs_sum⟩

end Erdos123