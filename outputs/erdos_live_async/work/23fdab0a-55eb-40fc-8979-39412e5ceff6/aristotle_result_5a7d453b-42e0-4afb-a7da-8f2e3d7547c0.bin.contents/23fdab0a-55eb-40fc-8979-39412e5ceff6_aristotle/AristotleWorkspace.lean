import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-! ## Reusable structural lemmas for PowTripleSet -/

/-- 1 belongs to PowTripleSet for any a, b, c. -/
lemma one_mem_PowTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c :=
  ⟨0, 0, 0, by norm_num⟩

/-- Pure powers of `a` belong to PowTripleSet. -/
lemma pow_a_mem (a b c : ℕ) (i : ℕ) : a ^ i ∈ PowTripleSet a b c :=
  ⟨i, 0, 0, by norm_num⟩

/-- Pure powers of `b` belong to PowTripleSet. -/
lemma pow_b_mem (a b c : ℕ) (j : ℕ) : b ^ j ∈ PowTripleSet a b c :=
  ⟨0, j, 0, by norm_num⟩

/-- Pure powers of `c` belong to PowTripleSet. -/
lemma pow_c_mem (a b c : ℕ) (k : ℕ) : c ^ k ∈ PowTripleSet a b c :=
  ⟨0, 0, k, by norm_num⟩

/-- General membership constructor. -/
lemma mem_PowTripleSet_of_eq (a b c : ℕ) {n : ℕ} (i j k : ℕ)
    (h : n = a ^ i * b ^ j * c ^ k) : n ∈ PowTripleSet a b c :=
  ⟨i, j, k, h⟩

/-- All elements of PowTripleSet are positive when generators are positive. -/
lemma pos_of_mem_PowTripleSet {a b c : ℕ} (ha : 0 < a) (hb : 0 < b) (hc : 0 < c)
    {n : ℕ} (hn : n ∈ PowTripleSet a b c) : 0 < n := by
  obtain ⟨i, j, k, rfl⟩ := hn; positivity

/-! ## Key divisibility-extraction lemmas

These are the central reusable lemmas: for pairwise coprime generators,
divisibility between elements of PowTripleSet is equivalent to componentwise
inequality of exponents. This pattern recurs across all parameter triples. -/

/-- Coprimality of powers with coprime bases. -/
lemma coprime_pow_of_coprime {a b : ℕ} (hab : Nat.Coprime a b) (i j : ℕ) :
    Nat.Coprime (a ^ i) (b ^ j) :=
  hab.pow _ _

/-- **Divisibility extraction**: for pairwise coprime a, b, c, if
a^i · b^j · c^k ∣ a^i' · b^j' · c^k', then i ≤ i', j ≤ j', k ≤ k'.
This is the key reusable lemma across all special-case proofs. -/
lemma exponent_le_of_dvd {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {i j k i' j' k' : ℕ}
    (hdvd : a ^ i * b ^ j * c ^ k ∣ a ^ i' * b ^ j' * c ^ k') :
    i ≤ i' ∧ j ≤ j' ∧ k ≤ k' := by
  have h_div_a : a ^ i ∣ a ^ i' := by
    have h_a_div : Nat.Coprime (a ^ i) (b ^ j' * c ^ k') := by
      apply_mod_cast Nat.Coprime.mul_right <;>
        apply_rules [Nat.Coprime.pow, hcop.1, hcop.2.1, hcop.2.2]
    exact h_a_div.dvd_of_dvd_mul_right
      (by obtain ⟨x, hx⟩ := hdvd; exact ⟨x * b ^ j * c ^ k, by nlinarith⟩)
  have h_div_b : b ^ j ∣ b ^ j' := by
    obtain ⟨m, hm⟩ := hdvd
    have h_div_b_coprime : Nat.Coprime (b ^ j) (a ^ i' * c ^ k') := by
      apply_mod_cast Nat.Coprime.mul_right <;>
        apply_rules [Nat.Coprime.pow, hcop.1.symm, hcop.2.1.symm, hcop.2.2]
    exact h_div_b_coprime.dvd_of_dvd_mul_left (by use m * a ^ i * c ^ k; linarith)
  have h_div_c : c ^ k ∣ c ^ k' := by
    have h_div_c : c ^ k ∣ a ^ i' * b ^ j' * c ^ k' :=
      dvd_trans (dvd_mul_left _ _) hdvd
    refine Nat.Coprime.dvd_of_dvd_mul_left ?_ h_div_c
    simp_all +decide [Nat.coprime_mul_iff_left, Nat.coprime_mul_iff_right, PairwiseCoprime3]
    exact ⟨Nat.Coprime.pow _ _ hcop.2.1.symm, Nat.Coprime.pow _ _ hcop.2.2.symm⟩
  exact ⟨Nat.le_of_not_lt fun hi =>
      Nat.not_dvd_of_pos_of_lt (pow_pos (zero_lt_one.trans ha) _)
        (pow_lt_pow_right₀ ha hi) h_div_a,
    Nat.le_of_not_lt fun hj =>
      Nat.not_dvd_of_pos_of_lt (pow_pos (zero_lt_one.trans hb) _)
        (pow_lt_pow_right₀ hb hj) h_div_b,
    Nat.le_of_not_lt fun hk =>
      Nat.not_dvd_of_pos_of_lt (pow_pos (zero_lt_one.trans hc) _)
        (pow_lt_pow_right₀ hc hk) h_div_c⟩

/-- Converse: componentwise ≤ on exponents implies divisibility. -/
lemma dvd_of_exponent_le {a b c : ℕ}
    {i j k i' j' k' : ℕ}
    (hi : i ≤ i') (hj : j ≤ j') (hk : k ≤ k') :
    a ^ i * b ^ j * c ^ k ∣ a ^ i' * b ^ j' * c ^ k' :=
  mul_dvd_mul (mul_dvd_mul (pow_dvd_pow _ hi) (pow_dvd_pow _ hj)) (pow_dvd_pow _ hk)

/-- Divisibility between PowTripleSet elements ↔ componentwise exponent comparison.
This reduces the antichain condition to lattice incomparability in ℕ³. -/
lemma antichain_iff_incomparable_exponents {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ}
    (hne : a ^ i₁ * b ^ j₁ * c ^ k₁ ≠ a ^ i₂ * b ^ j₂ * c ^ k₂) :
    (¬ a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂) ∧
    (¬ a ^ i₂ * b ^ j₂ * c ^ k₂ ∣ a ^ i₁ * b ^ j₁ * c ^ k₁) ↔
    (¬(i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂)) ∧ (¬(i₂ ≤ i₁ ∧ j₂ ≤ j₁ ∧ k₂ ≤ k₁)) := by
  constructor <;> intro H
  · exact ⟨fun h => H.1 <| dvd_of_exponent_le h.1 h.2.1 h.2.2,
           fun h => H.2 <| dvd_of_exponent_le h.1 h.2.1 h.2.2⟩
  · constructor <;> intro h <;> have := exponent_le_of_dvd ha hb hc hcop h <;> aesop

/-! ## Antichain infrastructure -/

/-- The empty set is a division antichain. -/
lemma isDivisionAntichain_empty : IsDivisionAntichain ∅ := by tauto

/-- A singleton set is a division antichain. -/
lemma isDivisionAntichain_singleton (x : ℕ) : IsDivisionAntichain {x} := by
  intro x₁ x₂ h₁ h₂ hne
  simp at h₁ h₂; exact absurd (h₁.trans h₂.symm) hne

/-- If two naturals > 1 are coprime, {x, y} is a division antichain. -/
lemma isDivisionAntichain_pair {x y : ℕ} (hxy : x ≠ y)
    (hx : 1 < x) (hy : 1 < y) (hcop : Nat.Coprime x y) :
    IsDivisionAntichain {x, y} := by
  simp_all +decide [IsDivisionAntichain]
  rintro a b (rfl | rfl) (rfl | rfl) <;> simp_all +decide [Nat.Coprime]
  · exact fun h => by have := Nat.gcd_eq_left h; aesop
  · exact fun h => fun h' => by have := Nat.gcd_eq_right h'; aesop

/-! ## Concrete boundary case: the triple (2, 3, 5)

The smallest pairwise coprime triple of primes. We verify structural
properties that ground the d-completeness conjecture. -/

/-- The triple (2, 3, 5) is pairwise coprime. -/
lemma pairwiseCoprime_2_3_5 : PairwiseCoprime3 2 3 5 := by
  constructor <;> decide

/-- Concrete elements of PowTripleSet 2 3 5. -/
lemma mem_235 : (1 : ℕ) ∈ PowTripleSet 2 3 5 ∧
    2 ∈ PowTripleSet 2 3 5 ∧ 3 ∈ PowTripleSet 2 3 5 ∧
    4 ∈ PowTripleSet 2 3 5 ∧ 5 ∈ PowTripleSet 2 3 5 ∧
    6 ∈ PowTripleSet 2 3 5 ∧ 8 ∈ PowTripleSet 2 3 5 ∧
    9 ∈ PowTripleSet 2 3 5 ∧ 10 ∈ PowTripleSet 2 3 5 ∧
    12 ∈ PowTripleSet 2 3 5 ∧ 15 ∈ PowTripleSet 2 3 5 ∧
    16 ∈ PowTripleSet 2 3 5 ∧ 20 ∈ PowTripleSet 2 3 5 ∧
    25 ∈ PowTripleSet 2 3 5 ∧ 27 ∈ PowTripleSet 2 3 5 := by
  exact ⟨⟨0,0,0,rfl⟩, ⟨1,0,0,rfl⟩, ⟨0,1,0,rfl⟩, ⟨2,0,0,rfl⟩, ⟨0,0,1,rfl⟩,
    ⟨1,1,0,rfl⟩, ⟨3,0,0,rfl⟩, ⟨0,2,0,rfl⟩, ⟨1,0,1,rfl⟩,
    ⟨2,1,0,rfl⟩, ⟨0,1,1,rfl⟩, ⟨4,0,0,rfl⟩, ⟨2,0,1,rfl⟩,
    ⟨0,0,2,rfl⟩, ⟨0,3,0,rfl⟩⟩

/-! ## Reformulated boundary theorems: generator antichains

For pairwise coprime a, b, c > 1, the triple {a, b, c} itself forms a
3-element division antichain inside PowTripleSet. More generally,
elements with "cross-support" exponents (e.g., a·c vs b) are pairwise
non-dividing. This boundary structure is the seed from which larger
antichain sum representations grow. -/

/-- For pairwise coprime a, b, c > 1, the generators {a, b, c} form a
3-element division antichain in PowTripleSet. This is the extremal
boundary case: the simplest nontrivial antichain. -/
theorem boundary_antichain_generators {a b c : ℕ}
    (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    (hab : a ≠ b) (hac : a ≠ c) (hbc : b ≠ c) :
    let s : Finset ℕ := {a, b, c}
    (↑s : Set ℕ) ⊆ PowTripleSet a b c ∧
    IsDivisionAntichain s ∧
    s.sum id = a + b + c := by
  refine ⟨?_, ?_, ?_⟩
  · simp +zetaDelta at *
    rintro x (rfl | rfl | rfl) <;>
      [exact ⟨1, 0, 0, by ring⟩; exact ⟨0, 1, 0, by ring⟩; exact ⟨0, 0, 1, by ring⟩]
  · intro x hx y hy hxy
    contrapose! hxy; have := Nat.gcd_eq_left hxy
    simp_all +decide [PairwiseCoprime3]
    rcases y with (rfl | rfl | rfl) <;> rcases hy with (rfl | rfl | rfl) <;>
      simp_all +decide [Nat.Coprime, Nat.Coprime.symm]
  · simp +decide [*, add_assoc]

/-- For pairwise coprime a, b, c > 1, the "cross-support" pair {a·b, c}
forms a 2-element antichain. Elements whose exponent supports don't
dominate each other are automatically non-dividing. -/
theorem boundary_cross_support_antichain {a b c : ℕ}
    (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) :
    let s : Finset ℕ := {a * b, c}
    (↑s : Set ℕ) ⊆ PowTripleSet a b c ∧
    IsDivisionAntichain s := by
  refine ⟨?_, ?_⟩
  · norm_num [Set.insert_subset_iff, Set.singleton_subset_iff]
    exact ⟨⟨1, 1, 0, by ring⟩, ⟨0, 0, 1, by ring⟩⟩
  · intro x y
    have h_coprime : Nat.Coprime (a * b) c :=
      Nat.Coprime.mul_left hcop.2.1 hcop.2.2
    simp
    rintro (rfl | rfl) (rfl | rfl) <;> simp_all +decide [Nat.Coprime, Nat.Coprime.symm]
    · exact fun h => fun h' => h <| by have := Nat.gcd_eq_left h'; aesop
    · exact fun h => fun hx => h <| by have := Nat.gcd_eq_right hx; aesop

/-! ## Main conjecture

**Erdős Problem 123** is a deep open conjecture in additive combinatorics.
The helper lemmas proved above — especially `exponent_le_of_dvd`,
`antichain_iff_incomparable_exponents`, and `dvd_of_exponent_le` — form
the reusable infrastructure that any proof strategy would build on.

### Discovery: Reusable covering / divisibility-extraction lemmas

The following lemmas recur across all special parameter triples
(2,3,5), (2,3,7), (2,5,7), etc.:

1. **`exponent_le_of_dvd`** — The central divisibility-extraction lemma.
   Reduces divisibility questions to componentwise exponent comparison.
   Strong enough to promote to any proof involving pairwise coprime generators.

2. **`dvd_of_exponent_le`** — The converse direction. Together with (1),
   gives a complete characterization of divisibility in PowTripleSet.

3. **`antichain_iff_incomparable_exponents`** — Reduces the antichain
   condition to lattice incomparability in ℕ³. This transforms
   the d-completeness problem into a purely combinatorial question
   about antichain decompositions and subset sums in ℕ³.

4. **`coprime_pow_of_coprime`** — Foundation for all coprimality arguments.

5. **`pos_of_mem_PowTripleSet`** — Positivity of elements; needed for
   well-foundedness arguments in greedy constructions.

These five lemmas together reduce any d-completeness argument to:
"Given n, find an antichain in the exponent lattice ℕ³ whose images
under (i,j,k) ↦ a^i·b^j·c^k sum to n."

The original Erdős Problem 123 conjecture (d-completeness for all
pairwise coprime triples) remains open. The boundary theorems
`boundary_antichain_generators` and `boundary_cross_support_antichain`
verify the extremal seed case — the simplest nontrivial antichains
from which larger representations would be built. -/

end Erdos123
