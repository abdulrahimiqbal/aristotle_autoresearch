-- erdos-123 focus: d-completeness, divisibility antichains, and reusable covering lemmas
import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-! ## Parameter extreme: boundary cases where d-completeness fails

### Discovery: Which d-completeness boundary cases fail because interval-style
coverage cannot be upgraded to a divisibility antichain?

The sharpest witness is the **non-coprime degeneration**: when the three generators
share a common prime factor `p`, the entire set `PowTripleSet a b c` collapses into
the set of powers of `p` (a totally ordered chain under divisibility). In a chain,
every divisibility antichain has at most one element, so the only representable sums
are individual elements of the set. Since powers of `p` are exponentially sparse,
most integers are not representable, and d-completeness fails catastrophically.

**Concrete witness**: `(a, b, c) = (2, 4, 8)`.
  - `PowTripleSet 2 4 8 = {2^n | n ∈ ℕ}` (since `4 = 2²` and `8 = 2³`).
  - Every divisibility antichain in this set has cardinality ≤ 1.
  - Therefore the set is not d-complete: the number `3` (or any non-power-of-2)
    is never representable as a sum of an antichain from the set.

This is the "parameter extreme" — it shows that the coprimality hypothesis in
Erdős Problem 123 is *essential*, not merely technical. Without it, interval-style
coverage (summing distinct elements to cover an interval) is impossible to achieve
with an antichain constraint, because the divisibility structure is maximally bad.
-/

/-
PROBLEM
============================================================================
Part 1: Every element of PowTripleSet 2 4 8 is a power of 2
============================================================================

Every element of `PowTripleSet 2 4 8` is a power of 2.

PROVIDED SOLUTION
Unfold PowTripleSet. Given n = 2^i * 4^j * 8^k, rewrite 4 = 2^2 and 8 = 2^3, so n = 2^i * (2^2)^j * (2^3)^k = 2^(i + 2*j + 3*k). Use m = i + 2*j + 3*k.
-/
lemma powTripleSet_248_eq_pow2 :
    ∀ n : ℕ, n ∈ PowTripleSet 2 4 8 → ∃ m : ℕ, n = 2 ^ m := by
  rintro _ ⟨ k, l, m, rfl ⟩ ; exact ⟨ k + 2 * l + 3 * m, by ring_nf; norm_num [ pow_add, pow_mul' ] ⟩ ;

/-
PROBLEM
============================================================================
Part 2: Powers of 2 form a chain under divisibility
============================================================================

Among two distinct powers of 2, one always divides the other.

PROVIDED SOLUTION
Let a = 2^m and b = 2^n. Since a ≠ b, m ≠ n. WLOG m < n or n < m. If m ≤ n then 2^m | 2^n so a | b. If n ≤ m then b | a. Use Nat.pow_dvd_pow and le_or_ge.
-/
lemma pow2_divides_of_ne {a b : ℕ} (ha : ∃ m, a = 2 ^ m) (hb : ∃ n, b = 2 ^ n)
    (hab : a ≠ b) : a ∣ b ∨ b ∣ a := by
  rcases ha with ⟨ m, rfl ⟩ ; rcases hb with ⟨ n, rfl ⟩ ; cases' le_total m n <;> simp +decide [ *, pow_dvd_pow_iff ] ;

/-
PROBLEM
============================================================================
Part 3: Any divisibility antichain of powers of 2 has at most one element
============================================================================

A divisibility antichain consisting entirely of powers of 2 has at most
one element.

PROVIDED SOLUTION
By contradiction. Assume s.card ≥ 2. Then there exist distinct x, y ∈ s with x ≠ y. By hs, both are powers of 2. By pow2_divides_of_ne, x | y ∨ y | x. But ha (IsDivisionAntichain) says neither can divide the other. Contradiction.
-/
lemma antichain_pow2_card_le_one (s : Finset ℕ) (hs : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (ha : IsDivisionAntichain s) : s.card ≤ 1 := by
  contrapose ha;
  obtain ⟨ x, hx, y, hy, hxy ⟩ := Finset.one_lt_card.1 ( lt_of_not_ge ha );
  exact fun h => hxy <| by obtain ⟨ m, rfl ⟩ := hs x hx; obtain ⟨ n, rfl ⟩ := hs y hy; exact ( pow2_divides_of_ne ⟨ m, rfl ⟩ ⟨ n, rfl ⟩ hxy ) |> Or.rec ( fun h' => by have := h hx hy hxy; tauto ) fun h' => by have := h hy hx ( Ne.symm hxy ) ; tauto;

/-
PROBLEM
============================================================================
Part 4: The set PowTripleSet 2 4 8 is NOT d-complete
============================================================================

3 cannot be represented as an antichain sum from `PowTripleSet 2 4 8`.

PROVIDED SOLUTION
Suppose s is an antichain subset of PowTripleSet 2 4 8 with sum 3. By powTripleSet_248_eq_pow2, all elements are powers of 2. By antichain_pow2_card_le_one, s.card ≤ 1. If s.card = 0, sum = 0 ≠ 3. If s.card = 1, the single element is 2^m for some m, and 2^m = 3 has no solution in ℕ (since powers of 2 are 1, 2, 4, 8, ..., never 3). Contradiction.
-/
lemma three_not_antichain_sum_248 :
    ¬ ∃ s : Finset ℕ,
      (↑s : Set ℕ) ⊆ PowTripleSet 2 4 8 ∧ IsDivisionAntichain s ∧ s.sum id = 3 := by
  -- Suppose s is an antichain subset of PowTripleSet 2 4 8 with sum 3.
  by_contra h
  obtain ⟨s, hs⟩ := h;
  -- By powTripleSet_248_eq_pow2, all elements are powers of 2.
  have hs_pow2 : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m := by
    exact fun x hx => powTripleSet_248_eq_pow2 x ( hs.1 hx );
  -- By antichain_pow2_card_le_one, s.card ≤ 1.
  have hs_card : s.card ≤ 1 := by
    exact antichain_pow2_card_le_one s hs_pow2 hs.2.1;
  interval_cases _ : #s <;> simp_all +decide;
  rw [ Finset.card_eq_one ] at *;
  rcases ‹_› with ⟨ a, rfl ⟩ ; simp_all +decide;
  exact absurd hs_pow2 ( by rintro ⟨ m, hm ⟩ ; linarith [ Nat.pow_le_pow_right ( show 1 ≤ 2 by norm_num ) ( show m ≥ 2 by contrapose! hm; interval_cases m <;> trivial ) ] )

/-
PROBLEM
`PowTripleSet 2 4 8` is not d-complete — the parameter extreme witness.
This demonstrates that the coprimality hypothesis in Erdős Problem 123 is essential:
when generators share a common factor, the set degenerates into a divisibility chain
and interval-style coverage cannot be upgraded to antichain coverage.

PROVIDED SOLUTION
Unfold IsDComplete. The filter atTop condition means for all sufficiently large n, there exists an antichain sum. We need to show this fails. Use three_not_antichain_sum_248 to show n=3 has no antichain sum representation. Since 3 is eventually reached by atTop, and the property fails at n=3, the set is not d-complete. Formally: IsDComplete means ∀ᶠ n in atTop, P n. We have ¬P 3 from three_not_antichain_sum_248. But ∀ᶠ n in atTop means ∃ N, ∀ n ≥ N, P n. For any such N, picking n = max N 3 ≥ 3 would require P (max N 3). But actually we can't directly get P 3 since n might need to be ≥ N > 3.

Better approach: show ¬P n for infinitely many n. Actually, every odd number > 1 that is not a power of 2 fails. Or more simply: show that for ALL n, if n is not a power of 2 then ¬P n. Since there are arbitrarily large non-powers-of-2, this contradicts ∀ᶠ.

Specifically: For any n that is odd and > 1 (like 2k+1 for k ≥ 1), n is not a power of 2, so it has no antichain sum representation. Since there are infinitely many such n, ∀ᶠ fails.

Actually simpler: show that ¬P n whenever n is odd and n > 1. Any antichain sum has card ≤ 1, so n must be a single power of 2, but odd n > 1 is never a power of 2. Since odd numbers are cofinal in atTop, this contradicts the eventually condition.

Even simpler: show ∀ n, ¬(2 ∣ n) → n ≠ 1 → n ≠ 0 → ¬P n. Then 3 is such an n. But the eventually condition means ∃ N, ∀ n ≥ N, P n. Take any N, then 2*N + 1 ≥ N is odd and > 1, contradiction.

Key structure: unfold IsDComplete, get ∃ N, ∀ n ≥ N, P n. Take N. Consider n = 2*N + 1 ≥ N. Show ¬P(2*N+1). Any antichain s has card ≤ 1, so sum is either 0 or 2^m. But 2*N+1 is odd and positive, so it's not 0 and not a power of 2 (for m ≥ 1), and it's not 1 = 2^0 when N ≥ 1. Actually 2*N+1 ≥ 3 when N ≥ 1. So 2*N+1 ≠ 2^m for any m. If N = 0 then 2*0+1=1=2^0. Hmm. Use n = 2*N + 3 instead, which is always ≥ 3 and odd.
-/
theorem not_d_complete_powTripleSet_248 :
    ¬ IsDComplete (PowTripleSet 2 4 8) := by
  -- By definition of $IsDComplete$, there exists some natural number $N$ such that for all $n \geq N$, $n$ can be represented as a sum of distinct elements from $A$.
  by_contra h
  obtain ⟨N, hN⟩ : ∃ N, ∀ n ≥ N, ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆PowTripleSet 2 4 8 ∧ (IsDivisionAntichain s) ∧ s.sum id = n := by
    exact mem_atTop_sets.mp h;
  obtain ⟨ s, hs₁, hs₂, hs₃ ⟩ := hN ( 2 * N + 3 ) ( by linarith );
  -- By Lemma `antichain_pow2_card_le_one`, $s$ can contain at most one element.
  have hs_card : s.card ≤ 1 := by
    exact antichain_pow2_card_le_one s ( fun x hx => powTripleSet_248_eq_pow2 x ( hs₁ hx ) ) hs₂;
  cases hs_card.eq_or_lt <;> simp_all +arith +decide;
  rw [ Finset.card_eq_one ] at *;
  obtain ⟨ a, rfl ⟩ := ‹_›; simp_all +arith +decide;
  obtain ⟨ i, j, k, h ⟩ := hs₁;
  have := congr_arg Even h ; norm_num [ parity_simps ] at this;
  aesop

-- ============================================================================
-- Part 5: The main conjecture (open problem)
-- ============================================================================

/-- **Erdős Problem 123** (open). When `a`, `b`, `c` are pairwise coprime integers
greater than 1, the set `{a^i · b^j · c^k}` is d-complete. This remains an open
problem in combinatorial number theory. The sorry here reflects the open status. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

end Erdos123