-- erdos family workspace
-- focus: extremal constructions, additive structure, and parameter boundary behavior
-- erdos-123 focus: d-completeness, divisibility antichains, and reusable covering lemmas
import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-!
## Erdős Problem 123 — Main Conjecture (Open)

The conjecture states that for any pairwise coprime triple a, b, c > 1,
the set `PowTripleSet a b c` is d-complete. This is an open problem in
additive combinatorics and we leave it as `sorry`.
-/

/-- Erdős Problem 123: for pairwise coprime a, b, c > 1, the multiplicative
semigroup they generate is d-complete. **Open conjecture.** -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-!
## Parameter Extreme: Boundary Counterexample

**Discovery question:** Which d-completeness boundary cases fail because
interval-style coverage cannot be upgraded to a divisibility antichain,
and what is the sharpest witness?

**Answer:** The sharpest witness is the triple `(a, b, c) = (2, 4, 8)`,
where all three generators are powers of a common base. In this case,
`PowTripleSet 2 4 8` is a subset of `{2^n | n ≥ 0}`, and any two distinct
elements are comparable under divisibility. Hence every divisibility antichain
is a singleton (or empty), the achievable sums are just individual powers of 2,
and d-completeness fails spectacularly—not even the number 3 is representable.

More precisely, "interval-style coverage" refers to the fact that sums of
powers of 2 can represent all positive integers (binary representation), so
one might naïvely claim d-completeness. But the antichain constraint kills this:
in binary representation, distinct powers of 2 are always divisibility-comparable,
so no multi-element antichain sum exists. The boundary is exactly the failure
of pairwise coprimality.
-/

/-- Every element of `PowTripleSet 2 4 8` is a power of 2. -/
lemma powTripleSet_248_subset_pow2 :
    PowTripleSet 2 4 8 ⊆ {n | ∃ m : ℕ, n = 2 ^ m} := by
  intro n hn
  obtain ⟨i, j, k, hn_eq⟩ := hn
  use i + 2 * j + 3 * k
  rw [hn_eq]
  ring_nf
  norm_num [pow_mul']

/-- Among distinct powers of 2, one always divides the other. -/
lemma pow2_dvd_of_ne {a b : ℕ} (ha : ∃ m, a = 2 ^ m) (hb : ∃ n, b = 2 ^ n)
    (hab : a ≠ b) : a ∣ b ∨ b ∣ a := by
  obtain ⟨m, rfl⟩ := ha
  obtain ⟨n, rfl⟩ := hb
  cases le_total m n <;> simp +decide [*, pow_dvd_pow_iff]

/-- A divisibility antichain of powers of 2 has at most one element. -/
lemma antichain_pow2_card_le_one (s : Finset ℕ)
    (hs : (↑s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m})
    (hac : IsDivisionAntichain s) : s.card ≤ 1 := by
  exact Nat.le_of_not_lt fun h => by
    obtain ⟨x, hx, y, hy, hxy⟩ := Finset.one_lt_card.1 h
    exact hac hx hy hxy <|
      pow2_dvd_of_ne (hs hx) (hs hy) hxy |>.resolve_right <| hac hy hx hxy.symm

/-- 3 is not a power of 2. -/
lemma three_not_pow2 : ¬∃ m : ℕ, 3 = 2 ^ m := by
  exact fun ⟨m, hm⟩ => by
    linarith [Nat.pow_le_pow_right (show 1 ≤ 2 by decide)
      (show m ≥ 2 by contrapose! hm; interval_cases m <;> trivial)]

/-- The set `PowTripleSet 2 4 8` is **not** d-complete.
This is the sharpest witness for the parameter extreme boundary:
interval-style coverage (every ℕ is a sum of distinct powers of 2) cannot
be upgraded to a divisibility-antichain sum because all generators share
the common base 2, making every pair divisibility-comparable. -/
theorem not_d_complete_248 : ¬ IsDComplete (PowTripleSet 2 4 8) := by
  unfold IsDComplete
  simp
  intro x
  use 2 * x + 3
  refine ⟨by linarith, fun s hs ha hsum => ?_⟩
  have hs_card : s.card ≤ 1 := by
    apply_rules [antichain_pow2_card_le_one]
    exact fun x hx => powTripleSet_248_subset_pow2 (hs hx)
  interval_cases _ : s.card <;> simp_all +decide [Finset.card_eq_one]
  obtain ⟨a, rfl⟩ := ‹_›
  simp_all +decide [IsDivisionAntichain]
  obtain ⟨i, j, k, h⟩ := hs
  have := congr_arg Even h
  norm_num [parity_simps] at this
  aesop

end Erdos123
