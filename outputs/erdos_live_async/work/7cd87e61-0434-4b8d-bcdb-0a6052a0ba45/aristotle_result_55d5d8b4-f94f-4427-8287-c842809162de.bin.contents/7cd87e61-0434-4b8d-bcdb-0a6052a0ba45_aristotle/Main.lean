import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-- A workspace-local Lean 4 stub for Erdős Problem 123. This is a deep open problem
in combinatorial number theory; the formal proof is beyond the scope of current
automated methods. The statement asserts that for pairwise coprime `a, b, c > 1`,
the multiplicative semigroup `{a^i · b^j · c^k}` is d-complete. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-! ## Counterexample: dropping pairwise coprimality

The "most fragile variant" of the theorem is the one where the pairwise coprimality
condition `PairwiseCoprime3 a b c` is dropped. We show that this variant is **false**
by exhibiting a concrete counterexample: `a = 2, b = 4, c = 8`.

### Key observations

1. `PowTripleSet 2 4 8 ⊆ {2^n | n ∈ ℕ}` — every element is a power of 2.
2. Powers of 2 are totally ordered by divisibility: if `2^i ≠ 2^j` then one divides
   the other.
3. Therefore any division antichain drawn from powers of 2 has at most one element.
4. A singleton antichain can only sum to a single power of 2.
5. Not every sufficiently large natural number is a power of 2.
6. Hence `PowTripleSet 2 4 8` is **not** d-complete.
-/

/-- Every element of `PowTripleSet 2 4 8` is a power of 2. -/
lemma powTripleSet_248_subset_pow2 :
    PowTripleSet 2 4 8 ⊆ {n | ∃ m : ℕ, n = 2 ^ m} := by
  intro n hn
  obtain ⟨i, j, k, rfl⟩ := hn
  exact ⟨i + 2 * j + 3 * k, by norm_num [pow_add, pow_mul, mul_assoc]⟩

/-- Among powers of 2, any two distinct elements satisfy a divisibility relation. -/
lemma pow2_division_chain (x y : ℕ) (hx : ∃ a, x = 2 ^ a) (hy : ∃ b, y = 2 ^ b)
    (hne : x ≠ y) : x ∣ y ∨ y ∣ x := by
  rcases hx with ⟨a, rfl⟩; rcases hy with ⟨b, rfl⟩
  cases le_total a b <;> simp +decide [*, pow_dvd_pow]

/-- A division antichain drawn from powers of 2 has at most one element. -/
lemma antichain_pow2_card_le_one (s : Finset ℕ)
    (hs : (↑s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m})
    (ha : IsDivisionAntichain s) : s.card ≤ 1 := by
  by_contra h
  obtain ⟨x, y, hx, hy, hxy⟩ : ∃ x ∈ s, ∃ y ∈ s, x ≠ y :=
    Finset.one_lt_card.1 (lt_of_not_ge h)
  exact ha y hy hxy (pow2_division_chain _ _ (hs y) (hs hy) hxy |>.resolve_right <|
    by simpa [hxy.symm] using ha hy y (Ne.symm hxy))

/-- Not every sufficiently large natural number is a power of 2. -/
lemma not_eventually_pow2 :
    ¬ (∀ᶠ n : ℕ in atTop, ∃ m : ℕ, n = 2 ^ m) := by
  simp +zetaDelta
  intro n
  use 2 ^ (n + 1) + 1
  exact ⟨Nat.le_succ_of_le (Nat.le_of_lt (Nat.recOn n (by norm_num)
    fun n ihn => by norm_num [Nat.pow_succ] at *; linarith)),
    fun x hx => by have := congr_arg Even hx; norm_num [Nat.even_add, Nat.even_pow] at this; aesop⟩

/-- **Counterexample**: the variant of Erdős 123 without pairwise coprimality is false.
Specifically, `PowTripleSet 2 4 8` is NOT d-complete, even though `2 > 1`, `4 > 1`, `8 > 1`.
This witnesses that the coprimality hypothesis is essential and cannot be dropped. -/
theorem fragile_variant_counterexample :
    ¬ IsDComplete (PowTripleSet 2 4 8) := by
  by_contra h_dc
  obtain ⟨N, hN⟩ : ∃ N, ∀ n > N, ∃ s : Finset ℕ,
      (s : Set ℕ) ⊆ PowTripleSet 2 4 8 ∧ IsDivisionAntichain s ∧ s.sum id = n :=
    Filter.eventually_atTop.mp h_dc |>.imp fun N hN n hn => hN n hn.le
  obtain ⟨n, hn_gt, hn_not_pow2⟩ : ∃ n > N, ¬∃ m : ℕ, n = 2 ^ m :=
    ⟨2 * N + 3, by linarith, fun ⟨m, hm⟩ => by
      have := congr_arg Even hm; norm_num [Nat.even_add, Nat.even_pow] at this; aesop⟩
  obtain ⟨s, hs₁, hs₂, hs₃⟩ := hN n hn_gt
  have hs_pow2 : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m :=
    fun x hx => powTripleSet_248_subset_pow2 <| hs₁ hx
  have hs_card : s.card ≤ 1 :=
    antichain_pow2_card_le_one s hs_pow2 hs₂
  rw [Finset.card_le_one_iff_subset_singleton] at hs_card; aesop

end Erdos123
