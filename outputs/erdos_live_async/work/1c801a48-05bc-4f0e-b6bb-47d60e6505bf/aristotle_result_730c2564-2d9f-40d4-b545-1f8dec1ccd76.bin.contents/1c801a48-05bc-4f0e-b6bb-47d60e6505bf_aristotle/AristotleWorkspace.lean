/-
Counterexample: The "most fragile variant" of Erdős Problem 123.

The original theorem asserts d-completeness of PowTripleSet a b c under the
hypotheses 1 < a, 1 < b, 1 < c, AND PairwiseCoprime3 a b c. The most
fragile variant drops the pairwise coprimality condition. We exhibit a
concrete falsifying witness: a = b = c = 2. In this case:
  • PowTripleSet 2 2 2 = {2^n : n ∈ ℕ},
  • powers of 2 are totally ordered by divisibility,
  • any division antichain in this set has cardinality ≤ 1,
  • hence every antichain sum is either 0 or a single power of 2,
  • so no odd number ≥ 3 is ever representable as such a sum,
  • and IsDComplete fails.
-/
import Mathlib

noncomputable section

open Filter Finset
open scoped BigOperators Pointwise

namespace Erdos123

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

-- ═══════════════════════════════════════════════════════════════════
-- §1. PowTripleSet 2 2 2 consists exactly of powers of 2
-- ═══════════════════════════════════════════════════════════════════

lemma mem_powTripleSet_222 (n : ℕ) :
    n ∈ PowTripleSet 2 2 2 ↔ ∃ m : ℕ, n = 2 ^ m := by
  constructor
  · rintro ⟨i, j, k, rfl⟩
    exact ⟨i + j + k, by ring⟩
  · rintro ⟨m, rfl⟩
    exact ⟨m, 0, 0, by ring⟩

-- ═══════════════════════════════════════════════════════════════════
-- §2. Powers of 2 are totally ordered by divisibility
-- ═══════════════════════════════════════════════════════════════════

lemma pow_two_dvd_iff {a b : ℕ} : 2 ^ a ∣ 2 ^ b ↔ a ≤ b := by
  exact Nat.pow_dvd_pow_iff_le_right (by norm_num : 1 < 2)

lemma pow_two_dvd_or_dvd (a b : ℕ) : 2 ^ a ∣ 2 ^ b ∨ 2 ^ b ∣ 2 ^ a := by
  rw [pow_two_dvd_iff, pow_two_dvd_iff]
  exact le_total a b

/-
PROBLEM
═══════════════════════════════════════════════════════════════════
§3. A division antichain in powers of 2 has at most one element
═══════════════════════════════════════════════════════════════════

In a set where every pair is comparable by divisibility, any division
antichain has at most one element.

PROVIDED SOLUTION
By contradiction: if s has ≥ 2 elements, pick two distinct elements x, y ∈ s. Since s ⊆ PowTripleSet 2 2 2, by mem_powTripleSet_222 both x and y are powers of 2. By pow_two_dvd_or_dvd, either x ∣ y or y ∣ x. Since x ≠ y (distinct elements), this contradicts IsDivisionAntichain.
-/
lemma antichain_subsingleton_of_total_dvd
    (s : Finset ℕ)
    (hs : (↑s : Set ℕ) ⊆ PowTripleSet 2 2 2)
    (ha : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  contrapose! ha;
  obtain ⟨ x, hx, y, hy, hxy ⟩ := Finset.one_lt_card.mp ha;
  obtain ⟨ m, rfl ⟩ := mem_powTripleSet_222 x |>.1 ( hs hx ) ; obtain ⟨ n, rfl ⟩ := mem_powTripleSet_222 y |>.1 ( hs hy ) ; cases lt_or_gt_of_ne hxy <;> simp_all +decide [ pow_two_dvd_or_dvd ] ;
  · exact fun h => h hx hy ( ne_of_lt ‹_› ) ( dvd_trans ( pow_dvd_pow _ ( Nat.le_of_lt ( Nat.lt_of_not_ge fun hmn => by linarith [ pow_le_pow_right₀ ( by decide : 1 ≤ 2 ) hmn ] ) ) ) ( dvd_refl _ ) );
  · exact fun h => h hy hx ( by aesop ) ( Nat.dvd_of_mod_eq_zero ( by rw [ Nat.mod_eq_zero_of_dvd ] ; exact pow_dvd_pow _ ( Nat.le_of_lt ( Nat.lt_of_not_ge fun hmn => by linarith [ pow_le_pow_right₀ ( by decide : 1 ≤ 2 ) hmn ] ) ) ) )

/-
PROBLEM
═══════════════════════════════════════════════════════════════════
§4. A singleton antichain sum is a power of 2, so odd n ≥ 3 fail
═══════════════════════════════════════════════════════════════════

If a finset in PowTripleSet 2 2 2 is a division antichain, its sum is
either 0 (empty) or a single power of 2.

PROVIDED SOLUTION
By antichain_subsingleton_of_total_dvd, s.card ≤ 1. If s is empty, sum is 0 (left case). If s = {x} for some x, then x ∈ PowTripleSet 2 2 2, so by mem_powTripleSet_222, x = 2^m for some m. The sum is x = 2^m (right case).
-/
lemma antichain_sum_eq_zero_or_pow_two
    (s : Finset ℕ)
    (hs : (↑s : Set ℕ) ⊆ PowTripleSet 2 2 2)
    (ha : IsDivisionAntichain s) :
    s.sum id = 0 ∨ ∃ m : ℕ, s.sum id = 2 ^ m := by
  by_cases h : s.Nonempty;
  · -- If $s$ is nonempty, then by antichain_subsingleton_of_total_dvd, $s$ must be a singleton set.
    obtain ⟨x, hx⟩ : ∃ x, s = {x} := by
      exact Finset.card_eq_one.mp ( le_antisymm ( antichain_subsingleton_of_total_dvd s hs ha ) ( Finset.card_pos.mpr h ) );
    simp_all +decide [ Set.subset_def ];
    exact Or.inr ( by rcases hs with ⟨ i, j, k, rfl ⟩ ; exact ⟨ i + j + k, by ring ⟩ );
  · aesop

/-
PROBLEM
3 is never representable as a division-antichain sum from PowTripleSet 2 2 2.

PROVIDED SOLUTION
Suppose s is a finset with s ⊆ PowTripleSet 2 2 2, IsDivisionAntichain s, and s.sum id = 3. By antichain_sum_eq_zero_or_pow_two, s.sum id = 0 or s.sum id = 2^m. If 0, then 0 ≠ 3, contradiction. If 2^m = 3, then 3 is a power of 2, but no power of 2 equals 3 (check: 2^0=1, 2^1=2, 2^2=4 > 3, and powers of 2 are monotone increasing for m ≥ 2). Contradiction.
-/
lemma three_not_representable :
    ¬ ∃ s : Finset ℕ,
      (↑s : Set ℕ) ⊆ PowTripleSet 2 2 2 ∧
      IsDivisionAntichain s ∧
      s.sum id = 3 := by
  simp +zetaDelta at *;
  intro s hs ha;
  by_contra h_contra;
  -- By antichain_sum_eq_zero_or_pow_two, s.sum id = 0 or s.sum id = 2^m.
  obtain ⟨m, hm⟩ : ∃ m : ℕ, s.sum id = 2 ^ m := by
    have := antichain_sum_eq_zero_or_pow_two s hs ha; aesop;
  exact absurd hm ( by erw [ h_contra ] ; intro con; linarith [ Nat.pow_le_pow_right ( show 1 ≤ 2 by decide ) ( show m ≥ 2 by contrapose! con; interval_cases m <;> trivial ) ] )

/-
PROBLEM
═══════════════════════════════════════════════════════════════════
§5. Infinitely many failures ⟹ ¬IsDComplete
═══════════════════════════════════════════════════════════════════

Every odd number ≥ 3 fails to be representable. Since there are
arbitrarily large odd numbers, IsDComplete (PowTripleSet 2 2 2) is false.

PROVIDED SOLUTION
We need ¬ IsDComplete (PowTripleSet 2 2 2), i.e. ¬ (∀ᶠ n in atTop, ...). Unfolding IsDComplete and Filter.Eventually atTop, we need to show there is no N such that for all n ≥ N, n is representable. For any N, the odd number 2*N+3 ≥ N+3 > N is ≥ N but is not representable: by antichain_sum_eq_zero_or_pow_two, any antichain sum is 0 or a power of 2, and 2*N+3 is odd and ≥ 3, hence not 0 and not a power of 2. Use three_not_representable's approach generalized, or more directly: show that arbitrarily large odd numbers exist that aren't powers of 2. Actually simpler: use that for every n, either n=0 or n is a power of 2. Any odd n ≥ 3 is neither. Since there are arbitrarily large odd numbers not equal to powers of 2, IsDComplete fails.
-/
lemma not_d_complete_222 : ¬ IsDComplete (PowTripleSet 2 2 2) := by
  -- By contradiction, assume that PowTripleSet 2 2 2 is d-complete.
  by_contra h_contra
  obtain ⟨N, hN⟩ : ∃ N, ∀ n ≥ N, ∃ s : (Finset ℕ), ((↑s : (Set ℕ)) ⊆ (PowTripleSet 2 2 2) ∧ (IsDivisionAntichain s) ∧ ((s.sum id) = n)) := by
    exact?
  generalize_proofs at *; (
  -- Apply the lemma that states any antichain sum in PowTripleSet 2 2 2 is either 0 or a power of 2.
  have h_antichain_sum : ∀ n ≥ N, ∃ m : ℕ, n = 2 ^ m ∨ n = 0 := by
    intro n hn; obtain ⟨ s, hs₁, hs₂, hs₃ ⟩ := hN n hn; specialize hN; have := antichain_sum_eq_zero_or_pow_two s hs₁ hs₂; aesop;
  generalize_proofs at *; (
  -- Choose an odd number $n \geq N$ such that $n > 1$.
  obtain ⟨n, hn_ge_N, hn_odd, hn_gt_one⟩ : ∃ n, N ≤ n ∧ Odd n ∧ 1 < n := by
    exact ⟨ 2 * N + 3, by linarith, by simp +arith +decide [ parity_simps ], by linarith ⟩
  generalize_proofs at *; (
  obtain ⟨ m, rfl | rfl ⟩ := h_antichain_sum n hn_ge_N <;> simp_all +decide [ Nat.even_pow ] ;
  exact absurd hn_odd ( by simp +decide [ hn_gt_one, parity_simps ] ))))

-- ═══════════════════════════════════════════════════════════════════
-- §6. Main result: the variant without coprimality is FALSE
-- ═══════════════════════════════════════════════════════════════════

/--
**The most fragile variant of Erdős 123 is false.**

Dropping the `PairwiseCoprime3` hypothesis from `erdos_123_d_complete_sequences`
yields a statement that admits a counterexample at `(a, b, c) = (2, 2, 2)`:
the multiplicative semigroup {2^n} is totally ordered by divisibility,
so every division-antichain sum is a single power of 2, and odd numbers
are never representable.
-/
theorem erdos_123_fragile_variant_false :
    ¬ (∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      IsDComplete (PowTripleSet a b c)) := by
  intro h
  exact not_d_complete_222 (h 2 2 2 (by norm_num) (by norm_num) (by norm_num))

end Erdos123