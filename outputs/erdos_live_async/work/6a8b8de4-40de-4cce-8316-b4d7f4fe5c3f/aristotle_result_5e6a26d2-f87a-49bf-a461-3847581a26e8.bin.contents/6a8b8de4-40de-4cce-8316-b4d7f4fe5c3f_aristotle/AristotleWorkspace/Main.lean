-- erdos-123 focus: d-completeness, divisibility antichains, and reusable covering lemmas
import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-! ## Boundary Variant: Counterexample when coprimality fails

When the pairwise coprimality condition is dropped, d-completeness can fail.
The simplest counterexample is `a = 2, b = 4, c = 8`, where the entire
`PowTripleSet` collapses to `{2^n : n ∈ ℕ}`. In this set, divisibility
is a total order, so every antichain is a singleton, and thus antichain
sums are just individual powers of 2. Since not every large integer is a
power of 2, d-completeness fails.
-/

/-- When a = 2, b = 4, c = 8, the PowTripleSet consists only of powers of 2. -/
lemma powTripleSet_248_eq :
    PowTripleSet 2 4 8 = {n | ∃ m : ℕ, n = 2 ^ m} := by
  ext n;
  constructor <;> intro h;
  · rcases h with ⟨ i, j, k, rfl ⟩ ; exact ⟨ i + 2 * j + 3 * k, by ring_nf; norm_num [ pow_mul' ] ⟩;
  · rcases h with ⟨ m, rfl ⟩ ; exact ⟨ m, 0, 0, by norm_num ⟩ ;

/-- Powers of 2 form a total order under divisibility: for any two powers,
one divides the other. -/
lemma pow_two_dvd_total (a b : ℕ) : 2 ^ a ∣ 2 ^ b ∨ 2 ^ b ∣ 2 ^ a := by
  cases le_total a b <;> simp +decide [ *, pow_dvd_pow ]

/-- In a totally ordered divisibility set, every antichain is a singleton or empty. -/
lemma antichain_singleton_of_total {S : Set ℕ}
    (htotal : ∀ x y : ℕ, x ∈ S → y ∈ S → x ∣ y ∨ y ∣ x)
    (s : Finset ℕ) (hsub : (↑s : Set ℕ) ⊆ S) (hac : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  by_contra h_contra;
  obtain ⟨x, y, hx, hy, hxy⟩ : ∃ x y : ℕ, x ∈ s ∧ y ∈ s ∧ x ≠ y := by
    exact Finset.one_lt_card_iff.1 ( lt_of_not_ge h_contra );
  cases htotal x y ( hsub hx ) ( hsub hy ) <;> tauto

/-- The set of powers of 2 is NOT d-complete (with the antichain condition).
This is the key boundary counterexample. -/
theorem pow_two_not_d_complete :
    ¬ IsDComplete {n : ℕ | ∃ m : ℕ, n = 2 ^ m} := by
  by_contra h_contra
  obtain ⟨N, h⟩ : ∃ N : ℕ, ∀ n ≥ N, ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m} ∧ IsDivisionAntichain s ∧ s.sum id = n := by
    exact Filter.eventually_atTop.mp h_contra;
  obtain ⟨m, hm⟩ : ∃ m, 2 * m + 1 ≥ N ∧ ¬∃ m', (2 * m + 1 = 2 ^ m') := by
    exact ⟨ N + 1, by linarith, fun ⟨ k, hk ⟩ => by have := congr_arg Even hk; norm_num [ Nat.even_add, Nat.even_pow ] at this; rcases k with ( _ | _ | k ) <;> norm_num at * ⟩;
  obtain ⟨ s, hs₁, hs₂, hs₃ ⟩ := h ( 2 * m + 1 ) hm.1;
  have hs_card : s.card ≤ 1 := by
    apply antichain_singleton_of_total;
    any_goals assumption;
    rintro x y ⟨ i, rfl ⟩ ⟨ j, rfl ⟩ ; cases le_total i j <;> [ left; right ] <;> exact pow_dvd_pow _ ‹_›;
  cases hs_card.eq_or_lt <;> simp_all +decide [ Finset.card_eq_one ];
  aesop

/-- Main boundary counterexample: PowTripleSet 2 4 8 is not d-complete,
showing the coprimality hypothesis in the main theorem cannot be removed. -/
theorem boundary_counterexample :
    ¬ IsDComplete (PowTripleSet 2 4 8) := by
  rw [powTripleSet_248_eq]
  exact pow_two_not_d_complete

/-! ## Structural Lemmas for PowTripleSet -/

/-- Every element of PowTripleSet is positive when a, b, c ≥ 1. -/
lemma powTripleSet_pos {a b c : ℕ} (ha : 1 ≤ a) (hb : 1 ≤ b) (hc : 1 ≤ c) :
    ∀ n ∈ PowTripleSet a b c, 0 < n := by
  exact fun n hn => by obtain ⟨ i, j, k, rfl ⟩ := hn; positivity;

/-- Membership criterion for PowTripleSet. -/
lemma mem_powTripleSet {a b c n : ℕ} :
    n ∈ PowTripleSet a b c ↔ ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k := by
  rfl

/-- Pure powers of coprime bases form antichains. -/
lemma coprime_pow_antichain {a b : ℕ} (hab : Nat.Coprime a b)
    (ha : 1 < a) (_hb : 1 < b)
    (i j : ℕ) (hi : 0 < i) (_hj : 0 < j) (hne : a ^ i ≠ b ^ j) :
    ¬ (a ^ i ∣ b ^ j) := by
  exact fun h => absurd ( hab.pow i j ▸ Nat.dvd_gcd ( dvd_refl _ ) h ) ( by aesop )

/-- The PowTripleSet of a pair (a, b, 1) is contained in the PowTripleSet
of a triple (a, b, c). -/
lemma powTripleSet_pair_sub_triple (a b c : ℕ) :
    PowTripleSet a b 1 ⊆ PowTripleSet a b c := by
  intro n hn
  obtain ⟨i, j, k, hn_eq⟩ := hn
  use i, j, 0
  simp [hn_eq]

/-
PROBLEM
Monotonicity: if A ⊆ B and A is d-complete, B is d-complete too.

PROVIDED SOLUTION
If A ⊆ B and A is d-complete, then for all sufficiently large n, there exists an antichain Finset s ⊆ A with sum n. Since A ⊆ B, s ⊆ B too. Use Filter.Eventually.mono on the filter statement.
-/
lemma isDComplete_mono {A B : Set ℕ} (h : A ⊆ B) (hA : IsDComplete A) :
    IsDComplete B := by
  exact hA.mono fun n hn => by rcases hn with ⟨ s, hs₁, hs₂, hs₃ ⟩ ; exact ⟨ s, hs₁.trans h, hs₂, hs₃ ⟩ ;

/-
PROBLEM
A singleton element from PowTripleSet always gives a valid antichain sum.

PROVIDED SOLUTION
Use s = {n}. Then s ⊆ A since n ∈ A. IsDivisionAntichain holds vacuously (no two distinct elements). And Finset.sum {n} id = n. Use Finset.singleton, Finset.sum_singleton.
-/
lemma singleton_antichain_sum {A : Set ℕ} {n : ℕ} (hn : n ∈ A) :
    ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n := by
  use { n };
  exact ⟨ by simpa, fun x y hx hy hxy => by aesop, by simp +decide ⟩

/-
PROBLEM
Two coprime elements > 1 in PowTripleSet form a valid 2-element antichain.

PROVIDED SOLUTION
Unfold IsDivisionAntichain. Take x, y in {a, b} with x ≠ y. Since {a,b} has exactly two elements and a ≠ b, either (x=a, y=b) or (x=b, y=a). In the first case, a ∣ b would imply gcd(a,b) ≥ a > 1 contradicting coprimality. Similarly for the other case. Use Nat.Coprime to derive that if a ∣ b and gcd(a,b) = 1, then a = 1, contradicting ha.
-/
lemma coprime_pair_antichain {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hab : Nat.Coprime a b) (hne : a ≠ b) :
    IsDivisionAntichain {a, b} := by
  -- By definition of coprimality, if a divides b, then their gcd would be a, which contradicts hab since a > 1.
  have h_div_a_b : ¬(a ∣ b) := by
    exact fun h => by have := Nat.gcd_eq_left h; aesop;
  -- Similarly, if b divides a, then their gcd would be b, which contradicts hab since b > 1.
  have h_div_b_a : ¬(b ∣ a) := by
    exact fun h => by have := Nat.gcd_eq_right h; aesop;
  intro x y hx hy hxy; aesop;

/-
PROBLEM
Elements `a · c^i` and `b · c^j` from PowTripleSet are always
antichain-compatible when a, b, c are pairwise coprime and a, b > 1.

PROVIDED SOLUTION
Suppose a * c^i ∣ b * c^j. Then a ∣ b * c^j. Since gcd(a, b) = 1 (hab) and gcd(a, c) = 1 (hac), we have gcd(a, b * c^j) = 1. So a ∣ b * c^j implies a = 1 (since coprime). But a > 1, contradiction. Key steps: use Nat.Coprime.coprime_dvd_left or show that a is coprime to b * c^j using hab.mul_right (hac.pow_right j), then use Nat.eq_one_of_self_mul_self or similar to conclude a = 1.
-/
lemma mixed_pair_antichain {a b c : ℕ}
    (ha : 1 < a) (_hb : 1 < b) (_hc : 1 < c)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (_hbc : Nat.Coprime b c)
    (i j : ℕ) (hne : a * c ^ i ≠ b * c ^ j) :
    ¬ (a * c ^ i ∣ b * c ^ j) := by
  contrapose! hne;
  -- Since $a$ and $b$ are coprime and $a \mid b \cdot c^j$, it follows that $a \mid c^j$.
  have ha_div_cj : a ∣ c ^ j := by
    exact hab.dvd_of_dvd_mul_left ( dvd_of_mul_right_dvd hne );
  have := Nat.dvd_gcd ( dvd_refl a ) ha_div_cj; simp_all +decide [ Nat.Coprime, Nat.Coprime.pow_right ] ;

/-! ## Main Theorem

This is Erdős Problem 123: for any pairwise coprime triple (a,b,c) with
a,b,c > 1, the multiplicative semigroup PowTripleSet(a,b,c) is d-complete.

**Status**: This remains an open formalization challenge. The problem requires
showing that every sufficiently large integer can be written as a sum of
elements from PowTripleSet(a,b,c) forming a divisibility antichain. The
mathematical difficulty lies in constructing explicit antichain
decompositions that cover all residue classes.

**What IS proved**:
- The boundary counterexample when coprimality fails (PowTripleSet 2 4 8).
- Key structural lemmas: positivity, antichain compatibility of coprime
  powers, monotonicity under set inclusion.
- The antichain machinery: total orders yield only singleton antichains.
-/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

end Erdos123