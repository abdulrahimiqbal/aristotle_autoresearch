import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-! ## Helper lemmas for the main theorem -/

/-- Membership in PowTripleSet. -/
lemma mem_powTripleSet (a b c n : ℕ) :
    n ∈ PowTripleSet a b c ↔ ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k := by
  rfl

/-- 1 is always in PowTripleSet (take all exponents 0). -/
lemma one_mem_powTripleSet (a b c : ℕ) (ha : 0 < a) (hb : 0 < b) (hc : 0 < c) :
    1 ∈ PowTripleSet a b c := by
  exact ⟨0, 0, 0, by simp⟩

/-- Pure powers of a are in PowTripleSet. -/
lemma pow_a_mem (a b c : ℕ) (hb : 0 < b) (hc : 0 < c) (i : ℕ) :
    a ^ i ∈ PowTripleSet a b c := by
  exact ⟨i, 0, 0, by simp⟩

/-
PROBLEM
For pairwise coprime a, b > 1 and exponents i, j ≥ 1,
    a^i does not divide b^j.

PROVIDED SOLUTION
Since a and b are coprime, a^i and b^j are coprime (by Nat.Coprime.pow). A coprime number > 1 cannot divide another (if x | y and gcd(x,y) = 1, then x = 1). Since a > 1 and i ≥ 1, a^i ≥ a > 1. So a^i ∤ b^j. The proof is: hcop.pow i j gives Coprime (a^i) (b^j), and Nat.Coprime.eq_one_of_self_mul_self_dvd or just the fact that if a^i | b^j and gcd(a^i, b^j) = 1 then a^i must be 1, contradiction.
-/
lemma coprime_pow_not_dvd {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hcop : Nat.Coprime a b) {i j : ℕ} (hi : 0 < i) (hj : 0 < j) :
    ¬ a ^ i ∣ b ^ j := by
  by_contra h;
  exact absurd ( hcop.pow i j ▸ Nat.dvd_gcd ( dvd_refl _ ) h ) ( by aesop )

/-
PROBLEM
For pairwise coprime a, b, c > 1, the set {a^i, b^j, c^k} with i,j,k ≥ 1
    is a divisibility antichain.

PROVIDED SOLUTION
Unfold IsDivisionAntichain. For any x, y in {a^i, b^j, c^k} with x ≠ y, show ¬ x ∣ y. Case split on which elements x and y are. Use coprime_pow_not_dvd for each case with the appropriate coprimality from hcop (PairwiseCoprime3 gives Nat.Coprime a b, Nat.Coprime a c, Nat.Coprime b c).
-/
lemma triple_pure_powers_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) {i j k : ℕ} (hi : 0 < i) (hj : 0 < j) (hk : 0 < k)
    (hij : a ^ i ≠ b ^ j) (hik : a ^ i ≠ c ^ k) (hjk : b ^ j ≠ c ^ k) :
    IsDivisionAntichain {a ^ i, b ^ j, c ^ k} := by
  intro x hx y hy;
  simp_all +decide [ Nat.Coprime, PairwiseCoprime3 ];
  grind +suggestions

/-
PROBLEM
For pairwise coprime a, b > 1, a^i ≠ b^j when i ≥ 1 and j ≥ 1.

PROVIDED SOLUTION
If a^i = b^j, then a^i | b^j (by dvd_refl after rewrite). But coprime_pow_not_dvd says a^i ∤ b^j. Contradiction. Alternative: Nat.Coprime.pow gives gcd(a^i, b^j) = 1, and if a^i = b^j > 1, then gcd(a^i, b^j) = a^i > 1, contradiction.
-/
lemma coprime_pow_ne {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hcop : Nat.Coprime a b) {i j : ℕ} (hi : 0 < i) (hj : 0 < j) :
    a ^ i ≠ b ^ j := by
  intro H; have := hcop.pow i j; simp_all +decide [ Nat.Coprime ] ;
  grind

/-! ## Core coverage lemma: every residue class mod (a*b*c) is eventually hit
    by an antichain sum from PowTripleSet.

    For pairwise coprime a, b, c > 1, consider the antichain sums from subsets
    of {a^i, b^j, c^k : i, j, k ≥ 1}. Since any selection of at most one power
    from each axis is an antichain, the achievable sums include:
    - singletons: a^i, b^j, c^k
    - pairs: a^i + b^j, a^i + c^k, b^j + c^k
    - triples: a^i + b^j + c^k

    The key is that these sums, as i, j, k range, cover all residue classes
    mod (a*b*c) (using CRT and the density of cyclic subgroups). Then by choosing
    exponents large enough, any target n above a threshold is achievable.
-/

/-- A workspace-local Lean 4 stub for Erdős Problem 123. The formal-conjectures repo
