import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-!
## Reformulation via Transfer Decomposition

**Transferable artifact**: "Special-case covering lemmas can often be transferred
by isolating the divisibility obstruction."

The reformulation decomposes d-completeness into two independent components:

1. **Additive covering**: Every sufficiently large `n` is a sum of distinct
   elements of `PowTripleSet a b c` (no antichain constraint). This is a purely
   additive number-theoretic statement. For triples with `min(a,b,c) = 2`, this
   is trivial via binary representation. For large generators, it holds but with
   an astronomically large threshold determined by the epoch structure of the set.

2. **Antichain upgrade**: For sufficiently large `n`, any `n` representable as a
   sum from a pairwise-coprime triple *also* admits an antichain representation.
   This is where the *divisibility obstruction* is isolated — pairwise coprimality
   ensures that divisibility among summands only arises from exponent domination
   within a single prime base, which can always be broken for large enough targets.

The key structural insight is that pairwise coprimality forces divisibility
relations within `PowTripleSet` to be *very structured*:
`a^i b^j c^k ∣ a^i' b^j' c^k'` iff `i ≤ i' ∧ j ≤ j' ∧ k ≤ k'`.
This "product-order" structure means divisibility chains are exactly
coordinate-wise chains, so antichain refinement reduces to a combinatorial
argument about partitions in `ℕ³`.
-/

/-- **Additive covering** (weaker version without antichain condition):
every sufficiently large integer is a sum of distinct elements from `A`. -/
def HasAdditiveCovering (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ s.sum id = n

/-- **Antichain upgrade**: for sufficiently large `n`, if `n` is a sum of
distinct elements from `A`, then it also admits a divisibility-antichain
sum representation from `A`. -/
def HasAntichainUpgrade (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop,
    (∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ A ∧ s.sum id = n) →
    (∃ t : Finset ℕ, (↑t : Set ℕ) ⊆ A ∧ IsDivisionAntichain t ∧ t.sum id = n)

/-!
## Structural Lemmas
-/

/-
PROBLEM
In a pairwise-coprime triple, divisibility within the power set is
precisely coordinate-wise domination.

PROVIDED SOLUTION
Forward: isolate each prime power factor using coprimality. Backward: use pow_dvd_pow and mul_dvd_mul.
-/
theorem divisibility_iff_coordinate_domination
    (a b c : ℕ) (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    (i₁ j₁ k₁ i₂ j₂ k₂ : ℕ) :
    a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ ↔
      i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
  constructor;
  · intro hdiv
    have hdiv_a : a ^ i₁ ∣ a ^ i₂ := by
      have hdiv_a : a ^ i₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
        exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_right _ _ ) _ ) hdiv;
      have hcop_a : Nat.Coprime (a ^ i₁) (b ^ j₂ * c ^ k₂) := by
        exact Nat.Coprime.mul_right ( Nat.Coprime.pow _ _ <| hcop.1 ) ( Nat.Coprime.pow _ _ <| hcop.2.1 );
      exact hcop_a.dvd_of_dvd_mul_right <| by simpa only [ mul_assoc ] using hdiv_a;
    have hdiv_b : b ^ j₁ ∣ b ^ j₂ := by
      have hdiv_b : b ^ j₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
        exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_left _ _ ) _ ) hdiv;
      have hcop_b : Nat.Coprime (b ^ j₁) (a ^ i₂ * c ^ k₂) := by
        rw [ Nat.coprime_mul_iff_right ];
        exact ⟨ Nat.Coprime.pow _ _ <| hcop.1.symm, Nat.Coprime.pow _ _ <| hcop.2.2 ⟩;
      exact hcop_b.dvd_of_dvd_mul_left <| by convert hdiv_b using 1; ring;
    have hdiv_c : c ^ k₁ ∣ c ^ k₂ := by
      have hdiv_c : c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
        exact dvd_trans ( dvd_mul_left _ _ ) hdiv;
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ hdiv_c;
      apply_mod_cast Nat.Coprime.mul_right <;> apply_rules [ Nat.Coprime.pow, hcop.1.symm, hcop.2.1.symm, hcop.2.2.symm ];
    exact ⟨ Nat.le_of_not_lt fun hi => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans ha ) _ ) ( pow_lt_pow_right₀ ha hi ) hdiv_a, Nat.le_of_not_lt fun hj => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hb ) _ ) ( pow_lt_pow_right₀ hb hj ) hdiv_b, Nat.le_of_not_lt fun hk => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hc ) _ ) ( pow_lt_pow_right₀ hc hk ) hdiv_c ⟩;
  · exact fun h => mul_dvd_mul ( mul_dvd_mul ( pow_dvd_pow _ h.1 ) ( pow_dvd_pow _ h.2.1 ) ) ( pow_dvd_pow _ h.2.2 )

/-- The element `1 = a^0 * b^0 * c^0` is in every `PowTripleSet`. -/
theorem one_mem_powTripleSet (a b c : ℕ) : (1 : ℕ) ∈ PowTripleSet a b c := by
  exact ⟨0, 0, 0, by norm_num⟩

/-- Each generator belongs to its own PowTripleSet. -/
theorem generator_mem_powTripleSet_a (a b c : ℕ) : a ∈ PowTripleSet a b c := by
  exact ⟨1, 0, 0, by norm_num⟩

theorem generator_mem_powTripleSet_b (a b c : ℕ) : b ∈ PowTripleSet a b c := by
  exact ⟨0, 1, 0, by ring⟩

theorem generator_mem_powTripleSet_c (a b c : ℕ) : c ∈ PowTripleSet a b c := by
  exact ⟨0, 0, 1, by simp⟩

/-- Products of elements in PowTripleSet are still in PowTripleSet. -/
theorem mul_mem_powTripleSet (a b c : ℕ)
    {m n : ℕ} (hm : m ∈ PowTripleSet a b c) (hn : n ∈ PowTripleSet a b c) :
    m * n ∈ PowTripleSet a b c := by
  rcases hm with ⟨i₁, j₁, k₁, rfl⟩; rcases hn with ⟨i₂, j₂, k₂, rfl⟩
  exact ⟨i₁ + i₂, j₁ + j₂, k₁ + k₂, by ring⟩

/-- Every element of a PowTripleSet with positive generators is positive. -/
theorem pos_of_mem_powTripleSet (a b c : ℕ) (ha : 0 < a) (hb : 0 < b) (hc : 0 < c)
    {n : ℕ} (hn : n ∈ PowTripleSet a b c) : 0 < n := by
  obtain ⟨i, j, k, rfl⟩ := hn; positivity

/-- Powers of 2 belong to `PowTripleSet 2 b c`. -/
theorem pow2_mem_powTripleSet (b c : ℕ) (i : ℕ) : 2 ^ i ∈ PowTripleSet 2 b c := by
  exact ⟨i, 0, 0, by norm_num⟩

/-!
## Composition Theorem
-/

/-- **Composition**: d-completeness follows from covering + antichain upgrade. -/
theorem dComplete_of_covering_and_upgrade
    (A : Set ℕ)
    (hcov : HasAdditiveCovering A)
    (hup : HasAntichainUpgrade A) :
    IsDComplete A := by
  filter_upwards [hcov, hup] with n hn hn' using hn' hn

/-!
## Covering Lemma for Triples with Generator 2
-/

/-
PROBLEM
**Covering lemma for triples with generator 2**: Every positive integer
is a sum of distinct elements from `PowTripleSet 2 b c` (via binary
representation using powers of 2).

PROVIDED SOLUTION
Every positive integer has a binary representation as a sum of distinct powers of 2. Each 2^i is in PowTripleSet 2 b c (by pow2_mem_powTripleSet). Use strong induction: for n > 0, let k = Nat.log 2 n, so 2^k ≤ n < 2^(k+1). Then n - 2^k < 2^k ≤ n, so by induction n - 2^k has a representation s. Since all elements of s are ≤ n - 2^k < 2^k, none equals 2^k, so s ∪ {2^k} is a valid Finset.
-/
theorem covering_with_generator_2 (b c : ℕ) :
    HasAdditiveCovering (PowTripleSet 2 b c) := by
  refine' Filter.eventually_atTop.mpr ⟨ 0, fun m hm => _ ⟩;
  -- By definition of binary representation, we can write m as a sum of distinct powers of 2.
  have h_binary : ∃ s : Finset ℕ, s.sum (fun i => 2 ^ i) = m := by
    induction' m using Nat.strong_induction_on with m ih;
    rcases Nat.even_or_odd' m with ⟨ k, rfl | rfl ⟩;
    · obtain ⟨ s, hs ⟩ := if hk : k = 0 then ⟨ ∅, by aesop ⟩ else ih k ( by linarith [ Nat.pos_of_ne_zero hk ] ) ( Nat.zero_le k );
      exact ⟨ s.image fun i => i + 1, by simp +decide [ ← hs, pow_succ', Finset.mul_sum _ _ _ ] ⟩;
    · obtain ⟨ s, hs ⟩ := ih k ( by linarith ) ( by linarith ) ; use s.image ( fun i => i + 1 ) ∪ { 0 } ; simp_all +decide [ Finset.sum_union, pow_succ', mul_assoc, Finset.mul_sum _ _ _ ] ; ring;
      rw [ ← Finset.sum_mul _ _ _, hs ];
  obtain ⟨ s, hs ⟩ := h_binary;
  use s.image (fun i => 2 ^ i);
  simp_all +decide [ Set.subset_def, Finset.sum_image ];
  exact ⟨ fun i hi => pow2_mem_powTripleSet b c i, by rw [ Finset.sum_image <| by aesop ] ; exact hs ⟩

