-- counterexample mode target
import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-- A workspace-local Lean 4 stub for Erdos Problem 123. The formal-conjectures repo
contains a current statement very close to this one together with solved variants. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-!
## Counterexample to the fragile variant (coprimality dropped)

The **most fragile variant** of Erdős Problem 123 is obtained by dropping
the `PairwiseCoprime3` hypothesis.  We show this variant is false:
the witness `a = b = c = 2` satisfies `1 < a ∧ 1 < b ∧ 1 < c` but
`PowTripleSet 2 2 2` is **not** `d`-complete.

### Proof sketch
1. `PowTripleSet 2 2 2 = {2^n | n : ℕ}` — every element is a power of 2.
2. Powers of 2 are **totally ordered** by divisibility (`2^a ∣ 2^b ↔ a ≤ b`).
3. Therefore every `IsDivisionAntichain` subset of `{2^n}` has **at most one** element.
4. The sum of such a subset is either `0` (empty) or a single power of 2.
5. There are arbitrarily large natural numbers that are not powers of 2 (e.g. `2^k + 1`),
   so `IsDComplete` fails.
-/

/-- Every element of `PowTripleSet 2 2 2` is a power of 2. -/
lemma powTripleSet_222_subset_pow2 :
    PowTripleSet 2 2 2 ⊆ {n | ∃ m : ℕ, n = 2 ^ m} := by
  sorry

/-- Powers of 2 are totally ordered by divisibility. -/
lemma pow2_dvd_total (a b : ℕ) : 2 ^ a ∣ 2 ^ b ∨ 2 ^ b ∣ 2 ^ a := by
  sorry

/-- An antichain (in the divisibility order) consisting of powers of 2
    has at most one element. -/
lemma antichain_pow2_card_le_one (s : Finset ℕ)
    (hpow : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (hac : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  sorry

/-- The sum of an antichain of powers of 2 is 0 or a single power of 2. -/
lemma sum_antichain_pow2 (s : Finset ℕ)
    (hpow : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (hac : IsDivisionAntichain s) :
    s.sum id = 0 ∨ ∃ m : ℕ, s.sum id = 2 ^ m := by
  sorry

/-- For every `N`, there exists `n ≥ N` that is neither 0 nor a power of 2. -/
lemma exists_large_non_pow2 (N : ℕ) :
    ∃ n, N ≤ n ∧ n ≠ 0 ∧ ∀ m : ℕ, n ≠ 2 ^ m := by
  sorry

/-- `PowTripleSet 2 2 2` is **not** `d`-complete: the fragile variant
    (without pairwise coprimality) is false. -/
theorem powTripleSet_222_not_dComplete :
    ¬ IsDComplete (PowTripleSet 2 2 2) := by
  sorry

/-- **Main result**: the variant of Erdős Problem 123 obtained by dropping
    the pairwise-coprimality hypothesis is **false**.

    Witness: `a = b = c = 2`.  All three exceed 1, but `PowTripleSet 2 2 2`
    (= the set of powers of 2) is not `d`-complete because every
    divisibility-antichain of powers of 2 is a subsingleton. -/
theorem erdos_123_fragile_variant_false :
    ¬ (∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
        IsDComplete (PowTripleSet a b c)) := by
  intro h
  exact powTripleSet_222_not_dComplete (h 2 2 2 (by norm_num) (by norm_num) (by norm_num))

end Erdos123
