-- counterexample mode target
import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-- A workspace-local Lean 4 stub for Erdos Problem 123. The formal-conjectures repo
contains a current statement very close to this one together with solved variants. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-!
## Counterexample for the most fragile variant

The most fragile variant of the theorem above is obtained by **dropping the
`PairwiseCoprime3` hypothesis**. Without mutual coprimality the generators can
share a common prime factor, collapsing `PowTripleSet` into powers of a single
prime. We demonstrate this concretely with `(a, b, c) = (2, 4, 8)`:

1. `PowTripleSet 2 4 8 = {2^m | m ∈ ℕ}` (every element is a power of 2).
2. Among powers of 2, smaller always divides larger, so any
   `IsDivisionAntichain` subset has at most one element.
3. Consequently the only achievable antichain sums are `0` and individual
   powers of 2. Odd numbers ≥ 3 are never representable.
4. Hence `IsDComplete (PowTripleSet 2 4 8)` is **false**.
-/

/-
PROBLEM
Every element of `PowTripleSet 2 4 8` is a power of 2.

PROVIDED SOLUTION
Every element is 2^i * 4^j * 8^k = 2^i * (2^2)^j * (2^3)^k = 2^(i + 2*j + 3*k). So take m = i + 2*j + 3*k.
-/
lemma powTripleSet_248_subset_pow2 :
    PowTripleSet 2 4 8 ⊆ {n | ∃ m : ℕ, n = 2 ^ m} := by
  rintro n ⟨ i, j, k, rfl ⟩ ; exact ⟨ i + 2 * j + 3 * k, by norm_num [ pow_add, pow_mul ] ⟩ ;

/-
PROBLEM
Among any two distinct powers of 2, the smaller divides the larger.

PROVIDED SOLUTION
Write x = 2^i, y = 2^j. If i ≤ j then x ∣ y, else y ∣ x. Use Nat.pow_dvd_pow.
-/
lemma pow2_div_of_ne {x y : ℕ} (hx : ∃ i, x = 2 ^ i) (hy : ∃ j, y = 2 ^ j)
    (hne : x ≠ y) : x ∣ y ∨ y ∣ x := by
  rcases hx with ⟨ i, rfl ⟩ ; rcases hy with ⟨ j, rfl ⟩ ; cases le_total i j <;> simp +decide [ *, pow_dvd_pow ] ;

/-
PROBLEM
A division antichain drawn from powers of 2 has at most one element.

PROVIDED SOLUTION
By contradiction: if s.card ≥ 2, pick two distinct elements x, y ∈ s. By hs, both are powers of 2. By pow2_div_of_ne, x ∣ y or y ∣ x. Either case contradicts IsDivisionAntichain. Use Finset.one_lt_card to get two distinct elements.
-/
lemma antichain_pow2_card_le_one (s : Finset ℕ)
    (hs : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (ha : IsDivisionAntichain s) : s.card ≤ 1 := by
  -- By contradiction, assume $s.card ≥ 2$.
  by_contra h_contra
  have h_card : s.card ≥ 2 := by
    grind;
  obtain ⟨ x, hx, y, hy, hxy ⟩ := Finset.one_lt_card.1 h_card;
  exact ha hx hy hxy ( pow2_div_of_ne ( hs x hx ) ( hs y hy ) hxy |> Or.resolve_right <| fun h => ha hy hx ( Ne.symm hxy ) h )

/-
PROBLEM
An antichain sum from powers of 2 is either `0` or a power of 2.

PROVIDED SOLUTION
By antichain_pow2_card_le_one, s.card ≤ 1. If s.card = 0, s is empty and sum is 0 (Left). If s.card = 1, s = {x} for some x which is 2^m, and sum = x = 2^m (Right). Use Finset.card_le_one_iff_eq or Finset.card_eq_zero/Finset.card_eq_one.
-/
lemma antichain_sum_pow2 (s : Finset ℕ)
    (hs : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (ha : IsDivisionAntichain s) :
    s.sum id = 0 ∨ ∃ m : ℕ, s.sum id = 2 ^ m := by
  have := antichain_pow2_card_le_one s hs ha; rw [ Finset.card_le_one_iff_subset_singleton ] at this; aesop;

/-
PROBLEM
No odd number ≥ 3 is `0` or a power of 2.

PROVIDED SOLUTION
n ≥ 3 so n ≠ 0. For the second part, 2^0 = 1 ≠ n (since n ≥ 3), and for m ≥ 1, 2^m is even but n is odd (¬ 2 ∣ n), contradiction. Use Nat.two_dvd_of_even or show 2 ∣ 2^m for m ≥ 1.
-/
lemma odd_ge3_not_zero_or_pow2 (n : ℕ) (hodd : ¬ 2 ∣ n) (h3 : 3 ≤ n) :
    n ≠ 0 ∧ ∀ m : ℕ, n ≠ 2 ^ m := by
  exact ⟨ by positivity, fun m hm => hodd <| hm.symm ▸ dvd_pow_self _ ( by rintro rfl; linarith ) ⟩

/-
PROBLEM
**Counterexample.** Dropping coprimality makes the d-completeness claim false:
    `PowTripleSet 2 4 8` is *not* d-complete.

PROVIDED SOLUTION
Unfold IsDComplete. The claim ∀ᶠ n in atTop means ∃ N, ∀ n ≥ N, P n. We show the negation: for any N, there exists n ≥ N with no valid representation. Take n = 2*N + 3 (odd and ≥ 3). Suppose s is a valid antichain with elements from PowTripleSet 2 4 8 and sum = n. By powTripleSet_248_subset_pow2, all elements are powers of 2. By antichain_sum_pow2, the sum is 0 or a power of 2. But n = 2*N+3 is odd and ≥ 3, so by odd_ge3_not_zero_or_pow2 it's neither 0 nor a power of 2 — contradiction. Use Filter.Eventually.exists_forall_of_atTop or unfold Filter.Eventually for atTop to get the ∃ N form, then provide 2*N+3 as witness.
-/
theorem fragile_variant_counterexample :
    ¬ IsDComplete (PowTripleSet 2 4 8) := by
  -- Let's choose any $N$ and derive a contradiction.
  by_contra h_contra
  obtain ⟨N, hN⟩ : ∃ N, ∀ n ≥ N, ∃ s : Finset ℕ, (s : Set ℕ) ⊆ {n | ∃ m, n = 2 ^ m} ∧ (IsDivisionAntichain s) ∧ s.sum id = n := by
    obtain ⟨ N, hN ⟩ := Filter.eventually_atTop.mp h_contra ; use N ; intros n hn ; rcases hN n hn with ⟨ s, hs₁, hs₂, hs₃ ⟩ ; refine' ⟨ s, fun x hx => _, hs₂, hs₃ ⟩ ; exact powTripleSet_248_subset_pow2 <| hs₁ hx;
  -- Choose an odd number $n \geq 3$ such that $n > 2N$.
  obtain ⟨n, hn_odd, hn_ge3, hn_gt⟩ : ∃ n, ¬2 ∣ n ∧ 3 ≤ n ∧ n > 2 * N := by
    exact ⟨ 2 * N + 3, by norm_num [ Nat.dvd_add_right ], by linarith, by linarith ⟩;
  obtain ⟨ s, hs₁, hs₂, hs₃ ⟩ := hN n ( by linarith ) ; have := antichain_sum_pow2 s ( fun x hx => hs₁ hx ) hs₂ ; simp_all +decide ;
  rcases this with ( rfl | ⟨ m, rfl ⟩ ) <;> norm_num [ Nat.pow_mod ] at *;
  cases m <;> norm_num at *

/-- The full statement without coprimality is therefore false. -/
theorem erdos_123_no_coprime_false :
    ¬ (∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
        IsDComplete (PowTripleSet a b c)) := by
  intro h
  exact fragile_variant_counterexample (h 2 4 8 (by norm_num) (by norm_num) (by norm_num))

end Erdos123