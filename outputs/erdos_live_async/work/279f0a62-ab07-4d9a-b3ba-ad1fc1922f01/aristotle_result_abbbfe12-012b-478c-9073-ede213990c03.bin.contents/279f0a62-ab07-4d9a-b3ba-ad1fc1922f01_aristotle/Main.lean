import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-- A workspace-local Lean 4 stub for Erdos Problem 123. The formal-conjectures repo
contains a current statement very close to this one together with solved variants. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-! ## Fragile variant and counterexample

The **most fragile hypothesis** in `erdos_123_d_complete_sequences` is
**pairwise coprimality** (`PairwiseCoprime3 a b c`).  Dropping it while keeping
`1 < a`, `1 < b`, `1 < c` immediately breaks the conclusion.

### Witness: `(a, b, c) = (2, 4, 8)`

All three bases exceed 1, but `gcd(2,4) = 2 ≠ 1`, so pairwise coprimality
fails.  The generated semigroup collapses:

  `PowTripleSet 2 4 8  =  { 2^i · 4^j · 8^k }  =  { 2^n : n ≥ 0 }`

This is a **totally ordered** set under divisibility (2^a ∣ 2^b ↔ a ≤ b),
so every division-antichain is a singleton.  Consequently, the only
achievable antichain-sums are individual powers of 2, and numbers like 3
are never representable.  Hence `IsDComplete (PowTripleSet 2 4 8)` is false.
-/

/-- The variant of Erdős 123 obtained by dropping pairwise coprimality. -/
def FragileVariant : Prop :=
  ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
    IsDComplete (PowTripleSet a b c)

/-
PROBLEM
Every element of `PowTripleSet 2 4 8` is a power of 2.

PROVIDED SOLUTION
Show set equality by ext. For the forward direction: given 2^i * 4^j * 8^k, rewrite as 2^i * (2^2)^j * (2^3)^k = 2^(i + 2*j + 3*k), so take m = i + 2*j + 3*k. For the reverse: given 2^m, take i=m, j=0, k=0, then 2^m * 4^0 * 8^0 = 2^m.
-/
lemma powTripleSet_2_4_8_eq :
    PowTripleSet 2 4 8 = {n | ∃ m : ℕ, n = 2 ^ m} := by
  ext n; exact ⟨by
  rintro ⟨ i, j, k, rfl ⟩ ; exact ⟨ i + j * 2 + k * 3, by norm_num [ pow_add, pow_mul' ] ⟩ ;, by
    rintro ⟨ m, rfl ⟩ ; exact ⟨ m, 0, 0, by norm_num ⟩ ;⟩;

/-
PROBLEM
Every antichain in a set of powers of 2 is a subsingleton (has at most one element).

PROVIDED SOLUTION
Suppose s has two distinct elements x, y with x = 2^a, y = 2^b. WLOG a ≤ b (or a ≠ b since x ≠ y). Then 2^a ∣ 2^b (since a ≤ b means Nat.pow_dvd_pow), contradicting IsDivisionAntichain. So s has at most 1 element. Use Finset.card_le_one_iff and show any two elements are equal.
-/
lemma antichain_pow2_subsingleton (s : Finset ℕ)
    (hs : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (ha : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  -- Assume there are two distinct elements x and y in s.
  by_contra h_contra
  obtain ⟨x, y, hx, hy, hxy⟩ : ∃ x y : ℕ, x ∈ s ∧ y ∈ s ∧ x ≠ y := by
    exact Finset.one_lt_card_iff.1 ( lt_of_not_ge h_contra );
  obtain ⟨ m, rfl ⟩ := hs x hx; obtain ⟨ n, rfl ⟩ := hs y hy; cases le_total m n <;> [ exact ha hx hy hxy ( pow_dvd_pow _ ‹_› ) ; exact ha hy hx ( Ne.symm hxy ) ( pow_dvd_pow _ ‹_› ) ] ;

/-
PROBLEM
3 is not a power of 2.

PROVIDED SOLUTION
By induction/cases on m. For m=0: 2^0=1≠3. For m=1: 2^1=2≠3. For m≥2: 2^m ≥ 4 > 3. Use omega or interval_cases for small cases and monotonicity for large ones.
-/
lemma three_ne_pow2 : ∀ m : ℕ, 3 ≠ 2 ^ m := by
  exact fun m hm => by linarith [ Nat.pow_le_pow_right ( show 1 ≤ 2 by norm_num ) ( show m ≥ 2 by contrapose! hm; interval_cases m <;> trivial ) ] ;

/-
PROBLEM
3 cannot be represented as an antichain sum from `PowTripleSet 2 4 8`,
and since 3 ≤ n for all sufficiently large n, d-completeness fails.

PROVIDED SOLUTION
Assume for contradiction there exists such an s. By powTripleSet_2_4_8_eq, every element of s is a power of 2. By antichain_pow2_subsingleton, s.card ≤ 1. If s is empty, sum is 0 ≠ 3. If s = {x} for some x, then x = 2^m for some m and sum = 2^m = 3, contradicting three_ne_pow2.
-/
lemma three_not_antichain_sum_of_pow2 :
    ¬ ∃ s : Finset ℕ,
      (↑s : Set ℕ) ⊆ PowTripleSet 2 4 8 ∧
      IsDivisionAntichain s ∧
      s.sum id = 3 := by
  by_contra h_contra
  obtain ⟨s, hs⟩ := h_contra
  have hs_pow2 : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m := by
    exact fun x hx => by rcases hs.1 hx with ⟨ i, j, k, rfl ⟩ ; exact ⟨ i + 2 * j + 3 * k, by ring_nf; norm_num [ pow_add, pow_mul' ] ⟩ ;
  have hs_card : s.card ≤ 1 := by
    exact antichain_pow2_subsingleton s hs_pow2 hs.2.1
  have hs_eq : s = {3} := by
    interval_cases _ : s.card <;> simp_all +decide [ Finset.card_le_one ];
    rw [ Finset.card_eq_one ] at * ; aesop
  simp_all +decide [ powTripleSet_2_4_8_eq ];
  exact absurd hs_pow2 ( by rintro ⟨ m, hm ⟩ ; linarith [ Nat.pow_le_pow_right ( show 1 ≤ 2 by norm_num ) ( show m ≥ 2 by contrapose! hm; interval_cases m <;> trivial ) ] )

