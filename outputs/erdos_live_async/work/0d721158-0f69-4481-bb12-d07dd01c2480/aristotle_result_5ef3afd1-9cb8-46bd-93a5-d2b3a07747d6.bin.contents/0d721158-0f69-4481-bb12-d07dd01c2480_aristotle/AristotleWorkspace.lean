-- counterexample mode target
import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-- A workspace-local Lean 4 stub for Erdos Problem 123. The formal-conjectures repo
contains a current statement very close to this one together with solved variants. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-!
## Counterexample: the most fragile variant

The theorem `erdos_123_d_complete_sequences` requires pairwise coprimality of `a`, `b`, `c`.
The "most fragile" variant drops this hypothesis. We exhibit a concrete falsifying witness:

**Witness:** `a = 2, b = 4, c = 16`.

These satisfy `1 < a`, `1 < b`, `1 < c`, but `¬ PairwiseCoprime3 2 4 16` (since `gcd(2,4)=2`).

Moreover, `PowTripleSet 2 4 16 = {2^(i+2j+4k) : i,j,k ∈ ℕ} ⊆ {powers of 2}`.
Any division antichain of powers of 2 has at most one element (since powers of 2 are
totally ordered by divisibility). So antichain sums are single powers of 2, and the set
is **not** d-complete: the number 3, for instance, is never representable.
-/

/-- Every element of `PowTripleSet 2 4 16` is a power of 2. -/
lemma powTripleSet_2_4_16_subset_powers_of_two :
    PowTripleSet 2 4 16 ⊆ {n | ∃ m : ℕ, n = 2 ^ m} := by
  intro n hn
  obtain ⟨i, j, k, hn⟩ := hn
  use i + 2 * j + 4 * k
  rw [hn]
  ring
  norm_num [pow_mul']

/-- Any division antichain of powers of 2 has cardinality at most 1. -/
lemma antichain_powers_of_two_card_le_one (s : Finset ℕ)
    (hs : (↑s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m})
    (ha : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  contrapose! ha
  obtain ⟨x, hx, y, hy, hxy⟩ := Finset.one_lt_card.mp ha
  rcases hs hx with ⟨m, rfl⟩
  rcases hs hy with ⟨n, rfl⟩
  rcases le_total m n with h | h
  · exact fun h' => h' hx hy (by aesop) (by exact pow_dvd_pow _ h)
  · exact fun h' => h' hy hx (by aesop) (by exact pow_dvd_pow _ h)

/-- The number 3 is not in `PowTripleSet 2 4 16`. -/
lemma three_not_in_powTripleSet_2_4_16 :
    3 ∉ PowTripleSet 2 4 16 := by
  rintro ⟨i, j, k, h⟩
  have := congr_arg (· % 2) h
  norm_num [Nat.mul_mod, Nat.pow_mod] at this
  cases i <;> cases j <;> cases k <;> norm_num at *

/-
PROBLEM
`PowTripleSet 2 4 16` is not d-complete: 3 has no antichain-sum representation.

PROVIDED SOLUTION
Assume for contradiction that PowTripleSet 2 4 16 is d-complete. Then by Filter.eventually_atTop.mp, there exists N such that for all n ≥ N, n has an antichain-sum representation from PowTripleSet 2 4 16.

Pick n = 2 * max N 3 + 1, which is ≥ N. Get a finset s with s ⊆ PowTripleSet 2 4 16, IsDivisionAntichain s, and s.sum id = n.

By powTripleSet_2_4_16_subset_powers_of_two, s ⊆ powers of 2. By antichain_powers_of_two_card_le_one, s.card ≤ 1. If s is empty, sum = 0, contradiction since n ≥ 3. If s = {x}, then x = n = 2*max N 3 + 1, which is odd. But x is a power of 2 (even or 1). Since n ≥ 3, x ≥ 3, so x ≠ 1, so x is even. But x is odd. Contradiction.
-/
lemma not_d_complete_2_4_16 :
    ¬ IsDComplete (PowTripleSet 2 4 16) := by
  intro h
  obtain ⟨N, hN⟩ : ∃ N, ∀ n ≥ N, ∃ s : Finset ℕ, (s : Set ℕ) ⊆ PowTripleSet 2 4 16 ∧ IsDivisionAntichain s ∧ s.sum id = n := by
    exact Filter.eventually_atTop.mp h;
  obtain ⟨ s, hs ⟩ := hN ( 2 * N + 3 ) ( by linarith );
  -- By powTripleSet_2_4_16_subset_powers_of_two, s ⊆ powers of 2. By antichain_powers_of_two_card_le_one, s.card ≤ 1.
  have hs_powers_of_two : (s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m} := by
    exact fun x hx => powTripleSet_2_4_16_subset_powers_of_two <| hs.1 hx
  have hs_card_le_one : s.card ≤ 1 := by
    exact antichain_powers_of_two_card_le_one s hs_powers_of_two hs.2.1
  have hs_empty_or_singleton : s = ∅ ∨ ∃ x, s = {x} := by
    exact Classical.or_iff_not_imp_left.2 fun h => Finset.card_eq_one.1 <| le_antisymm hs_card_le_one <| Finset.card_pos.2 <| Finset.nonempty_of_ne_empty h
  rcases hs_empty_or_singleton with ( rfl | ⟨ x, rfl ⟩ ) <;> simp_all +decide [ IsDivisionAntichain ];
  rcases hs_powers_of_two with ⟨ m, hm ⟩ ; have := congr_arg Even hm ; norm_num [ Nat.even_add, Nat.even_pow ] at this ; rcases m with ( _ | _ | m ) <;> simp_all +arith +decide [ Nat.pow_succ' ] ;

/-- The pairwise coprimality hypothesis in `erdos_123_d_complete_sequences` is necessary:
dropping it admits the counterexample `(a,b,c) = (2,4,16)`. -/
theorem fragile_variant_counterexample :
    ∃ a b c : ℕ, 1 < a ∧ 1 < b ∧ 1 < c ∧
      ¬ PairwiseCoprime3 a b c ∧
      ¬ IsDComplete (PowTripleSet a b c) := by
  exact ⟨2, 4, 16, by omega, by omega, by omega,
    by simp [PairwiseCoprime3, Nat.Coprime],
    not_d_complete_2_4_16⟩

end Erdos123