import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-! ## Basic properties of PowTripleSet -/

lemma one_mem_powTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c :=
  ⟨0, 0, 0, by simp⟩

lemma base_mem_powTripleSet_a (a b c : ℕ) : a ∈ PowTripleSet a b c :=
  ⟨1, 0, 0, by simp⟩

lemma base_mem_powTripleSet_b (a b c : ℕ) : b ∈ PowTripleSet a b c :=
  ⟨0, 1, 0, by simp⟩

lemma base_mem_powTripleSet_c (a b c : ℕ) : c ∈ PowTripleSet a b c :=
  ⟨0, 0, 1, by simp⟩

lemma pow_mem_powTripleSet_a (a b c : ℕ) (i : ℕ) : a ^ i ∈ PowTripleSet a b c :=
  ⟨i, 0, 0, by simp⟩

lemma pow_mem_powTripleSet_b (a b c : ℕ) (j : ℕ) : b ^ j ∈ PowTripleSet a b c :=
  ⟨0, j, 0, by simp⟩

lemma pow_mem_powTripleSet_c (a b c : ℕ) (k : ℕ) : c ^ k ∈ PowTripleSet a b c :=
  ⟨0, 0, k, by simp⟩

lemma mul_mem_powTripleSet {a b c : ℕ} {m n : ℕ}
    (hm : m ∈ PowTripleSet a b c) (hn : n ∈ PowTripleSet a b c) :
    m * n ∈ PowTripleSet a b c := by
  obtain ⟨i₁, j₁, k₁, rfl⟩ := hm
  obtain ⟨i₂, j₂, k₂, rfl⟩ := hn
  exact ⟨i₁ + i₂, j₁ + j₂, k₁ + k₂, by ring⟩

lemma pos_of_mem_powTripleSet {a b c n : ℕ} (ha : 0 < a) (hb : 0 < b) (hc : 0 < c)
    (hn : n ∈ PowTripleSet a b c) : 0 < n := by
  obtain ⟨i, j, k, rfl⟩ := hn
  positivity

/-! ## Divisibility antichain properties -/

lemma isDivisionAntichain_empty : IsDivisionAntichain ∅ := by
  intro x y hx; simp at hx

lemma isDivisionAntichain_singleton (n : ℕ) : IsDivisionAntichain {n} := by
  intro x y hx hy hne
  simp at hx hy
  exact absurd (hx ▸ hy.symm) hne

/-- Two elements a^i and b^j (with coprime a, b > 1, i,j ≥ 1) are incomparable
    under divisibility. This is a key reusable lemma. -/
lemma coprime_pow_not_dvd {a b : ℕ} (ha : 1 < a) (hb : 1 < b) (hab : Nat.Coprime a b)
    {i j : ℕ} (hi : 0 < i) (hj : 0 < j) : ¬ (a ^ i ∣ b ^ j) := by
  exact fun h => absurd ( Nat.Prime.dvd_of_dvd_pow ( Nat.minFac_prime ( by linarith ) ) ( dvd_trans ( Nat.minFac_dvd a ) ( dvd_trans ( dvd_pow_self _ hi.ne' ) h ) ) ) ( by intro t; have := Nat.dvd_gcd ( Nat.minFac_dvd a ) t; aesop )

/-- Symmetric version: b^j does not divide a^i for coprime a, b > 1. -/
lemma coprime_pow_not_dvd' {a b : ℕ} (ha : 1 < a) (hb : 1 < b) (hab : Nat.Coprime a b)
    {i j : ℕ} (hi : 0 < i) (hj : 0 < j) : ¬ (b ^ j ∣ a ^ i) := by
  exact mt ( fun h => Nat.Prime.dvd_of_dvd_pow ( Nat.minFac_prime ( by aesop ) ) ( dvd_trans ( dvd_pow ( Nat.minFac_dvd _ ) hj.ne' ) h ) ) ( by intro t; have := Nat.dvd_gcd t ( Nat.minFac_dvd _ ) ; aesop )

/-- Products of coprime bases with incomparable exponent triples are
    divisibility-incomparable. This captures the core antichain structure.
    **Reusable covering lemma**: This is the foundational criterion that recurs
    across ALL parameter triples — it reduces divisibility checking to componentwise
    comparison on exponent vectors. -/
lemma powTriple_not_dvd_of_incomparable {a b c : ℕ}
    (ha : 1 < a) (hb : 1 < b) (hc : 1 < c) (hpc : PairwiseCoprime3 a b c)
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ}
    (h_incomp : ¬ (i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂)) :
    ¬ (a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂) := by
  contrapose! h_incomp
  have h_div_a : a ^ i₁ ∣ a ^ i₂ := by
    have h_div_a : a ^ i₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
      exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_right _ _ ) _ ) h_incomp
    have h_coprime_a_bc : Nat.Coprime (a ^ i₁) (b ^ j₂ * c ^ k₂) := by
      apply_mod_cast Nat.Coprime.mul_right <;> apply_rules [ Nat.Coprime.pow, hpc.1, hpc.2.1, hpc.2.2 ]
    exact h_coprime_a_bc.dvd_of_dvd_mul_right <| by simpa only [ mul_assoc ] using h_div_a
  have h_div_b : b ^ j₁ ∣ b ^ j₂ := by
    obtain ⟨ k, hk ⟩ := h_incomp
    have h_div_b : b ^ j₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
      exact hk.symm ▸ dvd_mul_of_dvd_left ( dvd_mul_of_dvd_left ( dvd_mul_left _ _ ) _ ) _
    refine' Nat.Coprime.dvd_of_dvd_mul_left _ ( Nat.Coprime.dvd_of_dvd_mul_right _ h_div_b )
    · exact Nat.Coprime.pow _ _ <| hpc.1.symm
    · exact Nat.Coprime.pow _ _ <| hpc.2.2
  have h_div_c : c ^ k₁ ∣ c ^ k₂ := by
    have h_div_c : c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
      exact dvd_trans ( dvd_mul_left _ _ ) h_incomp
    refine' Nat.Coprime.dvd_of_dvd_mul_left _ h_div_c
    rw [ Nat.coprime_mul_iff_right ]
    exact ⟨ Nat.Coprime.pow _ _ <| hpc.2.1.symm, Nat.Coprime.pow _ _ <| hpc.2.2.symm ⟩
  exact ⟨ Nat.le_of_not_lt fun hi => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans ha ) _ ) ( pow_lt_pow_right₀ ha hi ) h_div_a, Nat.le_of_not_lt fun hj => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hb ) _ ) ( pow_lt_pow_right₀ hb hj ) h_div_b, Nat.le_of_not_lt fun hk => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hc ) _ ) ( pow_lt_pow_right₀ hc hk ) h_div_c ⟩

/-- Elements at the same "level" L (i.e., i + j + k = L) form a divisibility antichain.
    **Reusable covering lemma**: Level-based antichains are a universal construction
    that works for ALL parameter triples. At level L, the antichain has (L+1)(L+2)/2
    elements and their subset sums grow exponentially, providing the density needed
    for d-completeness. -/
lemma antichain_same_level {a b c : ℕ}
    (ha : 1 < a) (hb : 1 < b) (hc : 1 < c) (hpc : PairwiseCoprime3 a b c)
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ}
    (hL : i₁ + j₁ + k₁ = i₂ + j₂ + k₂)
    (hne : (i₁, j₁, k₁) ≠ (i₂, j₂, k₂)) :
    ¬ (a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂) := by
  convert powTriple_not_dvd_of_incomparable ha hb hc hpc _ using 1
  grind

/-! ## Covering / representation lemmas -/

/-- Frobenius-type: for coprime a, b > 1, every sufficiently large natural number
    is a non-negative integer combination of a and b.
    **Reusable**: This is the foundational covering lemma for 2-generator semigroups. -/
lemma frobenius_two_coprime {a b : ℕ} (ha : 1 < a) (hb : 1 < b) (hab : Nat.Coprime a b) :
    ∀ᶠ n in atTop, ∃ x y : ℕ, n = x * a + y * b := by
  norm_num at *
  use a * b + 1
  intro n hn
  obtain ⟨x, y, hxy⟩ : ∃ x y : ℤ, n = x * a + y * b ∧ 0 ≤ x ∧ x < b := by
    have h_bezout : ∃ x y : ℤ, n = x * a + y * b := by
      exact ⟨ Nat.gcdA a b * n, Nat.gcdB a b * n, by nlinarith [ Nat.gcd_eq_gcd_ab a b ] ⟩
    obtain ⟨ x, y, hxy ⟩ := h_bezout
    exact ⟨ x % b, y + x / b * a, by nth_rw 1 [ hxy ] ; nlinarith [ Int.emod_add_mul_ediv x b ], Int.emod_nonneg _ ( by positivity ), by linarith [ Int.emod_lt_of_pos x ( by positivity : 0 < ( b : ℤ ) ) ] ⟩
  exact ⟨ Int.toNat x, Int.toNat y, by nlinarith only [ Int.toNat_of_nonneg hxy.2.1, Int.toNat_of_nonneg ( by nlinarith : ( 0 : ℤ ) ≤ y ), hxy.1 ] ⟩

/-- Key extraction lemma: for coprime a, b > 1, if n ≥ a*b, then Euclidean division
    works with positive quotient. -/
lemma div_extract {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (n : ℕ) (hn : a * b ≤ n) :
    (∃ m r : ℕ, n = m * a + r ∧ r < a ∧ 0 < m) ∧
    (∃ m r : ℕ, n = m * b + r ∧ r < b ∧ 0 < m) := by
  exact ⟨ ⟨ n / a, n % a, by rw [ Nat.div_add_mod' ], Nat.mod_lt _ ( pos_of_gt ha ), Nat.div_pos ( by nlinarith ) ( pos_of_gt ha ) ⟩, ⟨ n / b, n % b, by rw [ Nat.div_add_mod' ], Nat.mod_lt _ ( pos_of_gt hb ), Nat.div_pos ( by nlinarith ) ( pos_of_gt hb ) ⟩ ⟩

/-! ## Scaling lemma: multiplying an antichain representation by an element preserves it -/

/-- If s is an antichain in PowTripleSet(a,b,c) summing to n, then
    (s.image (· * a)) is an antichain in PowTripleSet summing to a*n.
    **Reusable**: This scaling lemma is the key composition tool. It shows that
    the set of representable numbers is closed under multiplication by generators,
    which is essential for all parameter triples. The analogous lemma holds for b, c,
    and in fact any element of PowTripleSet. -/
lemma scale_antichain_rep (a b c : ℕ) (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (s : Finset ℕ) (n : ℕ)
    (hs_sub : (↑s : Set ℕ) ⊆ PowTripleSet a b c)
    (hs_anti : IsDivisionAntichain s)
    (hs_sum : s.sum id = n)
    (hs_pos : ∀ x ∈ s, 0 < x) :
    ∃ t : Finset ℕ, (↑t : Set ℕ) ⊆ PowTripleSet a b c ∧
      IsDivisionAntichain t ∧ t.sum id = a * n := by
  refine' ⟨ s.image fun x => x * a, _, _, _ ⟩
  · norm_num +zetaDelta at *
    exact fun x hx => mul_mem_powTripleSet ( hs_sub hx ) ( base_mem_powTripleSet_a a b c )
  · intro x hx y hy hxy
    obtain ⟨ x, hx, rfl ⟩ := Finset.mem_image.mp y
    obtain ⟨ y, hy, rfl ⟩ := Finset.mem_image.mp hy
    simp_all +decide [ Nat.mul_dvd_mul_iff_right ( pos_of_gt ha ) ]
    exact hs_anti hx hy hxy.1
  · simp +decide [ ← hs_sum, mul_comm, Finset.mul_sum _ _ _ ]
    rw [ Finset.sum_image ( by intros x hx y hy hxy; nlinarith [ hs_pos x hx, hs_pos y hy ] ) ]

/-! ## Adversarial blocker analysis -/

/-- **Adversarial witness 1**: `coprime_sum_ab_ac` is false in general.
    For a = 3, b = 5, c = 7 (pairwise coprime, all > 1),
    gcd(a + b, a + c) = gcd(8, 10) = 2 ≠ 1.
    This refutes the naive "two coprime generators from pairwise sums" approach. -/
theorem adversarial_coprime_sums_not_coprime :
    ¬ (∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c → Nat.Coprime (a + b) (a + c)) := by
  simp +zetaDelta at *
  exists 3, by decide, 5, by decide, 7, by decide

/-- The gcd of all pairwise sums divides 2. This characterizes the "blocker"
    obstruction for pairwise-sum-based covering strategies. -/
lemma gcd_pairwise_sums_dvd_two {a b c : ℕ}
    (hpc : PairwiseCoprime3 a b c) :
    Nat.gcd (a + b) (Nat.gcd (a + c) (b + c)) ∣ 2 := by
  have hdvd2c : Nat.gcd (a + b) (Nat.gcd (a + c) (b + c)) ∣ 2 * c := by
    rw [ ← Int.natCast_dvd_natCast ]
    convert Int.dvd_sub ( Int.dvd_add ( Int.natCast_dvd_natCast.mpr ( Nat.gcd_dvd_right _ _ |> Nat.dvd_trans <| Nat.gcd_dvd_right _ _ ) ) ( Int.natCast_dvd_natCast.mpr ( Nat.gcd_dvd_right _ _ |> Nat.dvd_trans <| Nat.gcd_dvd_left _ _ ) ) ) ( Int.natCast_dvd_natCast.mpr ( Nat.gcd_dvd_left _ _ ) ) using 1 ; push_cast ; ring
  refine' Nat.Coprime.dvd_of_dvd_mul_right _ hdvd2c
  simp_all +decide [ Nat.Coprime, Nat.gcd_assoc ]
  cases hpc ; aesop

/-- **Adversarial witness 2**: Even with one even element, pairwise sums
    need NOT be coprime. For a = 2, b = 3, c = 13: gcd(5, 15) = 5.
    This refutes the "even element eliminates the blocker" hypothesis. -/
theorem adversarial_even_sums_not_coprime :
    ¬ (∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c → 2 ∣ a → Nat.gcd (a + b) (a + c) = 1) := by
  simp +zetaDelta at *
  exists 2, by decide, 3, by decide, 13, by decide

/-! ## Two-element antichain representations -/

/-
PROBLEM
For coprime a, b > 1, the pair {a, b} is always an antichain.

PROVIDED SOLUTION
For coprime a, b > 1 with a ≠ b, the pair {a, b} is an antichain. We need to show: a ∤ b and b ∤ a. Since gcd(a,b) = 1, if a | b then a = 1 (contradiction with a > 1). Similarly b ∤ a. Use Nat.Coprime.eq_one_of_self_mul_self_dvd or similar.
-/
lemma pair_antichain {a b : ℕ} (ha : 1 < a) (hb : 1 < b) (hab : Nat.Coprime a b)
    (hab_ne : a ≠ b) : IsDivisionAntichain {a, b} := by
  -- By definition of IsDivisionAntichain, we need to show that for any x y in {a, b}, if x ≠ y, then x does not divide y.
  unfold IsDivisionAntichain;
  simp +zetaDelta at *;
  rintro x y ( rfl | rfl ) ( rfl | rfl ) <;> simp_all +decide [ Nat.Coprime, Nat.gcd_eq_left_iff_dvd ];
  · exact fun h => by have := Nat.gcd_eq_left h; aesop;
  · exact fun h => fun h' => by have := Nat.gcd_eq_right h'; aesop;

/-
PROBLEM
For coprime a, b > 1 with a ≠ b, a + b is representable as an antichain sum
    from PowTripleSet(a, b, c).

PROVIDED SOLUTION
Use the Finset {a, b}. Show: (1) both a and b are in PowTripleSet (by base_mem_powTripleSet_a/b), (2) {a, b} is an antichain (since a ∤ b and b ∤ a by coprimality, and a ≠ b since coprime numbers > 1 must be distinct), (3) sum = a + b. For a = b: impossible since gcd(a,b) = 1 and both > 1 requires a ≠ b.
-/
lemma sum_pair_representable {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hpc : PairwiseCoprime3 a b c) :
    ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowTripleSet a b c ∧
      IsDivisionAntichain s ∧ s.sum id = a + b := by
  refine' ⟨ { a, b }, _, _, _ ⟩ <;> norm_num;
  · exact Set.insert_subset_iff.mpr ⟨ base_mem_powTripleSet_a a b c, Set.singleton_subset_iff.mpr ( base_mem_powTripleSet_b a b c ) ⟩;
  · exact pair_antichain ha hb hpc.1 ( by rintro rfl; have := hpc.1; aesop );
  · rw [ Finset.sum_pair ] ; cases hpc ; aesop

/-
PROBLEM
For coprime a, b > 1, the pair {a*b, c} is always an antichain when
    c is coprime to both a and b.

PROVIDED SOLUTION
Need to show {a*b, c} is an antichain. First, a*b ≠ c (since a*b ≥ 2*2 = 4 and c might equal ab, but gcd(ab, c) = 1 means c ∤ ab unless c = 1, contradicting c > 1; actually a*b could equal c in theory... no: gcd(a,c)=1 and gcd(b,c)=1 so gcd(ab,c)=1, and c > 1 so c ∤ 1 = gcd(ab,c), hence c ∤ ab. And ab | c requires ab ≤ c, but then gcd(ab,c) = ab since ab | c, and ab > 1, contradicting gcd(ab,c)=1). So ab ∤ c and c ∤ ab. Also ab ≠ c (if ab = c then gcd(ab,c) = c = ab > 1, contradicting gcd = 1). So it's an antichain.
-/
lemma pair_ab_c_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hpc : PairwiseCoprime3 a b c) :
    IsDivisionAntichain ({a * b, c} : Finset ℕ) := by
  -- Since a, b, and c are pairwise coprime, gcd(ab, c) = 1. Therefore, ab and c are coprime.
  have h_coprime : Nat.Coprime (a * b) c := by
    exact Nat.Coprime.mul_left hpc.2.1 hpc.2.2;
  intro x hx y hy hxy;
  rw [ Finset.mem_insert, Finset.mem_singleton ] at y hy;
  cases y <;> cases hy <;> simp_all +decide [ Nat.Coprime, Nat.gcd_mul_left ];
  · exact fun h => by have := Nat.gcd_eq_left h; aesop;
  · exact fun h => by have := Nat.gcd_eq_right h; aesop;

/-
PROBLEM
a*b + c is representable.

PROVIDED SOLUTION
Use the Finset {a*b, c}. Show: (1) a*b ∈ PowTripleSet (exponents (1,1,0)) and c ∈ PowTripleSet (exponents (0,0,1)), (2) {a*b, c} is an antichain (by pair_ab_c_antichain), (3) sum = a*b + c. The membership follows from mul_mem_powTripleSet or direct construction.
-/
lemma sum_ab_c_representable {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hpc : PairwiseCoprime3 a b c) :
    ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowTripleSet a b c ∧
      IsDivisionAntichain s ∧ s.sum id = a * b + c := by
  refine' ⟨ { a * b, c }, _, _, _ ⟩ <;> norm_num;
  · rintro x ( rfl | rfl ) <;> [ exact ⟨ 1, 1, 0, by ring ⟩ ; exact ⟨ 0, 0, 1, by ring ⟩ ];
  · exact?;
  · rw [ Finset.sum_pair ];
    rintro rfl;
    have := hpc.2.1; have := hpc.2.2; simp_all +decide [ Nat.coprime_mul_iff_left, Nat.coprime_mul_iff_right ] ;

/-! ## The main theorem -/

/-- Erdos Problem 123: d-completeness of multiplicative semigroups.
    For pairwise coprime a, b, c > 1, the set {a^i * b^j * c^k} is d-complete.

    This is a deep theorem in additive number theory. The proven helper lemmas
    provide the key building blocks:

    **Reusable lemmas that recur across all parameter triples:**
    1. `powTriple_not_dvd_of_incomparable` — Divisibility ↔ componentwise ≤ on exponents.
       This is the universal criterion that works for ALL pairwise coprime triples.
    2. `antichain_same_level` — Same-level (i+j+k = L) elements form antichains.
       This provides the "free" antichain structure at each level.
    3. `scale_antichain_rep` — Representations scale under multiplication by generators.
       This shows RepSet is closed under multiplication by PowTripleSet elements.
    4. `frobenius_two_coprime` — Coprime generators eventually cover all integers.
    5. `gcd_pairwise_sums_dvd_two` — The GCD blocker for pairwise sums is at most 2.

    The full proof requires combining these with a subset-sum density argument
    at high levels: at level L, there are (L+1)(L+2)/2 antichain elements, and
    their 2^{(L+1)(L+2)/2} subset sums eventually cover all integers in a suitable
    range, which can be extended to all large integers via scaling. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

end Erdos123