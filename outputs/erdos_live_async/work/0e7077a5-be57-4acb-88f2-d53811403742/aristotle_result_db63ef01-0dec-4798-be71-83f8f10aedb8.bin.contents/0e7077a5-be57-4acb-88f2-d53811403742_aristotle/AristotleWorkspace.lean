/-! ## Core definitions -/

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ‚Ąē) : Set ‚Ąē :=
  {n | ‚ąÉ i j k : ‚Ąē, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ‚Ąē) : Prop :=
  Nat.Coprime a b ‚ąß Nat.Coprime a c ‚ąß Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ‚Ąē) : Prop :=
  ‚ąÄ ‚¶Éx y : ‚Ąē‚¶Ą, x ‚ąą s ‚Üí y ‚ąą s ‚Üí x ‚Č† y ‚Üí ¬¨ x ‚ą£ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ‚Ąē) : Prop :=
  ‚ąÄŠ∂† n : ‚Ąē in atTop, ‚ąÉ s : Finset ‚Ąē,
    (‚ÜĎs : Set ‚Ąē) ‚äÜ A ‚ąß IsDivisionAntichain s ‚ąß s.sum id = n

/-! ## Structural lemmas about PowTripleSet -/

lemma PowTripleSet_one_mem (a b c : ‚Ąē) : 1 ‚ąą PowTripleSet a b c :=
  ‚ü®0, 0, 0, by simp‚ü©

lemma PowTripleSet_base_a_mem {a b c : ‚Ąē} (ha : 0 < a) : a ‚ąą PowTripleSet a b c :=
  ‚ü®1, 0, 0, by simp‚ü©

lemma PowTripleSet_base_b_mem {a b c : ‚Ąē} (hb : 0 < b) : b ‚ąą PowTripleSet a b c :=
  ‚ü®0, 1, 0, by simp‚ü©

lemma PowTripleSet_base_c_mem {a b c : ‚Ąē} (hc : 0 < c) : c ‚ąą PowTripleSet a b c :=
  ‚ü®0, 0, 1, by simp‚ü©

lemma PowTripleSet_mul_closed {a b c : ‚Ąē} {x y : ‚Ąē}
    (hx : x ‚ąą PowTripleSet a b c) (hy : y ‚ąą PowTripleSet a b c) :
    x * y ‚ąą PowTripleSet a b c := by
  obtain ‚ü®i1, j1, k1, rfl‚ü© := hx
  obtain ‚ü®i2, j2, k2, rfl‚ü© := hy
  exact ‚ü®i1 + i2, j1 + j2, k1 + k2, by ring‚ü©

lemma PowTripleSet_pow_mem {a b c : ‚Ąē} {x : ‚Ąē} (n : ‚Ąē)
    (hx : x ‚ąą PowTripleSet a b c) : x ^ n ‚ąą PowTripleSet a b c := by
  induction n with
  | zero => exact ‚ü®0, 0, 0, by simp‚ü©
  | succ n ih => simpa only [pow_succ, mul_comm] using PowTripleSet_mul_closed hx ih

/-
PROBLEM
Every element of PowTripleSet is positive when a, b, c > 0.

PROVIDED SOLUTION
Get exponents i,j,k from hn. Then n = a^i * b^j * c^k. Since a, b, c > 0, each power is positive, so the product is positive.
-/
lemma PowTripleSet_pos {a b c : ‚Ąē} (ha : 0 < a) (hb : 0 < b) (hc : 0 < c)
    {n : ‚Ąē} (hn : n ‚ąą PowTripleSet a b c) : 0 < n := by
  obtain ‚ü® i, j, k, rfl ‚ü© := hn; positivity;

/-! ## Divisibility characterization (key reusable lemma) -/

/-
PROBLEM
**Divisibility-extraction lemma.** For pairwise coprime `a`, `b`, `c > 1`,
divisibility in `PowTripleSet` is characterized by componentwise `‚Č§` on
exponent triples.  This is the fundamental reusable lemma that recurs
across *all* parameter triples `(a, b, c)`.

PROVIDED SOLUTION
Forward direction: If the product divides, extract each exponent comparison using coprimality. For the a-exponent: a^i‚āĀ divides the whole product a^i‚āā * b^j‚āā * c^k‚āā. Since a is coprime to b and c, a^i‚āĀ is coprime to b^j‚āā * c^k‚āā. So a^i‚āĀ | a^i‚āā. Since a > 1, this gives i‚āĀ ‚Č§ i‚āā. Similarly for b and c exponents. Backward direction: componentwise ‚Č§ gives divisibility of each power factor.
-/
lemma coprime_triple_dvd_iff {a b c : ‚Ąē} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {i‚āĀ j‚āĀ k‚āĀ i‚āā j‚āā k‚āā : ‚Ąē} :
    a ^ i‚āĀ * b ^ j‚āĀ * c ^ k‚āĀ ‚ą£ a ^ i‚āā * b ^ j‚āā * c ^ k‚āā ‚ÜĒ
    i‚āĀ ‚Č§ i‚āā ‚ąß j‚āĀ ‚Č§ j‚āā ‚ąß k‚āĀ ‚Č§ k‚āā := by
  constructor <;> intro H;
  ¬∑ -- Let $p$ be any prime number. Since $a$, $b$, and $c$ are pairwise coprime, $p$ cannot divide all three numbers.
    have h_prime_div : ‚ąÄ p : ‚Ąē, Nat.Prime p ‚Üí (p ‚ą£ a ‚Üí p ‚ą£ b ‚Üí False) ‚ąß (p ‚ą£ a ‚Üí p ‚ą£ c ‚Üí False) ‚ąß (p ‚ą£ b ‚Üí p ‚ą£ c ‚Üí False) := by
      exact fun p pp => ‚ü® fun pa pb => pp.not_dvd_one <| hcop.1 ‚Ėł Nat.dvd_gcd pa pb, fun pa pb => pp.not_dvd_one <| hcop.2.1 ‚Ėł Nat.dvd_gcd pa pb, fun pb pc => pp.not_dvd_one <| hcop.2.2 ‚Ėł Nat.dvd_gcd pb pc ‚ü©;
    -- By considering the prime factors of $a$, $b$, and $c$, we can deduce the inequalities on the exponents.
    have h_exp : ‚ąÄ p : ‚Ąē, Nat.Prime p ‚Üí (p ‚ą£ a ‚Üí i‚āĀ ‚Č§ i‚āā) ‚ąß (p ‚ą£ b ‚Üí j‚āĀ ‚Č§ j‚āā) ‚ąß (p ‚ą£ c ‚Üí k‚āĀ ‚Č§ k‚āā) := by
      intro p pp; have := Nat.factorization_le_iff_dvd ( by aesop ) ( by aesop ) |>.2 H; simp_all +decide [ Nat.factorization_mul, ne_of_gt ( zero_lt_one.trans ha ), ne_of_gt ( zero_lt_one.trans hb ), ne_of_gt ( zero_lt_one.trans hc ) ] ;
      replace this := this p; simp_all +decide [ Nat.factorization_eq_zero_iff ] ;
      by_cases ha : p ‚ą£ a <;> by_cases hb : p ‚ą£ b <;> by_cases hc : p ‚ą£ c <;> simp_all +decide [ Nat.factorization_eq_zero_of_not_dvd ];
      ¬∑ exact le_of_mul_le_mul_right this ( Nat.pos_of_ne_zero ( Finsupp.mem_support_iff.mp ( by aesop ) ) );
      ¬∑ exact le_of_mul_le_mul_right this ( Nat.pos_of_ne_zero ( Finsupp.mem_support_iff.mp ( by aesop ) ) );
      ¬∑ exact le_of_mul_le_mul_right this ( Nat.pos_of_ne_zero ( Finsupp.mem_support_iff.mp ( by aesop ) ) );
    exact ‚ü® h_exp ( Nat.minFac a ) ( Nat.minFac_prime ha.ne' ) |>.1 ( Nat.minFac_dvd a ), h_exp ( Nat.minFac b ) ( Nat.minFac_prime hb.ne' ) |>.2.1 ( Nat.minFac_dvd b ), h_exp ( Nat.minFac c ) ( Nat.minFac_prime hc.ne' ) |>.2.2 ( Nat.minFac_dvd c ) ‚ü©;
  ¬∑ exact mul_dvd_mul ( mul_dvd_mul ( pow_dvd_pow _ H.1 ) ( pow_dvd_pow _ H.2.1 ) ) ( pow_dvd_pow _ H.2.2 )

/-! ## Antichain structure (key reusable lemma) -/

/-
PROBLEM
**Same-level antichain lemma.** Elements of `PowTripleSet` at the same
"level" (equal exponent sum `i + j + k = d`) automatically form a divisibility
antichain.  This is because componentwise `‚Č§` with equal coordinate-sum
forces equality.

PROVIDED SOLUTION
Take x, y ‚ąą s with x ‚Č† y and suppose x ‚ą£ y. Get exponent triples (i‚āĀ,j‚āĀ,k‚āĀ) for x and (i‚āā,j‚āā,k‚āā) for y with x = a^i‚āĀ*b^j‚āĀ*c^k‚āĀ, y = a^i‚āā*b^j‚āā*c^k‚āā, and i‚āĀ+j‚āĀ+k‚āĀ = d = i‚āā+j‚āā+k‚āā. By coprime_triple_dvd_iff, x ‚ą£ y implies i‚āĀ ‚Č§ i‚āā, j‚āĀ ‚Č§ j‚āā, k‚āĀ ‚Č§ k‚āā. Combined with equal sums, omega gives i‚āĀ=i‚āā, j‚āĀ=j‚āā, k‚āĀ=k‚āā, so x = y, contradicting x ‚Č† y.
-/
lemma same_level_is_antichain {a b c : ‚Ąē} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    (s : Finset ‚Ąē) (d : ‚Ąē)
    (hs : ‚ąÄ x ‚ąą s, ‚ąÉ i j k : ‚Ąē, x = a ^ i * b ^ j * c ^ k ‚ąß i + j + k = d) :
    IsDivisionAntichain s := by
  intro x y hx hy hxy;
  obtain ‚ü® i‚āĀ, j‚āĀ, k‚āĀ, rfl, hi‚āĀ ‚ü© := hs x hx; obtain ‚ü® i‚āā, j‚āā, k‚āā, rfl, hi‚āā ‚ü© := hs y hy; simp_all +decide [ Nat.pow_dvd_pow_iff ] ;
  contrapose! hxy;
  have := coprime_triple_dvd_iff ha hb hc hcop |>.1 hxy;
  exact congr_arg‚āā ( ¬∑ * ¬∑ ) ( congr_arg‚āā ( ¬∑ * ¬∑ ) ( congr_arg _ ( by linarith ) ) ( congr_arg _ ( by linarith ) ) ) ( congr_arg _ ( by linarith ) )

/-
PROBLEM
**Cross-type antichain lemma.** Two elements `a^i‚āĀ * b^j‚āĀ * c^k‚āĀ` and
`a^i‚āā * b^j‚āā * c^k‚āā` are incomparable (form an antichain pair) when
the exponent triples are incomparable in the componentwise partial order.

PROVIDED SOLUTION
Unfold IsDivisionAntichain. Take x, y ‚ąą {e‚āĀ, e‚āā} with x ‚Č† y and suppose x ‚ą£ y. By Finset.mem_insert and Finset.mem_singleton, either (x=e‚āĀ,y=e‚āā) or (x=e‚āā,y=e‚āĀ). In the first case, by coprime_triple_dvd_iff, e‚āĀ ‚ą£ e‚āā implies i‚āĀ‚Č§i‚āā ‚ąß j‚āĀ‚Č§j‚āā ‚ąß k‚āĀ‚Č§k‚āā, contradicting h1. In the second case, e‚āā ‚ą£ e‚āĀ implies i‚āā‚Č§i‚āĀ ‚ąß j‚āā‚Č§j‚āĀ ‚ąß k‚āā‚Č§k‚āĀ, contradicting h2.
-/
lemma cross_type_antichain_pair {a b c : ‚Ąē} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {i‚āĀ j‚āĀ k‚āĀ i‚āā j‚āā k‚āā : ‚Ąē}
    (h1 : ¬¨(i‚āĀ ‚Č§ i‚āā ‚ąß j‚āĀ ‚Č§ j‚āā ‚ąß k‚āĀ ‚Č§ k‚āā))
    (h2 : ¬¨(i‚āā ‚Č§ i‚āĀ ‚ąß j‚āā ‚Č§ j‚āĀ ‚ąß k‚āā ‚Č§ k‚āĀ)) :
    IsDivisionAntichain ({a ^ i‚āĀ * b ^ j‚āĀ * c ^ k‚āĀ, a ^ i‚āā * b ^ j‚āā * c ^ k‚āā} : Finset ‚Ąē) := by
  intro x y;
  -- Assume that x divides y, then by the coprime_triple_dvd_iff lemma, the exponent triples must be componentwise ordered.
  by_contra h_div
  have h_order : (i‚āĀ ‚Č§ i‚āā ‚ąß j‚āĀ ‚Č§ j‚āā ‚ąß k‚āĀ ‚Č§ k‚āā) ‚ą® (i‚āā ‚Č§ i‚āĀ ‚ąß j‚āā ‚Č§ j‚āĀ ‚ąß k‚āā ‚Č§ k‚āĀ) := by
    simp +zetaDelta at *;
    rcases h_div with ‚ü® rfl | rfl, rfl | rfl, hxy, h ‚ü© <;> simp_all +decide [ coprime_triple_dvd_iff ];
  grind +splitIndPred

/-
PROBLEM
Elements with disjoint "support" are automatically antichain.
E.g., `a^i` (with `i ‚Č• 1`) and `b^j` (with `j ‚Č• 1`) are always antichain
because their exponent triples `(i,0,0)` and `(0,j,0)` are incomparable.

PROVIDED SOLUTION
Apply cross_type_antichain_pair with exponents (i,0,0) and (0,j,0). h1: ¬¨(i‚Č§0 ‚ąß 0‚Č§j ‚ąß 0‚Č§0) ‚ÄĒ since i > 0, i ‚Č§ 0 is false. h2: ¬¨(0‚Č§i ‚ąß j‚Č§0 ‚ąß 0‚Č§0) ‚ÄĒ since j > 0, j ‚Č§ 0 is false. Both push_neg + omega should work. Note: a^i = a^i * b^0 * c^0 and b^j = a^0 * b^j * c^0, so rewrite using pow_zero and mul_one.
-/
lemma pure_powers_antichain {a b c : ‚Ąē} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {i j : ‚Ąē} (hi : 0 < i) (hj : 0 < j) :
    IsDivisionAntichain ({a ^ i, b ^ j} : Finset ‚Ąē) := by
  convert cross_type_antichain_pair ha hb hc hcop _ _ using 1;
  rotate_left;
  exacts [ i, 0, 0, 0, j, 0, by omega, by omega, by ext; simp +decide ]

/-
PROBLEM
Singleton sets are always division antichains.

PROVIDED SOLUTION
Unfold IsDivisionAntichain. For x, y ‚ąą {n}, x = n and y = n, so x = y, contradicting x ‚Č† y.
-/
lemma singleton_antichain (n : ‚Ąē) : IsDivisionAntichain {n} := by
  intro x y hx hy hxy; aesop;

/-
PROBLEM
The empty set is a division antichain.

PROVIDED SOLUTION
Vacuously true since no elements in the empty set.
-/
lemma empty_antichain : IsDivisionAntichain (‚ąÖ : Finset ‚Ąē) := by
  tauto

/-
PROBLEM
Subsets of division antichains are division antichains.

PROVIDED SOLUTION
Take x, y ‚ąą s with x ‚Č† y. Since s ‚äÜ t, x, y ‚ąą t. Apply h to get ¬¨ x ‚ą£ y.
-/
lemma IsDivisionAntichain.subset {s t : Finset ‚Ąē}
    (h : IsDivisionAntichain t) (hst : s ‚äÜ t) : IsDivisionAntichain s := by
  exact fun x y hx hy hxy => h ( hst hx ) ( hst hy ) hxy

/-! ## Membership and element-level lemmas -/

lemma PowTripleSet_mem_iff {a b c n : ‚Ąē} :
    n ‚ąą PowTripleSet a b c ‚ÜĒ ‚ąÉ i j k : ‚Ąē, n = a ^ i * b ^ j * c ^ k := Iff.rfl

/-- Level-d elements are in PowTripleSet. -/
lemma level_elem_mem {a b c : ‚Ąē} {i j k : ‚Ąē} :
    a ^ i * b ^ j * c ^ k ‚ąą PowTripleSet a b c :=
  ‚ü®i, j, k, rfl‚ü©

/-! ## Main theorem -/

/-- **ErdŇĎs Problem 123.** For pairwise coprime `a, b, c > 1`, the multiplicative
semigroup `{a^i ¬∑ b^j ¬∑ c^k}` is d-complete: every sufficiently large integer
admits a representation as a sum of distinct elements from the set, no one of
which divides another.

*Proof status:* The structural infrastructure (divisibility characterization,
antichain structure, cross-type compatibility) is fully proved above.  The
combinatorial covering step ‚ÄĒ showing that antichain subset sums from level-d
elements eventually cover all integers ‚ÄĒ requires a density / additive
combinatorics argument that is not yet formalized. -/
theorem erdos_123_d_complete_sequences :
    ‚ąÄ a b c : ‚Ąē, 1 < a ‚Üí 1 < b ‚Üí 1 < c ‚Üí
      PairwiseCoprime3 a b c ‚Üí
      IsDComplete (PowTripleSet a b c) := by
  sorry

end Erdos123