import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

-- ============================================================
-- HELPER LEMMAS: Infrastructure for the main theorem
-- ============================================================

/-- 1 belongs to PowTripleSet. -/
lemma one_mem_powTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c := by
  exact ⟨ 0, 0, 0, by norm_num ⟩

/-- PowTripleSet is closed under multiplication by `a`. -/
lemma mul_a_mem {a b c n : ℕ} (hn : n ∈ PowTripleSet a b c) :
    a * n ∈ PowTripleSet a b c := by
  obtain ⟨ i, j, k, rfl ⟩ := hn; exact ⟨ i + 1, j, k, by ring ⟩

/-- PowTripleSet is closed under multiplication by `b`. -/
lemma mul_b_mem {a b c n : ℕ} (hn : n ∈ PowTripleSet a b c) :
    b * n ∈ PowTripleSet a b c := by
  obtain ⟨ i, j, k, rfl ⟩ := hn; exact ⟨ i, j + 1, k, by ring ⟩

/-- PowTripleSet is closed under multiplication by `c`. -/
lemma mul_c_mem {a b c n : ℕ} (hn : n ∈ PowTripleSet a b c) :
    c * n ∈ PowTripleSet a b c := by
  obtain ⟨ i, j, k, rfl ⟩ := hn; exact ⟨ i, j, k + 1, by ring ⟩

/-- All positive powers of generators are in the set. -/
lemma pow_mem_powTripleSet_a (a b c : ℕ) (i : ℕ) :
    a ^ i ∈ PowTripleSet a b c := by
  exact ⟨ i, 0, 0, by ring ⟩

lemma pow_mem_powTripleSet_b (a b c : ℕ) (j : ℕ) :
    b ^ j ∈ PowTripleSet a b c := by
  exact ⟨ 0, j, 0, by ring ⟩

lemma pow_mem_powTripleSet_c (a b c : ℕ) (k : ℕ) :
    c ^ k ∈ PowTripleSet a b c := by
  exact ⟨ 0, 0, k, by ring ⟩

/-- Divisibility in PowTripleSet with coprimality: a^i₁ * b^j₁ * c^k₁ divides
    a^i₂ * b^j₂ * c^k₂ iff all exponents are componentwise ≤. -/
lemma powTriple_dvd_iff {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ} :
    a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ ↔
    i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
  constructor <;> intro h_div
  have h_exp_div : a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ → i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
    intro h_div
    have h_exp_div_a : a ^ i₁ ∣ a ^ i₂ := by
      refine' Nat.Coprime.dvd_of_dvd_mul_right _ _;
      exact b ^ j₂ * c ^ k₂;
      · exact Nat.Coprime.mul_right ( Nat.Coprime.pow _ _ hcop.1 ) ( Nat.Coprime.pow _ _ hcop.2.1 );
      · convert dvd_of_mul_right_dvd ( dvd_of_mul_right_dvd h_div ) using 1 ; ring
    have h_exp_div_b : b ^ j₁ ∣ b ^ j₂ := by
      have h_exp_div_b : b ^ j₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
        exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_left _ _ ) _ ) h_div;
      have h_exp_div_b : b ^ j₁ ∣ a ^ i₂ * c ^ k₂ * b ^ j₂ := by
        convert h_exp_div_b using 1 ; ring;
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ h_exp_div_b;
      rw [ Nat.coprime_mul_iff_right ];
      exact ⟨ Nat.Coprime.pow _ _ <| hcop.1.symm, Nat.Coprime.pow _ _ <| hcop.2.2 ⟩
    have h_exp_div_c : c ^ k₁ ∣ c ^ k₂ := by
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ _;
      exact a ^ i₂ * b ^ j₂;
      · exact Nat.Coprime.mul_right ( Nat.Coprime.pow _ _ <| hcop.2.1.symm ) ( Nat.Coprime.pow _ _ <| hcop.2.2.symm );
      · exact dvd_trans ( dvd_mul_left _ _ ) h_div;
    exact ⟨ Nat.le_of_not_lt fun hi => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans ha ) _ ) ( pow_lt_pow_right₀ ha hi ) h_exp_div_a, Nat.le_of_not_lt fun hj => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hb ) _ ) ( pow_lt_pow_right₀ hb hj ) h_exp_div_b, Nat.le_of_not_lt fun hk => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hc ) _ ) ( pow_lt_pow_right₀ hc hk ) h_exp_div_c ⟩;
  · exact h_exp_div h_div;
  · exact mul_dvd_mul ( mul_dvd_mul ( pow_dvd_pow _ h_div.1 ) ( pow_dvd_pow _ h_div.2.1 ) ) ( pow_dvd_pow _ h_div.2.2 )

/-- All elements of PowTripleSet are positive (when generators are > 1). -/
lemma pos_of_mem_powTripleSet {a b c n : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hn : n ∈ PowTripleSet a b c) : 0 < n := by
  obtain ⟨ i, j, k, rfl ⟩ := hn; positivity;

/-- A singleton from PowTripleSet is always a valid antichain sum representation. -/
lemma singleton_antichain {a b c n : ℕ} (hn : n ∈ PowTripleSet a b c) :
    IsDivisionAntichain {n} := by
  intro x y hx hy hxy; aesop;

/-- The set {a, b, c} is a divisibility antichain when a, b, c are pairwise coprime and > 1. -/
lemma generators_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) :
    IsDivisionAntichain {a, b, c} := by
  simp [IsDivisionAntichain, PairwiseCoprime3] at *; (
  rintro x y ( rfl | rfl | rfl ) ( rfl | rfl | rfl ) <;> intro h <;> simp_all +decide [ Nat.Coprime, Nat.gcd_eq_left_iff_dvd ] ;
  all_goals intro H; have := Nat.gcd_eq_left H; simp_all +decide [ Nat.gcd_comm ] ;)

/-- The singleton finset has the correct sum. -/
lemma singleton_sum (n : ℕ) : ({n} : Finset ℕ).sum id = n := by
  norm_num +zetaDelta at *

/-- Every element of PowTripleSet can be represented as an antichain sum (trivially). -/
lemma mem_has_antichain_rep {a b c n : ℕ} (hn : n ∈ PowTripleSet a b c) :
    ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowTripleSet a b c ∧
    IsDivisionAntichain s ∧ s.sum id = n := by
  exact ⟨ { n }, by simpa using hn, by simpa using singleton_antichain hn, by simpa ⟩

/-- PowTripleSet contains infinitely many elements. -/
lemma powTripleSet_infinite {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c) :
    Set.Infinite (PowTripleSet a b c) := by
  exact Set.infinite_of_injective_forall_mem ( fun x y hxy => by simpa using Nat.pow_right_injective ha hxy ) fun x => pow_mem_powTripleSet_a a b c x

/-- For coprime a, b > 1, every sufficiently large natural number can be written as
    a non-negative integer linear combination of a and b. This is the Chicken McNugget /
    Frobenius theorem for two generators. -/
lemma frobenius_two (a b : ℕ) (ha : 1 < a) (hb : 1 < b) (hcop : Nat.Coprime a b) :
    ∀ᶠ n : ℕ in atTop, ∃ x y : ℕ, n = x * a + y * b := by
  set N := a * b - a - b;
  have h_decomp : ∀ n > N, ∃ x y : ℤ, n = x * a + y * b ∧ 0 ≤ x ∧ x < b := by
    intro n hn
    obtain ⟨x, y, hxy⟩ : ∃ x y : ℤ, n = x * a + y * b := by
      exact ⟨ n * Nat.gcdA a b, n * Nat.gcdB a b, by nlinarith [ Nat.gcd_eq_gcd_ab a b ] ⟩;
    exact ⟨ x % b, y + x / b * a, by nth_rw 1 [ hxy ] ; nlinarith [ Int.emod_add_mul_ediv x b ], Int.emod_nonneg _ <| by positivity, Int.emod_lt_of_pos _ <| by positivity ⟩;
  filter_upwards [ Filter.eventually_gt_atTop N ] with n hn using by obtain ⟨ x, y, hxy, hx, hy ⟩ := h_decomp n hn; exact ⟨ x.toNat, y.toNat, by nlinarith [ Int.toNat_of_nonneg hx, Int.toNat_of_nonneg ( by nlinarith [ Nat.sub_add_cancel ( show a ≤ a * b from by nlinarith ), Nat.sub_add_cancel ( show b ≤ a * b - a from Nat.le_sub_of_add_le ( by nlinarith ) ) ] : ( 0 : ℤ ) ≤ y ) ] ⟩ ;

-- ============================================================
-- KEY STRUCTURAL LEMMAS for the main theorem
-- ============================================================

/-- Elements at the same "bc-level" M (with different b,c exponents summing to M)
    form an antichain, regardless of the a-exponent chosen. -/
lemma level_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {M : ℕ} (s : Finset (Fin (M + 1)))
    (f : Fin (M + 1) → ℕ) :
    IsDivisionAntichain (s.image (fun p => a ^ (f p) * b ^ (p : ℕ) * c ^ (M - (p : ℕ)))) := by
  unfold IsDivisionAntichain;
  simp;
  intro x y i hi hx j hj hy hxy;
  rw [ ← hx, ← hy ];
  rw [ powTriple_dvd_iff ha hb hc hcop ];
  grind

/-- The elements a^{f(p)} · b^p · c^{M-p} all belong to PowTripleSet. -/
lemma level_mem_powTripleSet (a b c : ℕ) (M : ℕ) (p : Fin (M + 1)) (f : ℕ) :
    a ^ f * b ^ (p : ℕ) * c ^ (M - (p : ℕ)) ∈ PowTripleSet a b c := by
  exact ⟨ f, p, M - p, rfl ⟩

/-- If A ⊆ B and A is d-complete, then B is d-complete. -/
lemma IsDComplete.mono {A B : Set ℕ} (hAB : A ⊆ B) (hA : IsDComplete A) :
    IsDComplete B := by
  filter_upwards [ hA ] with n hn using by obtain ⟨ s, hsA, hs ⟩ := hn; exact ⟨ s, Set.Subset.trans hsA hAB, hs ⟩ ;

/-
PROBLEM
Elements a^i · b (with i ≥ 0, b-exponent 1, c-exponent 0) and a^j · c
    (with j ≥ 0, b-exponent 0, c-exponent 1) are always divisibility-incomparable
    when a, b, c are pairwise coprime and > 1.

PROVIDED SOLUTION
We need to show that a^i * b does not divide a^j * c and vice versa.

By powTriple_dvd_iff, a^i * b * c^0 ∣ a^j * b^0 * c^1 iff i ≤ j ∧ 1 ≤ 0 ∧ 0 ≤ 1. The second condition 1 ≤ 0 is false. So a^i * b ∤ a^j * c.

Similarly, a^j * c = a^j * b^0 * c^1 and a^i * b = a^i * b^1 * c^0. By powTriple_dvd_iff, a^j * c ∣ a^i * b iff j ≤ i ∧ 0 ≤ 1 ∧ 1 ≤ 0. The third condition 1 ≤ 0 is false. So a^j * c ∤ a^i * b.

Rewrite a^i * b as a^i * b^1 * c^0 and a^j * c as a^j * b^0 * c^1 using mul_one and one_mul, then apply powTriple_dvd_iff.
-/
lemma ab_ac_incomparable {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) (i j : ℕ) :
    ¬ (a ^ i * b ∣ a ^ j * c) ∧ ¬ (a ^ j * c ∣ a ^ i * b) := by
  constructor <;> intro h;
  · -- Since $a$ and $b$ are coprime, $b$ must divide $c$.
    have hb_div_c : b ∣ c := by
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ ( dvd_of_mul_left_dvd h );
      exact Nat.Coprime.pow_right _ ( hcop.1.symm );
    have := Nat.dvd_gcd ( dvd_refl b ) hb_div_c; simp_all +decide [ PairwiseCoprime3 ] ;
  · -- Since $c$ is coprime with $a$, it must divide $b$.
    have h_div_b : c ∣ b := by
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ ( dvd_of_mul_left_dvd h );
      exact Nat.Coprime.pow_right _ ( hcop.2.1.symm );
    have := Nat.dvd_gcd h_div_b ( dvd_refl c ) ; simp_all +decide [ PairwiseCoprime3 ] ;

/-
PROBLEM
A pair {a^i · b, a^j · c} always forms an antichain (for pairwise coprime a,b,c > 1).

PROVIDED SOLUTION
Unfold IsDivisionAntichain. For x, y ∈ {a^i * b, a^j * c} with x ≠ y, show ¬(x ∣ y).

Case split on membership. If x = a^i * b and y = a^j * c: by ab_ac_incomparable, ¬(a^i*b ∣ a^j*c). If x = a^j * c and y = a^i * b: by ab_ac_incomparable, ¬(a^j*c ∣ a^i*b). The cases x = y are excluded by hne and the Finset structure.

Use ab_ac_incomparable ha hb hc hcop i j to get both directions.
-/
lemma pair_ab_ac_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) (i j : ℕ) (hne : a ^ i * b ≠ a ^ j * c) :
    IsDivisionAntichain ({a ^ i * b, a ^ j * c} : Finset ℕ) := by
  intro x hx y hy hxy;
  contrapose! hxy; have := ab_ac_incomparable ha hb hc hcop i j; aesop;

-- ============================================================
-- KEY LEMMA: Subset sum completeness of smooth numbers
-- ============================================================

/-- The sorted smooth numbers form a complete sequence: every positive integer
    can be written as a sum of distinct elements from PowTripleSet when min(a,b,c) = 2.
    More generally, for any a, b, c pairwise coprime > 1, every sufficiently large
    integer is a sum of distinct smooth numbers. -/
lemma smooth_subset_sum_complete {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) :
    ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
      (↑s : Set ℕ) ⊆ PowTripleSet a b c ∧ s.sum id = n := by
  sorry

/-- Given a representation of n as a sum of distinct smooth numbers, we can
    always find a representation that additionally forms a divisibility antichain.
    This is the "antichain conversion" lemma. -/
-- Note: This lemma's hypotheses (s, hs_sub, hs_sum) merely witness that n
-- is representable as a sum of smooth numbers. The antichain t is constructed
-- independently. The core difficulty is the same as the main d-completeness result.
lemma subset_sum_to_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {n : ℕ} (s : Finset ℕ) (hs_sub : (↑s : Set ℕ) ⊆ PowTripleSet a b c)
    (hs_sum : s.sum id = n) :
    ∃ t : Finset ℕ, (↑t : Set ℕ) ⊆ PowTripleSet a b c ∧
      IsDivisionAntichain t ∧ t.sum id = n := by
  sorry

/-
PROBLEM
============================================================
MAIN THEOREM
============================================================

A workspace-local Lean 4 stub for Erdos Problem 123. The formal-conjectures repo
contains a current statement very close to this one together with solved variants.

PROVIDED SOLUTION
Combine smooth_subset_sum_complete and subset_sum_to_antichain.

Use Filter.Eventually.mono on smooth_subset_sum_complete. For each n, the smooth_subset_sum_complete gives a Finset s with s ⊆ PowTripleSet and s.sum id = n. Then subset_sum_to_antichain converts this to an antichain representation t with t ⊆ PowTripleSet, IsDivisionAntichain t, and t.sum id = n.
-/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  intro a b c;
  intro ha hb hc;
  -- Let's choose any $n$ greater than some threshold $N$.
  intro hcop
  obtain ⟨N, hN⟩ : ∃ N, ∀ n ≥ N, ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowTripleSet a b c ∧ s.sum id = n := by
    exact Filter.eventually_atTop.mp ( smooth_subset_sum_complete ha hb hc hcop );
  exact Filter.eventually_atTop.mpr ⟨ N, fun n hn => by obtain ⟨ s, hs₁, hs₂ ⟩ := hN n hn; exact subset_sum_to_antichain ha hb hc hcop s hs₁ hs₂ ⟩

end Erdos123