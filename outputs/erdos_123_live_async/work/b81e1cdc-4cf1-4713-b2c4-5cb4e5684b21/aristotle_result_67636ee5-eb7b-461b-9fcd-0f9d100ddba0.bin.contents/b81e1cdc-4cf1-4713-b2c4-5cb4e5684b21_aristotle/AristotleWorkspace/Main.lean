import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-!
## Analysis and Results

### Reusable Invariant: Antichain Refinement Monotonicity Principle

The recurring signal 'unknown' in the invariant target is explained by the following
**monotonicity principle** (proved below as `IsDComplete_mono`):

> **Antichain Refinement Monotonicity**: If `A ⊆ B` and `A` is d-complete, then `B`
> is d-complete.

This reduces the d-completeness problem to showing it for the smallest natural
generating subset. The critical structural invariant for `PowTripleSet a b c` is that
the divisibility order restricted to exponent triples `(i, j, k) ∈ ℕ³` is
**isomorphic to the product order** on `ℕ³` (proved below as
`coprime_pow_triple_incomparable`). Pairwise coprimality ensures the set contains
arbitrarily large antichains — specifically, all elements on a "diagonal"
`{a^i * b^j * c^k : i + j + k = N}` are pairwise incomparable (proved as
`diagonal_antichain`), giving antichains of size `Θ(N²)` on each diagonal.

This **monotone family of antichains** indexed by `N` is the core reusable invariant.
Its subset sums grow super-exponentially in richness, but proving they eventually cover
all integers remains an open problem.

### Boundary Cases for d-Completeness Failure

**Question**: Which d-completeness boundary cases fail because interval-style coverage
cannot be upgraded to a divisibility antichain, and what is the sharpest witness?

**Answer**: The boundary cases fail precisely when the generators share common prime
factors, collapsing the 3-dimensional exponent lattice `ℕ³` to a lower-dimensional
structure where large antichains cannot exist.

**Sharpest witness**: `(a, b, c) = (2, 4, 8)` — equivalently `(p, p², p³)` for any
prime `p > 1`.

- `PowTripleSet 2 4 8 = {2^(i + 2j + 3k) : i, j, k ∈ ℕ} = {2^n : n ∈ ℕ}`.
- **Interval-style coverage holds**: every positive integer has a binary
  representation as a sum of *distinct* powers of 2. So the set of subset-sums
  (ignoring the antichain constraint) covers all positive integers.
- **Antichain upgrade fails completely**: the divisibility order on `{2^n}` is a
  total order (chain), so every antichain is a singleton. Thus the only
  antichain-sums are individual powers of 2, which are exponentially sparse.

The fundamental mechanism is: **pairwise coprimality ensures the exponent lattice is
genuinely 3-dimensional** (product order on `ℕ³`), where Dilworth's theorem guarantees
arbitrarily large antichains. Without coprimality, the lattice collapses to a
1-dimensional chain, and d-completeness fails.

More precisely, the "boundary" in parameter space is:
- d-completeness holds (conjecturally) when `gcd(a,b) = gcd(a,c) = gcd(b,c) = 1`
  and all generators > 1, giving a full 3-dimensional antichain structure.
- d-completeness **provably fails** when two generators share a prime factor,
  reducing the effective dimension. The sharpest single witness `(2, 4, 8)` gives
  dimension 1 (a total chain).

### Status of the Main Theorem

The main theorem (`erdos_123_d_complete_sequences`) is **Erdős Problem 123**, an open
conjecture in additive combinatorics. The conjecture asserts d-completeness of the
multiplicative semigroup generated by three pairwise coprime integers > 1. Even the
two-generator case `{2^a · 3^b : a, b ∈ ℕ}` remains open. The structural
infrastructure (coprimality ↔ product order, diagonal antichains, monotonicity)
developed below provides the foundation for any future formal proof.
-/

-- ============================================================================
-- § Proved structural lemmas
-- ============================================================================

/-- Every element of PowTripleSet is positive when generators are > 1. -/
lemma PowTripleSet_pos {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    {n : ℕ} (hn : n ∈ PowTripleSet a b c) : 0 < n := by
  obtain ⟨i, j, k, rfl⟩ := hn; positivity

/-- 1 is in PowTripleSet (taking all exponents = 0). -/
lemma one_mem_PowTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c :=
  ⟨0, 0, 0, by norm_num⟩

/-- Any power product `a ^ i * b ^ j * c ^ k` is in PowTripleSet. -/
lemma pow_mem_PowTripleSet (a b c : ℕ) (i j k : ℕ) :
    a ^ i * b ^ j * c ^ k ∈ PowTripleSet a b c :=
  ⟨i, j, k, rfl⟩

/-- `a` is in `PowTripleSet a b c`. -/
lemma a_mem_PowTripleSet (a b c : ℕ) : a ∈ PowTripleSet a b c :=
  ⟨1, 0, 0, by norm_num⟩

/-- `b` is in `PowTripleSet a b c`. -/
lemma b_mem_PowTripleSet (a b c : ℕ) : b ∈ PowTripleSet a b c := by
  use 0, 1, 0; simp [pow_zero, pow_one]

/-- `c` is in `PowTripleSet a b c`. -/
lemma c_mem_PowTripleSet (a b c : ℕ) : c ∈ PowTripleSet a b c :=
  ⟨0, 0, 1, by norm_num⟩

/-- **Divisibility ↔ componentwise order**: For pairwise coprime generators, if one
power product divides another, then the exponent triple is componentwise ≤.
This is the key structural fact showing that divisibility on `PowTripleSet` is
isomorphic to the product order on `ℕ³`. -/
lemma coprime_pow_triple_incomparable {a b c : ℕ}
    (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hco : PairwiseCoprime3 a b c)
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ}
    (_hne : (i₁, j₁, k₁) ≠ (i₂, j₂, k₂))
    (h1 : a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂) :
    i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
  refine' ⟨Nat.le_of_not_lt fun hi => _, Nat.le_of_not_lt fun hj => _,
           Nat.le_of_not_lt fun hk => _⟩
  · have h_coprime : ¬(a ^ (i₁ - i₂)) ∣ b ^ j₂ * c ^ k₂ := by
      have hcop : Nat.Coprime (a ^ (i₁ - i₂)) (b ^ j₂ * c ^ k₂) := by
        rw [Nat.coprime_mul_iff_right]
        exact ⟨Nat.Coprime.pow _ _ hco.1, Nat.Coprime.pow _ _ hco.2.1⟩
      intro h
      have := Nat.dvd_gcd (dvd_refl _) h
      simp_all +decide [Nat.Coprime, Nat.Coprime.gcd_eq_one]
      exact absurd (this.resolve_left ha.ne') (Nat.sub_ne_zero_of_lt hi)
    refine' h_coprime (Nat.dvd_of_mul_dvd_mul_left (pow_pos (zero_lt_one.trans ha) i₂) _)
    simp_all +decide [mul_assoc, ← pow_add, hi.le]
    exact dvd_of_mul_right_dvd h1
  · have h_contra : b ^ j₁ ∣ b ^ j₂ := by
      have h_contra : b ^ j₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ :=
        dvd_trans (dvd_mul_of_dvd_left (dvd_mul_left _ _) _) h1
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ (Nat.Coprime.dvd_of_dvd_mul_right _ h_contra)
      · exact Nat.Coprime.pow _ _ hco.1.symm
      · exact Nat.Coprime.pow _ _ hco.2.2
    exact Nat.not_dvd_of_pos_of_lt (pow_pos (zero_lt_one.trans hb) _)
      (pow_lt_pow_right₀ hb hj) h_contra
  · have h_div : a ^ i₁ * b ^ j₁ * c ^ (k₁ - k₂) ∣ a ^ i₂ * b ^ j₂ := by
      refine' Nat.dvd_of_mul_dvd_mul_right (pow_pos (zero_lt_one.trans hc) k₂) _
      rwa [mul_assoc, ← pow_add, Nat.sub_add_cancel hk.le]
    have h_div_c : c ^ (k₁ - k₂) ∣ a ^ i₂ * b ^ j₂ :=
      dvd_of_mul_left_dvd h_div
    have h_div_one : c ^ (k₁ - k₂) ∣ 1 := by
      convert Nat.dvd_gcd (dvd_refl _) h_div_c using 1
      refine' Eq.symm (Nat.Coprime.pow_left _ _)
      exact Nat.Coprime.mul_right (hco.2.1.symm.pow_right _) (hco.2.2.symm.pow_right _)
    exact absurd h_div_one
      (Nat.not_dvd_of_pos_of_lt (by norm_num) (one_lt_pow₀ hc (Nat.sub_ne_zero_of_lt hk)))

/-- **Diagonal antichain lemma**: Elements on the same diagonal `i + j + k = N`
with distinct exponent triples are pairwise incomparable in divisibility.
This follows immediately from `coprime_pow_triple_incomparable` and the fact
that componentwise ≤ with equal sum forces equality. -/
lemma diagonal_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hco : PairwiseCoprime3 a b c) {N : ℕ}
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ}
    (hN1 : i₁ + j₁ + k₁ = N) (hN2 : i₂ + j₂ + k₂ = N)
    (hne : (i₁, j₁, k₁) ≠ (i₂, j₂, k₂)) :
    ¬ (a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂) := by
  intro hdiv
  have := coprime_pow_triple_incomparable ha hb hc hco hne hdiv
  -- i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ with i₁+j₁+k₁ = i₂+j₂+k₂ forces equality
  grind

/-- **d-completeness monotonicity**: If `A ⊆ B` and `A` is d-complete, then `B`
is d-complete. Any antichain witness for `A` is also a witness for `B`. -/
lemma IsDComplete_mono {A B : Set ℕ} (hAB : A ⊆ B) (hA : IsDComplete A) :
    IsDComplete B :=
  hA.mono fun _n ⟨s, hs₁, hs₂, hs₃⟩ => ⟨s, hs₁.trans hAB, hs₂, hs₃⟩

