/-- 1 belongs to PowTripleSet a b c. -/
lemma one_mem_PowTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c := by
  exact ⟨ 0, 0, 0, by norm_num ⟩

/-- Every element of PowTripleSet is positive when a, b, c > 0. -/
lemma PowTripleSet_pos {a b c n : ℕ} (ha : 0 < a) (hb : 0 < b) (hc : 0 < c)
    (hn : n ∈ PowTripleSet a b c) : 0 < n := by
  obtain ⟨ i, j, k, rfl ⟩ := hn; positivity;

/-- a ∈ PowTripleSet a b c. -/
lemma a_mem_PowTripleSet (a b c : ℕ) : a ∈ PowTripleSet a b c := by
  exact ⟨ 1, 0, 0, by norm_num ⟩

/-- b ∈ PowTripleSet a b c. -/
lemma b_mem_PowTripleSet (a b c : ℕ) : b ∈ PowTripleSet a b c := by
  exact ⟨ 0, 1, 0, by simp +decide ⟩

/-- c ∈ PowTripleSet a b c. -/
lemma c_mem_PowTripleSet (a b c : ℕ) : c ∈ PowTripleSet a b c := by
  exact ⟨ 0, 0, 1, by simp +decide ⟩

/-- PowTripleSet is closed under multiplication. -/
lemma PowTripleSet_mul_closed {a b c m n : ℕ}
    (hm : m ∈ PowTripleSet a b c) (hn : n ∈ PowTripleSet a b c) :
    m * n ∈ PowTripleSet a b c := by
  rcases hm with ⟨ i, j, k, rfl ⟩ ; rcases hn with ⟨ i', j', k', rfl ⟩ ;
  exact ⟨ i + i', j + j', k + k', by ring ⟩ ;

/-- Two elements a^i * b^j * c^k and a^i' * b^j' * c^k' with pairwise coprime a,b,c:
    the first divides the second iff i ≤ i' ∧ j ≤ j' ∧ k ≤ k'. -/
lemma PowTripleSet_dvd_iff {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (hbc : Nat.Coprime b c)
    {i j k i' j' k' : ℕ} :
    a ^ i * b ^ j * c ^ k ∣ a ^ i' * b ^ j' * c ^ k' ↔
    i ≤ i' ∧ j ≤ j' ∧ k ≤ k' := by
  constructor <;> intro H
  · have ha_div : a ^ i ∣ a ^ i' := by
      exact Nat.Coprime.dvd_of_dvd_mul_right
        (by apply_rules [Nat.Coprime.pow, Nat.Coprime.symm])
        (Nat.Coprime.dvd_of_dvd_mul_right
          (by apply_rules [Nat.Coprime.pow, Nat.Coprime.symm])
          (dvd_of_mul_right_dvd (dvd_of_mul_right_dvd H)))
    have hb_div : b ^ j ∣ b ^ j' := by
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ _
      exact a ^ i' * c ^ k'
      · rw [Nat.coprime_mul_iff_right]
        exact ⟨Nat.Coprime.pow _ _ <| hab.symm, Nat.Coprime.pow _ _ <| hbc⟩
      · obtain ⟨m, hm⟩ := H
        exact ⟨m * a ^ i * c ^ k, by linarith⟩
    have hc_div : c ^ k ∣ c ^ k' := by
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ _
      exact a ^ i' * b ^ j'
      · rw [Nat.coprime_mul_iff_right]
        exact ⟨Nat.Coprime.pow _ _ <| Nat.Coprime.symm <| by aesop,
               Nat.Coprime.pow _ _ <| Nat.Coprime.symm <| by aesop⟩
      · exact dvd_trans (dvd_mul_left _ _) H
    exact ⟨Nat.le_of_not_lt fun hi =>
             Nat.not_dvd_of_pos_of_lt (pow_pos (zero_lt_one.trans ha) _)
               (pow_lt_pow_right₀ ha hi) ha_div,
           Nat.le_of_not_lt fun hj =>
             Nat.not_dvd_of_pos_of_lt (pow_pos (zero_lt_one.trans hb) _)
               (pow_lt_pow_right₀ hb hj) hb_div,
           Nat.le_of_not_lt fun hk =>
             Nat.not_dvd_of_pos_of_lt (pow_pos (zero_lt_one.trans hc) _)
               (pow_lt_pow_right₀ hc hk) hc_div⟩
  · exact mul_dvd_mul (mul_dvd_mul (pow_dvd_pow _ H.1) (pow_dvd_pow _ H.2.1))
      (pow_dvd_pow _ H.2.2)

/-- The set of elements of PowTripleSet up to n is finite. -/
lemma PowTripleSet_finite_le (a b c n : ℕ) :
    Set.Finite {m ∈ PowTripleSet a b c | m ≤ n} := by
  exact Set.finite_iff_bddAbove.mpr ⟨n, fun m hm => hm.2⟩

/-- For coprime a, b > 1, the Frobenius number is a*b - a - b.
    Every integer ≥ (a-1)*(b-1) can be represented as x*a + y*b. -/
lemma frobenius_two_coprime {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hab : Nat.Coprime a b) (n : ℕ) (hn : n ≥ (a - 1) * (b - 1)) :
    ∃ x y : ℕ, n = x * a + y * b := by
  obtain ⟨x, y, hxy⟩ : ∃ x y : ℤ, a * x + b * y = n ∧ 0 ≤ x ∧ x < b := by
    have h_bezout : ∃ x y : ℤ, a * x + b * y = n := by
      exact ⟨Nat.gcdA a b * n, Nat.gcdB a b * n, by nlinarith [Nat.gcd_eq_gcd_ab a b]⟩
    obtain ⟨x, y, hxy⟩ := h_bezout
    exact ⟨x % b, y + (x / b) * a, by nlinarith [Int.emod_add_mul_ediv x b],
           Int.emod_nonneg _ (by positivity), Int.emod_lt_of_pos _ (by positivity)⟩
  exact ⟨Int.toNat x, Int.toNat y,
    by nlinarith only [Int.toNat_of_nonneg hxy.2.1,
       Int.toNat_of_nonneg
         (by nlinarith [Nat.sub_add_cancel ha.le, Nat.sub_add_cancel hb.le] : (0 : ℤ) ≤ y),
       hxy.1]⟩

/-
PROBLEM
============================================================
Key structural lemma: cross-family incomparability
Elements a^i * c^k (with i ≥ 1, j = 0) are always
incomparable with b^j * c^l (with j ≥ 1, i = 0).
============================================================

Elements with positive a-exponent and zero b-exponent are incomparable
    with elements with zero a-exponent and positive b-exponent.

PROVIDED SOLUTION
By PowTripleSet_dvd_iff, a^i * b^0 * c^k | a^0 * b^j * c^l iff i ≤ 0 ∧ 0 ≤ j ∧ k ≤ l. Since i ≥ 1, i ≤ 0 is false. So the divisibility is impossible. Rewrite using PowTripleSet_dvd_iff and derive the contradiction from hi and the first conjunct.
-/
lemma cross_family_incomparable {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (hbc : Nat.Coprime b c)
    {i k j l : ℕ} (hi : 1 ≤ i) (hj : 1 ≤ j) :
    ¬ (a ^ i * b ^ 0 * c ^ k ∣ a ^ 0 * b ^ j * c ^ l) := by
  intro h;
  -- Apply the lemma that states the divisibility condition for elements in the set.
  have := @PowTripleSet_dvd_iff a b c ha hb hc hab hac hbc i 0 k 0 j l; simp_all +decide

/-
PROBLEM
Singleton division antichain.

PROVIDED SOLUTION
A singleton set trivially satisfies the antichain condition because x ∈ {m} and y ∈ {m} with x ≠ y is impossible.
-/
lemma singleton_antichain (m : ℕ) : IsDivisionAntichain {m} := by
  exact fun x y hx hy hxy => by aesop;

/-
PROBLEM
Two-element antichain from incomparable elements.

PROVIDED SOLUTION
For a two-element set {m₁, m₂}, the antichain condition requires checking all four pairs (x,y) with x ≠ y. By Finset.mem_insert, membership in {m₁, m₂} means x = m₁ or x = m₂. Check all cases: (m₁,m₂) → ¬m₁∣m₂ by h₁, (m₂,m₁) → ¬m₂∣m₁ by h₂, and (m₁,m₁) or (m₂,m₂) are excluded by x ≠ y.
-/
lemma pair_antichain {m₁ m₂ : ℕ} (hne : m₁ ≠ m₂)
    (h₁ : ¬ m₁ ∣ m₂) (h₂ : ¬ m₂ ∣ m₁) : IsDivisionAntichain {m₁, m₂} := by
  intro x y hx hy hxy; aesop;

