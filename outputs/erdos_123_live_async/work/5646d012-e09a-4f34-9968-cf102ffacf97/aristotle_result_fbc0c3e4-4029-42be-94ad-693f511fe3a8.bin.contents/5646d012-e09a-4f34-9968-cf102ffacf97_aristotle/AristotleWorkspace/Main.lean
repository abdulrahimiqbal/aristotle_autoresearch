    iέΓΒ έΚν iέΓΓ έΙπ jέΓΒ έΚν jέΓΓ έΙπ kέΓΒ έΚν kέΓΓ := by
  apply And.intro (by
  have h_div_a : a ^ iέΓΒ έΙμ a ^ iέΓΓ := by
    have := dvd_of_mul_right_dvd ( dvd_of_mul_right_dvd hdvd );
    refine' Nat.Coprime.dvd_of_dvd_mul_right _ ( Nat.Coprime.dvd_of_dvd_mul_right _ this );
    ┬╖ exact Nat.Coprime.pow _ _ hcop.1;
    ┬╖ exact Nat.Coprime.pow _ _ ( hcop.2.1 );
  exact Nat.le_of_not_lt fun hi => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans ha ) _ ) ( pow_lt_pow_rightέΓΑ ha hi ) h_div_a) (And.intro (by
  -- Since $a$, $b$, and $c$ are pairwise coprime, $b^jέΓΒ$ must divide $b^jέΓΓ$.
  have hb_div : b ^ jέΓΒ έΙμ b ^ jέΓΓ := by
    have hb_div : b ^ jέΓΒ έΙμ a ^ iέΓΓ * b ^ jέΓΓ * c ^ kέΓΓ := by
      exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_left _ _ ) _ ) hdvd;
    have hb_coprime : Nat.Coprime (b ^ jέΓΒ) (a ^ iέΓΓ * c ^ kέΓΓ) := by
      rw [ Nat.coprime_mul_iff_right ];
      exact έθρ Nat.Coprime.pow _ _ <| hcop.1.symm, Nat.Coprime.pow _ _ <| hcop.2.2 έθσ;
    exact hb_coprime.dvd_of_dvd_mul_left <| by convert hb_div using 1; ring;
  exact Nat.le_of_not_lt fun h => not_le_of_gt ( pow_lt_pow_rightέΓΑ hb h ) ( Nat.le_of_dvd ( pow_pos ( zero_lt_one.trans hb ) _ ) hb_div )) (by
  have hk : c ^ kέΓΒ έΙμ c ^ kέΓΓ := by
    refine' Nat.Coprime.dvd_of_dvd_mul_left _ _;
    exact a ^ iέΓΓ * b ^ jέΓΓ;
    ┬╖ exact Nat.Coprime.mul_right ( Nat.Coprime.pow _ _ <| hcop.2.1.symm ) ( Nat.Coprime.pow _ _ <| hcop.2.2.symm );
    ┬╖ exact dvd_trans ( dvd_mul_left _ _ ) hdvd;
