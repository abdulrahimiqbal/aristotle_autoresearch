/-! # Sylvester-Frobenius theorem -/

/-
PROBLEM
For coprime a, b έΚξ 2, every sufficiently large n is representable as x┬╖a + y┬╖b.

PROVIDED SOLUTION
Use Bezout's identity (Nat.gcd_eq_gcd_ab) to get integer representations, reduce mod b to get 0 έΚν x < b, then show y έΚξ 0 for n έΚξ a*b. Apply Filter.eventually_atTop.mpr.
-/
lemma sylvester_frobenius {a b : έΕΧ} (ha : 1 < a) (hb : 1 < b) (hab : Nat.Coprime a b) :
    έΙΑά╢ι n : έΕΧ in atTop, έΙΔ x y : έΕΧ, n = x * a + y * b := by
  -- By Bezout's identity, since $a$ and $b$ are coprime, there exist integers $x$ and $y$ such that $ax + by = 1$.
  obtain έθρx, y, h_bezoutέθσ : έΙΔ x y : έΕν, a * x + b * y = 1 := by
    have := Nat.gcd_eq_gcd_ab a b; aesop;
  -- For any $n$, we can find integers $x$ and $y$ such that $n = ax + by$ by multiplying both sides of $ax + by = 1$ by $n$.
  have h_exists_int : έΙΑ n : έΕΧ, έΙΔ x y : έΕν, n = a * x + b * y έΙπ 0 έΚν x έΙπ x < b := by
    intro n
    obtain έθρx, y, hxyέθσ : έΙΔ x y : έΕν, n = a * x + b * y := by
      exact έθρ n * x, n * y, by linear_combination' n * h_bezout.symm έθσ;
    exact έθρ x % b, y + x / b * a, by nth_rw 1 [ hxy ] ; nlinarith [ Int.emod_add_mul_ediv x b ], Int.emod_nonneg _ ( by positivity ), Int.emod_lt_of_pos _ ( by positivity ) έθσ;
  norm_num +zetaDelta at *;
  exact έθρ a * b, fun n hn => by obtain έθρ x, έθρ y, hy έθσ, hxέΓΒ, hxέΓΓ έθσ := h_exists_int n; exact έθρ Int.toNat x, Int.toNat y, by nlinarith [ Int.toNat_of_nonneg hxέΓΒ, Int.toNat_of_nonneg ( by nlinarith : ( 0 : έΕν ) έΚν y ) ] έθσ έθσ

/-! # Monotonicity -/

/-- D-completeness is monotone under set inclusion. -/
lemma IsDComplete.mono {A B : Set έΕΧ} (hAB : A έΛΗ B) (hA : IsDComplete A) :
    IsDComplete B := by
  unfold IsDComplete at *
  exact hA.mono fun n έθρs, hsέΓΒ, hsέΓΓ, hsέΓΔέθσ => έθρs, hsέΓΒ.trans hAB, hsέΓΓ, hsέΓΔέθσ

/-! # Anti-diagonal antichain construction -/

/-
PROBLEM
Anti-diagonal elements form a divisibility antichain.

PROVIDED SOLUTION
Take two elements a^i * b^(K-i) and a^j * b^(K-j) with i έΚι j from the image. If the first divides the second, use coprimality to extract a^i | a^j and b^(K-i) | b^(K-j). The first gives i έΚν j, the second gives K-i έΚν K-j (i.e., j έΚν i). Combined: i = j, contradiction.
-/
lemma antidiag_antichain {a b : έΕΧ} (ha : 1 < a) (hb : 1 < b)
    (hab : Nat.Coprime a b) (K : έΕΧ) :
    IsDivisionAntichain ((Finset.range (K + 1)).image (fun i => a ^ i * b ^ (K - i))) := by
  intro x hx y hy hxy hdiv;
  obtain έθρ i, hi, rfl έθσ := Finset.mem_image.mp y ; obtain έθρ j, hj, rfl έθσ := Finset.mem_image.mp hy ; simp_all +decide [ Nat.pow_succ', mul_assoc, Nat.mul_dvd_mul_iff_left ];
  -- Since $a$ and $b$ are coprime, $a^i \mid a^j$ implies $i \leq j$ and $b^{K-i} \mid b^{K-j}$ implies $K-i \leq K-j$.
  have h_exp_div : i έΚν j έΙπ K - i έΚν K - j := by
    have h_exp_div : a ^ i έΙμ a ^ j έΙπ b ^ (K - i) έΙμ b ^ (K - j) := by
      refine' έθρ Nat.Coprime.dvd_of_dvd_mul_right _ _, Nat.Coprime.dvd_of_dvd_mul_left _ _ έθσ;
      exact b ^ ( K - j );
      exact hab.pow _ _;
      exact dvd_of_mul_right_dvd hdiv;
      exact a ^ j;
      ┬╖ exact hab.symm.pow _ _;
      ┬╖ exact dvd_of_mul_left_dvd hdiv;
    exact έθρ Nat.le_of_not_lt fun hi' => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans ha ) _ ) ( pow_lt_pow_rightέΓΑ ha hi' ) h_exp_div.1, Nat.le_of_not_lt fun hj' => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hb ) _ ) ( pow_lt_pow_rightέΓΑ hb hj' ) h_exp_div.2 έθσ;
  exact hxy ( by congr <;> omega )

