/-! # Definitions -/

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : έΕΧ) : Set έΕΧ :=
  {n | έΙΔ i j k : έΕΧ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : έΕΧ) : Prop :=
  Nat.Coprime a b έΙπ Nat.Coprime a c έΙπ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset έΕΧ) : Prop :=
  έΙΑ έοΔx y : έΕΧέοΕ, x έΙΙ s έΗΤ y έΙΙ s έΗΤ x έΚι y έΗΤ ┬υ x έΙμ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set έΕΧ) : Prop :=
  έΙΑά╢ι n : έΕΧ in atTop, έΙΔ s : Finset έΕΧ,
    (έΗΣs : Set έΕΧ) έΛΗ A έΙπ IsDivisionAntichain s έΙπ s.sum id = n

