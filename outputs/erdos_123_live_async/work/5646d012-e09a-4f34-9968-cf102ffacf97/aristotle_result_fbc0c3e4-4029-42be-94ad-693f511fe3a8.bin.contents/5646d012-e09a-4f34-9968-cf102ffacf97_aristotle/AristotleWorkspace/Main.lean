/-- Reverse direction: componentwise έΚν implies divisibility. -/
lemma exp_le_implies_div {a b c : έΕΧ}
    {iέΓΒ jέΓΒ kέΓΒ iέΓΓ jέΓΓ kέΓΓ : έΕΧ}
    (hi : iέΓΒ έΚν iέΓΓ) (hj : jέΓΒ έΚν jέΓΓ) (hk : kέΓΒ έΚν kέΓΓ) :
    a ^ iέΓΒ * b ^ jέΓΒ * c ^ kέΓΒ έΙμ a ^ iέΓΓ * b ^ jέΓΓ * c ^ kέΓΓ :=
  mul_dvd_mul (mul_dvd_mul (pow_dvd_pow _ hi) (pow_dvd_pow _ hj)) (pow_dvd_pow _ hk)

/-! # Antichain lemmas -/

/-- A singleton is always a valid antichain representation. -/
lemma singleton_antichain {a b c n : έΕΧ} (hn : n έΙΙ PowTripleSet a b c) :
    έΙΔ s : Finset έΕΧ, (έΗΣs : Set έΕΧ) έΛΗ PowTripleSet a b c έΙπ
      IsDivisionAntichain s έΙπ s.sum id = n := by
  use {n}; unfold IsDivisionAntichain; aesop

/-
PROBLEM
Coprime elements > 1 form a two-element divisibility antichain.

PROVIDED SOLUTION
Unfold IsDivisionAntichain. Take elements from {x, y}. Casework: if one divides the other, use Nat.Coprime to show the divisor must be 1, contradicting > 1.
-/
lemma coprime_pair_antichain {x y : έΕΧ} (hxy : x έΚι y)
    (hcop : Nat.Coprime x y) (hx : 1 < x) (hy : 1 < y) :
    IsDivisionAntichain {x, y} := by
  intro a b ha hb hab; cases Finset.mem_insert.mp ha <;> cases Finset.mem_insert.mp hb <;> simp_all +decide [ Nat.Coprime ] ;
  ┬╖ exact fun h => by have := Nat.gcd_eq_left h; aesop;
  ┬╖ exact fun h => by have := Nat.gcd_eq_right h; aesop;

/-! # Transfer lemmas -/

/-- Powers of coprime bases are coprime. -/
lemma coprime_pow_of_coprime {a b : έΕΧ} (hab : Nat.Coprime a b) (i j : έΕΧ) :
    Nat.Coprime (a ^ i) (b ^ j) :=
  hab.pow _ _

/-
PROBLEM
Pure powers from coprime bases can't divide each other.

PROVIDED SOLUTION
If a^i | b^j, since gcd(a^i, b^j) = 1 (from hab.pow i j), we get a^i | 1, so a^i = 1. But a > 1 and i > 0 gives a^i > 1, contradiction.
-/
lemma pure_powers_not_dvd {a b : έΕΧ} (ha : 1 < a) (_hb : 1 < b)
    (hab : Nat.Coprime a b) {i j : έΕΧ} (hi : 0 < i) (_hj : 0 < j) :
    ┬υ a ^ i έΙμ b ^ j := by
  by_contra hdiv
  have h_coprime : Nat.Coprime (a ^ i) (b ^ j) := by
    exact?
  have h_contradiction : a ^ i έΙμ 1 := by
    exact h_coprime.gcd_eq_one έΨ╕ Nat.dvd_gcd ( dvd_refl _ ) hdiv
  have h_absurd : a ^ i = 1 := by
    exact Nat.eq_one_of_dvd_one h_contradiction
  exact absurd h_absurd (by
  exact ne_of_gt ( one_lt_powέΓΑ ha hi.ne' ))

/-
