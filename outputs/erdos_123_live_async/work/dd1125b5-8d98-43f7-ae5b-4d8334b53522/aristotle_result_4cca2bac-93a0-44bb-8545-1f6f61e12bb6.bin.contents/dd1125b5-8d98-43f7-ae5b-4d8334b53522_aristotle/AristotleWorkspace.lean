import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- The multiplicative semigroup generated by `a` and `b` (2-generator version). -/
def PowPairSet (a b : ℕ) : Set ℕ :=
  {n | ∃ i j : ℕ, n = a ^ i * b ^ j}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-! ## Part 1: Basic structural properties -/

lemma one_mem_PowTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c :=
  ⟨0, 0, 0, by norm_num⟩

lemma pow_mem_PowTripleSet_left (a b c : ℕ) (i : ℕ) :
    a ^ i ∈ PowTripleSet a b c :=
  ⟨i, 0, 0, by norm_num⟩

lemma pow_mem_PowTripleSet_mid (a b c : ℕ) (j : ℕ) :
    b ^ j ∈ PowTripleSet a b c :=
  ⟨0, j, 0, by norm_num⟩

lemma pow_mem_PowTripleSet_right (a b c : ℕ) (k : ℕ) :
    c ^ k ∈ PowTripleSet a b c :=
  ⟨0, 0, k, by norm_num⟩

/-! ## Part 2: Divisibility characterization for coprime power products -/

/-- For pairwise coprime bases, divisibility of products is equivalent to
componentwise ≤ on the exponents. -/
lemma coprime_pow_dvd_iff {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) (i₁ j₁ k₁ i₂ j₂ k₂ : ℕ) :
    a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ ↔
    i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
  refine' ⟨ fun h => _, fun h => mul_dvd_mul ( mul_dvd_mul ( pow_dvd_pow _ h.left ) ( pow_dvd_pow _ h.right.left ) ) ( pow_dvd_pow _ h.right.right ) ⟩;
  have h_div_a : a ^ i₁ ∣ a ^ i₂ := by
    refine' Nat.Coprime.dvd_of_dvd_mul_right _ _;
    exact b ^ j₂ * c ^ k₂;
    · rw [ Nat.coprime_mul_iff_right ];
      exact ⟨ hcop.1.pow _ _, hcop.2.1.pow _ _ ⟩;
    · exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_right _ _ ) _ ) ( by convert h using 1; ring )
  have h_div_b : b ^ j₁ ∣ b ^ j₂ := by
    have h_div_b : b ^ j₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
      exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_left _ _ ) _ ) h;
    have h_coprime_b_a : Nat.Coprime (b ^ j₁) (a ^ i₂) := by
      exact Nat.Coprime.pow _ _ <| hcop.1.symm
    have h_coprime_b_c : Nat.Coprime (b ^ j₁) (c ^ k₂) := by
      exact Nat.Coprime.pow _ _ <| hcop.2.2;
    exact h_coprime_b_a.dvd_of_dvd_mul_left <| h_coprime_b_c.dvd_of_dvd_mul_right <| by simpa only [ mul_assoc ] using h_div_b;
  have h_div_c : c ^ k₁ ∣ c ^ k₂ := by
    obtain ⟨ k, hk ⟩ := h;
    have h_div_c : c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
      exact hk.symm ▸ dvd_mul_of_dvd_left ( dvd_mul_left _ _ ) _;
    refine' Nat.Coprime.dvd_of_dvd_mul_left _ h_div_c;
    rw [ Nat.coprime_mul_iff_right ];
    exact ⟨ Nat.Coprime.pow _ _ <| hcop.2.1.symm, Nat.Coprime.pow _ _ <| hcop.2.2.symm ⟩;
  exact ⟨ Nat.le_of_not_lt fun hi => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans ha ) _ ) ( pow_lt_pow_right₀ ha hi ) h_div_a, Nat.le_of_not_lt fun hj => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hb ) _ ) ( pow_lt_pow_right₀ hb hj ) h_div_b, Nat.le_of_not_lt fun hk => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hc ) _ ) ( pow_lt_pow_right₀ hc hk ) h_div_c ⟩

/-- Elements on the same total degree level form a division antichain. -/
lemma same_level_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ}
    (hL : i₁ + j₁ + k₁ = i₂ + j₂ + k₂)
    (hdvd : a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂) :
    i₁ = i₂ ∧ j₁ = j₂ ∧ k₁ = k₂ := by
  have hle := (coprime_pow_dvd_iff ha hb hc hcop i₁ j₁ k₁ i₂ j₂ k₂).mp hdvd
  exact ⟨by omega, by omega, by omega⟩

/-! ## Part 3: Monotonicity and reduction lemmas -/

/-- `PowPairSet a b` embeds into `PowTripleSet a b c` (take k = 0). -/
lemma PowPairSet_subset_PowTripleSet (a b c : ℕ) :
    PowPairSet a b ⊆ PowTripleSet a b c :=
  fun _ hx => by obtain ⟨i, j, rfl⟩ := hx; exact ⟨i, j, 0, by ring⟩

/-- d-completeness is monotone: if A ⊆ B and A is d-complete, then B is d-complete. -/
lemma IsDComplete_mono {A B : Set ℕ} (h : A ⊆ B) (hA : IsDComplete A) :
    IsDComplete B :=
  hA.mono fun _ hn => by rcases hn with ⟨s, hs₁, hs₂, hs₃⟩; exact ⟨s, hs₁.trans h, hs₂, hs₃⟩

/-! ## Part 4: Pair divisibility and staircase lemmas -/

/-- Two-generator divisibility characterization. -/
lemma coprime_pair_dvd_iff {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hcop : Nat.Coprime a b) (i₁ j₁ i₂ j₂ : ℕ) :
    a ^ i₁ * b ^ j₁ ∣ a ^ i₂ * b ^ j₂ ↔ i₁ ≤ i₂ ∧ j₁ ≤ j₂ := by
  constructor
  · contrapose!
    intro h₁ h₂
    have h_exp_a : i₁ ≤ i₂ := by
      have : a ^ i₁ ∣ a ^ i₂ :=
        Nat.Coprime.dvd_of_dvd_mul_right (hcop.pow _ _) (dvd_of_mul_right_dvd h₂)
      exact Nat.le_of_not_lt fun h => Nat.not_dvd_of_pos_of_lt (pow_pos (zero_lt_one.trans ha) _) (pow_lt_pow_right₀ ha h) this
    have h_exp_b : b ^ j₁ ∣ b ^ j₂ :=
      Nat.Coprime.dvd_of_dvd_mul_left (Nat.Coprime.pow _ _ hcop.symm) (dvd_of_mul_left_dvd h₂)
    exact Nat.not_dvd_of_pos_of_lt (pow_pos (zero_lt_one.trans hb) _) (pow_lt_pow_right₀ hb (h₁ h_exp_a)) h_exp_b
  · exact fun h => mul_dvd_mul (pow_dvd_pow _ h.1) (pow_dvd_pow _ h.2)

/-- A staircase selection (decreasing a-exponents, increasing b-exponents)
always forms a division antichain when bases are coprime. -/
lemma staircase_antichain {a b : ℕ} (ha : 1 < a) (hb : 1 < b) (hcop : Nat.Coprime a b)
    {m : ℕ} (is_ : Fin m → ℕ) (js : Fin m → ℕ)
    (hi_strict : StrictMono is_) (hj_strict : StrictAnti js) :
    IsDivisionAntichain (Finset.image (fun t => a ^ (is_ t) * b ^ (js t)) Finset.univ) := by
  intros x hx y hy hxy
  by_contra h_div
  obtain ⟨t₁, t₂, ht₁, ht₂, h_exp⟩ : ∃ t₁ t₂ : Fin m, t₁ ≠ t₂ ∧ is_ t₁ ≤ is_ t₂ ∧ js t₁ ≤ js t₂ := by
    simp +zetaDelta at *
    rcases y with ⟨t₁, rfl⟩; rcases hy with ⟨t₂, rfl⟩; use t₁, t₂
    have := coprime_pair_dvd_iff ha hb hcop (is_ t₁) (js t₁) (is_ t₂) (js t₂); aesop
  exact ht₁ (hi_strict.injective (le_antisymm ht₂ (Nat.le_of_not_lt fun h =>
    not_lt_of_ge h_exp <| hj_strict.lt_iff_gt.mpr <| hi_strict.lt_iff_lt.mp h)))

/-! ## Part 5: Representation lemmas and scaling -/

/-- Level-L elements belong to PowPairSet. -/
lemma level_set_in_PowPairSet {a b : ℕ} (L : ℕ) :
    ∀ i : ℕ, i ≤ L → a ^ i * b ^ (L - i) ∈ PowPairSet a b :=
  fun i _ => ⟨i, L - i, rfl⟩

/-- Level-L elements form a division antichain. -/
lemma level_set_antichain {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hcop : Nat.Coprime a b) (L : ℕ) :
    IsDivisionAntichain (Finset.image (fun i : Fin (L + 1) => a ^ i.val * b ^ (L - i.val)) Finset.univ) := by
  intro x y
  simp +zetaDelta at *
  rintro ⟨i, hi⟩ rfl ⟨j, hj⟩ rfl H
  have := coprime_pair_dvd_iff ha hb hcop i (L - i) j (L - j)
  exact fun h => H <| Nat.le_antisymm (this.mp h |>.1) (this.mp h |>.2 |> fun x => by omega) ▸ rfl

/-- Singleton antichain representations. -/
lemma singleton_rep {a b : ℕ} (i j : ℕ) :
    ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowPairSet a b ∧
      IsDivisionAntichain s ∧ s.sum id = a ^ i * b ^ j := by
  refine' ⟨{a ^ i * b ^ j}, _, _, _⟩ <;> norm_num [IsDivisionAntichain]
  exact ⟨i, j, rfl⟩

/-- Pair antichain representations: {a^i, b^j} for i, j ≥ 1. -/
lemma pair_rep {a b : ℕ} (ha : 1 < a) (hb : 1 < b) (hcop : Nat.Coprime a b)
    (i j : ℕ) (hi : 0 < i) (hj : 0 < j) :
    ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowPairSet a b ∧
      IsDivisionAntichain s ∧ s.sum id = a ^ i + b ^ j := by
  use {a ^ i, b ^ j}; simp
  rw [Finset.sum_pair]
  · refine' ⟨_, _, rfl⟩
    · rintro x (rfl | rfl) <;> [exact ⟨i, 0, by ring⟩; exact ⟨0, j, by ring⟩]
    · have h_coprime : ¬(a ^ i ∣ b ^ j) ∧ ¬(b ^ j ∣ a ^ i) := by
        constructor <;> intro h <;> have := Nat.gcd_eq_left h <;> simp_all +decide [Nat.Coprime, Nat.Coprime.pow]
        · rw [eq_comm, pow_eq_one_iff] at this; aesop
        · exact absurd (Nat.dvd_gcd (dvd_refl (b ^ j)) h) (by rw [Nat.Coprime.gcd_eq_one (by exact Nat.Coprime.pow _ _ <| Nat.Coprime.symm hcop)]; aesop)
      intro x hx y hy hxy; aesop
  · intro h; have := Nat.Coprime.pow i j hcop; simp_all +decide [Nat.Coprime]; aesop

/-- Scaling by a: if n is representable, then a*n is representable. -/
lemma rep_scale_a {a b : ℕ} (ha : 1 < a) (_hb : 1 < b) (_hcop : Nat.Coprime a b)
    {n : ℕ} (s : Finset ℕ) (hs : (↑s : Set ℕ) ⊆ PowPairSet a b)
    (hac : IsDivisionAntichain s) (hsum : s.sum id = n) :
    ∃ s' : Finset ℕ, (↑s' : Set ℕ) ⊆ PowPairSet a b ∧
      IsDivisionAntichain s' ∧ s'.sum id = a * n := by
  refine ⟨s.image fun x => x * a, ?_, ?_, ?_⟩
  · intro x hx
    simp only [Finset.coe_image, Set.mem_image] at hx
    obtain ⟨y, hy, rfl⟩ := hx
    obtain ⟨i, j, rfl⟩ := hs hy
    exact ⟨i + 1, j, by ring⟩
  · intro x y hx hy hxy
    obtain ⟨x', hx', rfl⟩ := Finset.mem_image.mp hx
    obtain ⟨y', hy', rfl⟩ := Finset.mem_image.mp hy
    simp only [mul_dvd_mul_iff_right (by omega : (a : ℕ) ≠ 0)]
    exact hac hx' hy' (by intro h; apply hxy; rw [h])
  · rw [← hsum, mul_comm, Finset.sum_image]
    · simp [Finset.sum_mul]
    · exact fun x _ y _ hxy => mul_right_cancel₀ (by omega) hxy

/-- Scaling by b: if n is representable, then b*n is representable. -/
lemma rep_scale_b {a b : ℕ} (_ha : 1 < a) (hb : 1 < b) (_hcop : Nat.Coprime a b)
    {n : ℕ} (s : Finset ℕ) (hs : (↑s : Set ℕ) ⊆ PowPairSet a b)
    (hac : IsDivisionAntichain s) (hsum : s.sum id = n) :
    ∃ s' : Finset ℕ, (↑s' : Set ℕ) ⊆ PowPairSet a b ∧
      IsDivisionAntichain s' ∧ s'.sum id = b * n := by
  refine' ⟨s.image fun x => x * b, _, _, _⟩
  · simp_all +decide [Set.subset_def]
    intro x hx; obtain ⟨i, j, rfl⟩ := hs x hx; exact ⟨i, j + 1, by ring⟩
  · intro x y hx hy hxy
    obtain ⟨x, hx, rfl⟩ := Finset.mem_image.mp hx
    obtain ⟨y, hy, rfl⟩ := Finset.mem_image.mp hy
    simp_all +decide [mul_dvd_mul_iff_right (by positivity : b ≠ 0)]
    exact hac hx hy hxy.1
  · rw [← hsum, mul_comm, Finset.sum_image]
    · simp +decide [Finset.sum_mul _ _ _]
    · exact fun x _ y _ hxy => mul_right_cancel₀ (by linarith) hxy

/-! ## Part 6: Core d-completeness theorem -/

/-- For coprime a, b > 1, the 2-generator set {a^i * b^j} is d-complete.
This is the core of the Erdős-123 result. The proof requires showing that
staircase antichain sums eventually cover all integers, using the density of
level-set antichains and the scaling lemmas above. -/
theorem pair_d_complete {a b : ℕ} (ha : 1 < a) (hb : 1 < b) (hcop : Nat.Coprime a b) :
    IsDComplete (PowPairSet a b) := by
  sorry

/-! ## Part 7: Main theorem -/

/-- For pairwise coprime a, b, c > 1, the set PowTripleSet a b c is d-complete.
Follows from the 2-generator case by monotonicity. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  intro a b c ha hb hc hcop
  exact IsDComplete_mono (PowPairSet_subset_PowTripleSet a b c)
    (pair_d_complete ha hb hcop.1)

end Erdos123
