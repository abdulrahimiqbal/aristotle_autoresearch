import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-! ## Core definitions -/

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-! ## Membership lemmas -/

lemma one_mem_PowTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c :=
  ⟨0, 0, 0, by simp⟩

lemma pow_a_mem (a b c : ℕ) (i : ℕ) : a ^ i ∈ PowTripleSet a b c :=
  ⟨i, 0, 0, by simp⟩

lemma pow_b_mem (a b c : ℕ) (j : ℕ) : b ^ j ∈ PowTripleSet a b c :=
  ⟨0, j, 0, by simp⟩

lemma pow_c_mem (a b c : ℕ) (k : ℕ) : c ^ k ∈ PowTripleSet a b c :=
  ⟨0, 0, k, by simp⟩

lemma mem_PowTripleSet (a b c : ℕ) (i j k : ℕ) :
    a ^ i * b ^ j * c ^ k ∈ PowTripleSet a b c :=
  ⟨i, j, k, rfl⟩

/-! ## Closure and positivity -/

lemma PowTripleSet_mul_closed (a b c : ℕ) :
    ∀ x y, x ∈ PowTripleSet a b c → y ∈ PowTripleSet a b c →
      x * y ∈ PowTripleSet a b c := by
  intros x y hx hy
  obtain ⟨i1, j1, k1, hx_eq⟩ := hx
  obtain ⟨i2, j2, k2, hy_eq⟩ := hy
  exact ⟨i1 + i2, j1 + j2, k1 + k2, by simp [hx_eq, hy_eq]; ring⟩

lemma PowTripleSet_pos {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    {n : ℕ} (hn : n ∈ PowTripleSet a b c) : 0 < n := by
  obtain ⟨i, j, k, rfl⟩ := hn; positivity

/-! ## Divisibility characterization

The key structural insight: for pairwise coprime generators, divisibility in the
triple-power semigroup is equivalent to componentwise ≤ on exponents. This reduces
the antichain condition from a number-theoretic property to a purely order-theoretic
one on ℕ³. -/

/-
PROVIDED SOLUTION
Forward: extract each exponent via coprimality. Backward: mul_dvd_mul and pow_dvd_pow.
-/
lemma dvd_iff_exponents_le {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    (i₁ j₁ k₁ i₂ j₂ k₂ : ℕ) :
    a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ ↔
      i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
  constructor <;> intro h;
  · -- Apply the lemma that states if a product of powers divides another product of powers, then each exponent must be less than or equal to the corresponding exponent in the divisor. Use this lemma for each prime factor.
    have h_exp_a : a ^ i₁ ∣ a ^ i₂ := by
      refine' Nat.Coprime.dvd_of_dvd_mul_right _ _;
      exact b ^ j₂ * c ^ k₂;
      · rw [ Nat.coprime_mul_iff_right ];
        exact ⟨ Nat.Coprime.pow _ _ hcop.1, Nat.Coprime.pow _ _ hcop.2.1 ⟩;
      · exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_right _ _ ) _ ) ( by simpa only [ mul_assoc ] using h )
    have h_exp_b : b ^ j₁ ∣ b ^ j₂ := by
      have h_exp_b : b ^ j₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
        exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_left _ _ ) _ ) h;
      have h_coprime_b : Nat.Coprime (b ^ j₁) (a ^ i₂ * c ^ k₂) := by
        apply_mod_cast Nat.Coprime.mul_right <;> apply_mod_cast Nat.Coprime.pow <;> simp_all +decide [ PairwiseCoprime3 ];
        · exact hcop.1.symm;
        · tauto;
      exact h_coprime_b.dvd_of_dvd_mul_left <| by convert h_exp_b using 1; ring;
    have h_exp_c : c ^ k₁ ∣ c ^ k₂ := by
      have h_exp_c : c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
        exact dvd_trans ( dvd_mul_left _ _ ) h;
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ h_exp_c;
      rw [ Nat.coprime_mul_iff_right ];
      exact ⟨ Nat.Coprime.pow _ _ <| hcop.2.1.symm, Nat.Coprime.pow _ _ <| hcop.2.2.symm ⟩;
    exact ⟨ Nat.le_of_not_lt fun hi => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans ha ) _ ) ( pow_lt_pow_right₀ ha hi ) h_exp_a, Nat.le_of_not_lt fun hj => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hb ) _ ) ( pow_lt_pow_right₀ hb hj ) h_exp_b, Nat.le_of_not_lt fun hk => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hc ) _ ) ( pow_lt_pow_right₀ hc hk ) h_exp_c ⟩;
  · exact mul_dvd_mul ( mul_dvd_mul ( pow_dvd_pow _ h.1 ) ( pow_dvd_pow _ h.2.1 ) ) ( pow_dvd_pow _ h.2.2 )

/-! ## Antichain characterization -/

lemma antichain_iff_exponents_incomparable {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    (i₁ j₁ k₁ i₂ j₂ k₂ : ℕ)
    (_hne : a ^ i₁ * b ^ j₁ * c ^ k₁ ≠ a ^ i₂ * b ^ j₂ * c ^ k₂) :
    ¬(a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂) ∧
    ¬(a ^ i₂ * b ^ j₂ * c ^ k₂ ∣ a ^ i₁ * b ^ j₁ * c ^ k₁) ↔
      ¬(i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂) ∧ ¬(i₂ ≤ i₁ ∧ j₂ ≤ j₁ ∧ k₂ ≤ k₁) := by
  constructor <;> intro H <;> simp_all +decide [dvd_iff_exponents_le]

/-! ## Monotonicity -/

lemma IsDComplete_mono {A B : Set ℕ} (h : A ⊆ B) (hA : IsDComplete A) : IsDComplete B := by
  exact hA.mono fun n => by rintro ⟨s, hsA, hs⟩; exact ⟨s, hsA.trans h, hs⟩

/-! ## Scaling lemmas -/

/-
PROBLEM
Multiplying every element by a preserves the antichain property.

PROVIDED SOLUTION
Unfold IsDivisionAntichain. Take x*a, y*a from s.image. If x*a | y*a then x | y (cancel a). This contradicts hs_anti since x,y ∈ s with x ≠ y.
-/
lemma antichain_scale_a {s : Finset ℕ} {a : ℕ} (ha : 1 < a)
    (hs_anti : IsDivisionAntichain s) :
    IsDivisionAntichain (s.image (· * a)) := by
  cases s using Finset.induction <;> simp_all +decide [ IsDivisionAntichain ];
  rintro x y ( rfl | ⟨ b, hb, rfl ⟩ ) ( rfl | ⟨ c, hc, rfl ⟩ ) hxy <;> simp_all +decide [ Nat.mul_dvd_mul_iff_right ( zero_lt_one.trans ha ) ]

lemma scale_mem_PowTripleSet {a b c n : ℕ} (hn : n ∈ PowTripleSet a b c) :
    n * a ∈ PowTripleSet a b c := by
  obtain ⟨i, j, k, rfl⟩ := hn; exact ⟨i + 1, j, k, by ring⟩

lemma scale_mem_PowTripleSet_b {a b c n : ℕ} (hn : n ∈ PowTripleSet a b c) :
    n * b ∈ PowTripleSet a b c := by
  obtain ⟨i, j, k, rfl⟩ := hn; exact ⟨i, j + 1, k, by ring⟩

lemma scale_mem_PowTripleSet_c {a b c n : ℕ} (hn : n ∈ PowTripleSet a b c) :
    n * c ∈ PowTripleSet a b c := by
  obtain ⟨i, j, k, rfl⟩ := hn; exact ⟨i, j, k + 1, by ring⟩

/-
PROBLEM
If a | n and n/a has an antichain representation, then n does too (scale by a).

PROVIDED SOLUTION
Construct s' = s.image (· * a). Membership: scale_mem_PowTripleSet. Antichain: antichain_scale_a. Sum: Finset.sum_image (injective by mul_right_cancel₀), then Finset.sum_mul and Nat.div_mul_cancel.
-/
lemma represent_div_a {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c) {n : ℕ} (hdvd : a ∣ n)
    (hrep : ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowTripleSet a b c ∧
      IsDivisionAntichain s ∧ s.sum id = n / a) :
    ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ PowTripleSet a b c ∧
      IsDivisionAntichain s ∧ s.sum id = n := by
  obtain ⟨s, hs_sub, hs_anti, hs_sum⟩ := hrep
  refine' ⟨ s.image fun x => x * a, _, _, _ ⟩ <;> simp_all +decide [ Finset.subset_iff ];
  · exact fun x hx => scale_mem_PowTripleSet ( hs_sub hx );
  · exact?;
  · rw [ Finset.sum_image ];
    · rw [ ← Finset.sum_mul _ _ _, hs_sum, Nat.div_mul_cancel hdvd ];
    · exact fun x hx y hy hxy => mul_right_cancel₀ ( by linarith ) hxy

/-! ## Key obstruction analysis

**Discovery**: The two-generator case `{a^i · b^j}` is NOT always d-complete.

*Example*: For `{8^i · 3^j}`, since `3^j mod 8 ∈ {1, 3}` and an antichain in ℕ²
uses at most one "row-0" element (since `b^j₁ | b^j₂` for `j₁ < j₂`), any antichain
sum is `≡ 0, 1, or 3 mod 8`. Hence integers `≡ 2 mod 8` are never representable,
and `{8^i · 3^j}` is NOT d-complete.

**Key insight for three generators**: With three generators, "row 0" (`i=0` plane)
contains `{b^j · c^k}`, and antichains in the `(j,k)`-plane can have multiple elements
(incomparable pairs like `(j₁,k₁)` and `(j₂,k₂)` with `j₁ > j₂` and `k₁ < k₂`).
Sums of such elements cover all residues modulo `a`, overcoming the modular obstruction.

*Example*: For `PowTripleSet(8, 3, 5)`, the elements `27 = 3³·5⁰` and `15 = 3¹·5¹`
are incomparable (exponents `(3,0)` vs `(1,1)`) and sum to `42 ≡ 2 mod 8`, recovering
the missing residue class.

**Which solved special cases transfer?** The `(2,3,5)` case is the prototypical solved
instance. Any triple `(p,q,r)` of distinct primes transfers since powers of primes
generate full residue groups. For composite generators, the three-generator formulation
provides enough flexibility through 2D antichains within each hyperplane. The key
mechanism is that antichains in ℕ³ are strictly richer than in ℕ² — they allow multiple
"row-0" elements, providing the combinatorial flexibility needed to cover all residue
classes and achieve d-completeness. -/

/-! ## Residue coverage: the deep number-theoretic ingredient

For coprime b, c > 1 and a coprime to both, we need: for every residue r mod a,
there exists an antichain (w.r.t. componentwise ≤ on (j,k)) of products b^j · c^k
whose sum ≡ r mod a. This uses the 2D antichain structure in the (j,k)-plane and
follows from additive combinatorics (Cauchy-Davenport / Kneser type arguments). -/

/-- For coprime b, c > 1 and a > 1 coprime to both, every residue class mod a contains
an antichain sum from {b^j · c^k}. This is the key number-theoretic ingredient that
makes three generators sufficient where two may fail. -/
lemma residue_coverage {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (_hbc : Nat.Coprime b c)
    (r : ℕ) (hr : r < a) :
    ∃ (s : Finset ℕ), (∀ x ∈ s, ∃ j k : ℕ, x = b ^ j * c ^ k ∧ (j > 0 ∨ k > 0)) ∧
      IsDivisionAntichain s ∧ s.sum id % a = r := by
  sorry

/-! ## Main theorem -/

/-- Erdős Problem 123 (reformulated): for pairwise coprime `a`, `b`, `c > 1`, the
triple-power semigroup `{a^i · b^j · c^k}` is d-complete.

**Proof infrastructure**: All structural lemmas (divisibility characterization,
antichain equivalence, scaling, monotonicity, represent_div_a) are fully proved.
The remaining gap is `residue_coverage` — a deep number-theoretic ingredient about
antichain sums covering all residue classes mod a. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

end Erdos123