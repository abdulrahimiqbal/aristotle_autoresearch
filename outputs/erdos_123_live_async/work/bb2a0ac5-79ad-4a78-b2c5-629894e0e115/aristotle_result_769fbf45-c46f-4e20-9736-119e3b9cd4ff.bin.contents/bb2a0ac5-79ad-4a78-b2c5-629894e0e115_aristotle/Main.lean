import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-
PROBLEM
============================================================
§ 1. Adversarial witness: (2, 2, 2) is NOT pairwise coprime
============================================================

The triple (2, 2, 2) fails the coprimality hypothesis.

PROVIDED SOLUTION
Unfold PairwiseCoprime3. Nat.Coprime 2 2 means gcd 2 2 = 1, but gcd 2 2 = 2 ≠ 1. So the first conjunct fails. Use decide or omega.
-/
theorem not_pairwiseCoprime_222 : ¬ PairwiseCoprime3 2 2 2 := by
  simp +decide [ PairwiseCoprime3 ]

/-
PROBLEM
============================================================
§ 2. PowTripleSet 2 2 2 consists exactly of powers of 2
============================================================

Every element of PowTripleSet 2 2 2 is a power of 2.

PROVIDED SOLUTION
For n ∈ PowTripleSet 2 2 2, we have n = 2^i * 2^j * 2^k = 2^(i+j+k). So n is a power of 2 with m = i+j+k.
-/
theorem powTripleSet_222_subset_powers_of_two :
    PowTripleSet 2 2 2 ⊆ {n | ∃ m : ℕ, n = 2 ^ m} := by
  rintro _ ⟨ i, j, k, rfl ⟩ ; exact ⟨ i + j + k, by ring ⟩

/-
PROBLEM
Every power of 2 belongs to PowTripleSet 2 2 2.

PROVIDED SOLUTION
For n = 2^m, set i = m, j = 0, k = 0. Then 2^m * 2^0 * 2^0 = 2^m * 1 * 1 = 2^m = n.
-/
theorem powers_of_two_subset_powTripleSet_222 :
    {n | ∃ m : ℕ, n = 2 ^ m} ⊆ PowTripleSet 2 2 2 := by
  exact fun n ↦ by rintro ⟨ m, rfl ⟩ ; exact ⟨ m, 0, 0, by ring ⟩ ;

/-
PROBLEM
============================================================
§ 3. Powers of 2 are totally ordered by divisibility
============================================================

Among distinct powers of 2, one always divides the other.

PROVIDED SOLUTION
Write a = 2^m, b = 2^n. If m ≤ n then 2^m | 2^n (a | b). Otherwise n < m so 2^n | 2^m (b | a). Use Nat.pow_dvd_pow and Nat.le_of_lt_succ or similar. The key lemma is pow_dvd_pow 2.
-/
theorem pow_two_dvd_of_ne {a b : ℕ} (ha : ∃ m, a = 2 ^ m)
    (hb : ∃ n, b = 2 ^ n) (hab : a ≠ b) : a ∣ b ∨ b ∣ a := by
  rcases ha with ⟨ m, rfl ⟩ ; rcases hb with ⟨ n, rfl ⟩ ; cases le_total m n <;> simp +decide [ ‹_›, pow_dvd_pow ]

/-
PROBLEM
============================================================
§ 4. Division antichains from powers of 2 are singletons or empty
============================================================

A division antichain drawn from powers of 2 has at most one element.

PROVIDED SOLUTION
By contradiction: if s.card ≥ 2 then there exist distinct x, y ∈ s. Since both are powers of 2 (by hs), by pow_two_dvd_of_ne, either x ∣ y or y ∣ x. But hac says neither can hold for distinct elements, contradiction. Use Finset.one_lt_card to get two distinct elements.
-/
theorem antichain_powers_of_two_card_le_one (s : Finset ℕ)
    (hs : (↑s : Set ℕ) ⊆ {n | ∃ m : ℕ, n = 2 ^ m})
    (hac : IsDivisionAntichain s) : s.card ≤ 1 := by
  contrapose! hac;
  obtain ⟨ x, hx, y, hy, hxy ⟩ := Finset.one_lt_card.mp hac;
  -- Since $x$ and $y$ are distinct powers of 2, one must divide the other.
  have h_div : x ∣ y ∨ y ∣ x := by
    obtain ⟨ m, rfl ⟩ := hs hx; obtain ⟨ n, rfl ⟩ := hs hy; cases le_total m n <;> [ left; right ] <;> norm_num [ pow_dvd_pow _ ‹_› ] ;
  exact fun H => by cases h_div <;> [ exact absurd ( H hx hy hxy ) ( by aesop ) ; exact absurd ( H hy hx hxy.symm ) ( by aesop ) ] ;

/-
PROBLEM
============================================================
§ 5. PowTripleSet 2 2 2 is NOT d-complete
============================================================

The sum of a division antichain from PowTripleSet 2 2 2 is either
    0 (empty set) or a single power of 2.

PROVIDED SOLUTION
By antichain_powers_of_two_card_le_one applied via powTripleSet_222_subset_powers_of_two, s.card ≤ 1. Case split: if s.card = 0 then s = ∅ so sum = 0 (Left). If s.card = 1 then s = {x} for some x, sum = x, and x ∈ PowTripleSet 2 2 2 ⊆ powers of 2 so ∃ m, x = 2^m (Right). Use Finset.card_eq_zero, Finset.card_eq_one.
-/
theorem antichain_sum_of_powTripleSet_222 (s : Finset ℕ)
    (hs : (↑s : Set ℕ) ⊆ PowTripleSet 2 2 2)
    (hac : IsDivisionAntichain s) :
    s.sum id = 0 ∨ ∃ m : ℕ, s.sum id = 2 ^ m := by
  -- Let's consider the two possible cases for the cardinality of $s$.
  by_cases h_card : s.card = 0 ∨ s.card = 1;
  · rcases h_card with ( h | h );
    · aesop;
    · rw [ Finset.card_eq_one ] at h;
      rcases h with ⟨ a, rfl ⟩ ; simp_all +decide;
      rcases hs with ⟨ i, j, k, rfl ⟩ ; exact Or.inr ⟨ i + j + k, by ring ⟩;
  · -- Since $s$ has more than one element, we can apply the result from the previous theorem to get a contradiction.
    have h_contra : s.card ≤ 1 := by
      apply antichain_powers_of_two_card_le_one;
      · exact fun x hx => by rcases hs hx with ⟨ i, j, k, rfl ⟩ ; exact ⟨ i + j + k, by ring ⟩ ;
      · assumption;
    omega

/-
PROBLEM
3 is not 0 and not a power of 2.

PROVIDED SOLUTION
By induction on m. 2^0 = 1 ≠ 3, 2^1 = 2 ≠ 3, and for m ≥ 2, 2^m ≥ 4 > 3. Use omega for base cases and monotonicity.
-/
theorem three_not_power_of_two : ∀ m : ℕ, 3 ≠ 2 ^ m := by
  intro m hm; linarith [ Nat.pow_le_pow_right ( show 1 ≤ 2 by norm_num ) ( show m ≥ 3 by contrapose! hm; interval_cases m <;> trivial ) ] ;

/-
PROBLEM
**Main adversarial result**: PowTripleSet 2 2 2 is NOT d-complete.
This demonstrates that the coprimality hypotheses in the Erdős-123
conjecture are essential and cannot be dropped.

PROVIDED SOLUTION
Unfold IsDComplete. We need to show ¬∀ᶠ n in atTop, ∃ s, ... . It suffices to show that 3 is not representable. By Filter.not_eventually (or showing the set of representable n is not cofinite), we can show there exist arbitrarily large non-representable numbers. Specifically, show 3 cannot be represented: by antichain_sum_of_powTripleSet_222, any antichain sum is 0 or 2^m, but 3 ≠ 0 and 3 ≠ 2^m (by three_not_power_of_two). More concretely: unfold the eventually-at-top to get ∃ N, ∀ n ≥ N, P n. Then apply to n = max N 3 ≥ N to get P (max N 3)... Actually simpler: apply to n = 3 if N ≤ 3, otherwise we need n ≥ N. Better: show ¬P 3 where P n = ∃ s, .... The eventually means ∃ N, ∀ n ≥ N, P n. But we need to show infinitely many n fail. Actually, a single failure below N is fine... no, we need ∀ n ≥ N, P n to fail.

Actually let me reconsider. We need to show that arbitrarily large n cannot be represented. Any odd number > 1 cannot be represented (since sums are 0 or a power of 2, and powers of 2 ≥ 2 are even, and 2^0 = 1). So no odd number ≥ 3 is representable. Since there are arbitrarily large odd numbers, we're done. Formally: given N, take n = 2*N + 3 ≥ N, show n is odd and ≥ 3, hence not 0 and not a power of 2 (since 2^0 = 1 < 3 and 2^m for m ≥ 1 is even).
-/
theorem not_d_complete_powTripleSet_222 :
    ¬ IsDComplete (PowTripleSet 2 2 2) := by
  unfold IsDComplete;
  simp;
  intro x;
  -- Let's choose any $n$ greater than $x$ that is not a power of 2.
  obtain ⟨n, hn₁, hn₂⟩ : ∃ n : ℕ, x < n ∧ ¬(n = 0) ∧ ¬(∃ m : ℕ, n = 2 ^ m) := by
    use 3 * 2 ^ x;
    refine' ⟨ _, _, _ ⟩;
    · induction' x with n ih <;> norm_num [ Nat.pow_succ' ] at * ; linarith [ Nat.one_le_pow n 2 zero_lt_two ];
    · positivity;
    · exact fun ⟨ m, hm ⟩ => by have := congr_arg ( ·.factorization 3 ) hm; norm_num at this;
  refine' ⟨ n, hn₁.le, fun s hs₁ hs₂ hs₃ ↦ _ ⟩;
  have := antichain_sum_of_powTripleSet_222 s hs₁ hs₂; aesop;

/-
PROBLEM
============================================================
§ 6. Special cases that DO satisfy coprimality
============================================================

The triple (2, 3, 5) is pairwise coprime.

PROVIDED SOLUTION
Unfold PairwiseCoprime3 and Nat.Coprime. gcd(2,3)=1, gcd(2,5)=1, gcd(3,5)=1. Use decide or native_decide.
-/
theorem pairwiseCoprime_2_3_5 : PairwiseCoprime3 2 3 5 := by
  exact ⟨ by decide, by decide, by decide ⟩

