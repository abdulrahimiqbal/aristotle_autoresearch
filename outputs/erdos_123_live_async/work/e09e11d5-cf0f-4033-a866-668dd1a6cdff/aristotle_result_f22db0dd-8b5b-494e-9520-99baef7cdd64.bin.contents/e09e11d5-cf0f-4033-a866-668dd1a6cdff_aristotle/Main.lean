import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

-- ============================================================================
-- Part 1: Original theorem (with the `1 < a, 1 < b, 1 < c` hypotheses)
-- This is Erdős Problem 123 — an open problem in combinatorial number theory.
-- ============================================================================

/-- Erdős Problem 123: for pairwise coprime integers a, b, c > 1, the set of
products a^i * b^j * c^k is d-complete. This is an open problem. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

/-
PROBLEM
============================================================================
Part 2: Analysis of the perturbed statement (1 < a, 1 < b, 1 < c removed)
The modified statement is FALSE. We provide a concrete counterexample.

Blocker: When any generator equals 1, the multiplicative semigroup
degenerates. With (1, 1, 2), the set reduces to {2^k | k ∈ ℕ}, a
geometric sequence in which every pair has a divisibility relation.
Antichain subsets are singletons, so d-completeness fails.
============================================================================

PROVIDED SOLUTION
Unfold PairwiseCoprime3. All three conditions are Nat.Coprime 1 1, Nat.Coprime 1 2, Nat.Coprime 1 2. These hold by Nat.coprime_one_left or decide.
-/
lemma coprime_1_1_2 : PairwiseCoprime3 1 1 2 := by
  exact ⟨ by decide, by decide, by decide ⟩

/-
PROVIDED SOLUTION
Unfold PowTripleSet. Show {n | ∃ i j k, n = 1^i * 1^j * 2^k} = {n | ∃ k, n = 2^k}. Since 1^i = 1 and 1^j = 1, this simplifies to n = 2^k. Use ext, simp, and the fact that 1^n = 1.
-/
lemma powTripleSet_1_1_2_eq :
    PowTripleSet 1 1 2 = {n | ∃ k : ℕ, n = 2 ^ k} := by
  ext n; simp [PowTripleSet]

/-
PROVIDED SOLUTION
Given a = 2^i and b = 2^j with a ≠ b, we have i ≠ j. WLOG i < j or j < i. If i < j then a = 2^i divides b = 2^j (by pow_dvd_pow). Similarly if j < i. Use Nat.lt_or_gt_of_ne.
-/
lemma pow2_dvd_of_ne {a b : ℕ} (ha : ∃ i, a = 2 ^ i) (hb : ∃ j, b = 2 ^ j)
    (hab : a ≠ b) : a ∣ b ∨ b ∣ a := by
  rcases ha with ⟨ i, rfl ⟩ ; rcases hb with ⟨ j, rfl ⟩ ; cases le_total i j <;> simp +decide [ *, pow_dvd_pow ] ;

/-
PROVIDED SOLUTION
By contradiction: if s.card ≥ 2, pick two distinct elements x, y ∈ s. By hs, both are powers of 2. By pow2_dvd_of_ne, x ∣ y or y ∣ x. Either case contradicts IsDivisionAntichain. Use Finset.one_lt_card_iff to get two distinct elements.
-/
lemma antichain_pow2_card_le_one (s : Finset ℕ)
    (hs : ∀ x ∈ s, ∃ k : ℕ, x = 2 ^ k) (hac : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  -- Apply the lemma that states if s has at least two elements and each element is a power of 2, then s is not a division antichain.
  have h_contra : s.card ≥ 2 → ¬IsDivisionAntichain s := by
    intro h₂ h₃; obtain ⟨ x, hx, y, hy, hxy ⟩ := Finset.one_lt_card.mp h₂; exact h₃ hx hy hxy ( pow2_dvd_of_ne ( hs x hx ) ( hs y hy ) hxy |> Or.resolve_right <| by tauto ) ;
  exact le_of_not_gt fun h => h_contra h hac

/-
PROBLEM
The set `PowTripleSet 1 1 2` is NOT d-complete.

PROVIDED SOLUTION
Unfold IsDComplete. We need to show it's not the case that eventually every n has an antichain-sum representation from PowTripleSet 1 1 2. By powTripleSet_1_1_2_eq, the set is {2^k}. Consider n = 3 (or any non-power-of-2). For any s with elements from {2^k}, if s has antichain property, then by antichain_pow2_card_le_one, s has at most 1 element, so s.sum id is either 0 (empty) or a power of 2. So n = 3 can never be represented. More precisely, the filter eventually condition means there exists N such that for all n ≥ N, n has a representation. But there are infinitely many non-powers-of-2, so for any N we can find n ≥ N that is not a power of 2 (and not 0) that cannot be represented. Use Filter.Eventually.exists_forall_of_atTop or unpack the atTop filter directly.
-/
theorem powTripleSet_1_1_2_not_dComplete :
    ¬ IsDComplete (PowTripleSet 1 1 2) := by
  unfold IsDComplete; ( norm_num );
  intro n
  use 2 * n + 3;
  refine' ⟨ by linarith, _ ⟩;
  intro x hx hx' hx''; have := antichain_pow2_card_le_one x ?_ hx'; simp_all +decide [ Set.subset_def ] ;
  · interval_cases _ : x.card <;> simp_all +decide [ Finset.card_eq_one ];
    rcases ‹_› with ⟨ a, rfl ⟩ ; simp_all +arith +decide [ IsDivisionAntichain ];
    obtain ⟨ i, j, k, h ⟩ := hx ; simp_all +arith +decide;
    have := congr_arg Even h ; norm_num [ Nat.even_add, Nat.even_pow ] at this ; aesop;
  · intro y hy; specialize hx hy; unfold PowTripleSet at hx; aesop;

/-- The perturbed Erdős 123 statement (without `1 < a, b, c`) is false. -/
theorem erdos_123_perturbed_is_false :
    ¬ (∀ a b c : ℕ,
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c)) := by
  intro h
  exact powTripleSet_1_1_2_not_dComplete (h 1 1 2 coprime_1_1_2)

-- ============================================================================
-- Part 3: Discovery — Which special cases transfer?
--
-- The obstruction for the perturbed statement is that when any generator
-- equals 1, the multiplicative semigroup degenerates:
--
-- • If all three are 1: PowTripleSet = {1}, trivially not d-complete.
-- • If two are 1 (say a = b = 1): PowTripleSet = {c^k}, a geometric
--   sequence where every pair has a divisibility relation, so antichains
--   are singletons and sums are just individual elements.
-- • If one is 1 (say a = 1): PowTripleSet = {b^j * c^k}, a 2-generator
--   smooth number set. This is still sparse but now antichains can be
--   non-trivial. Whether this 2-generator case is d-complete is itself
--   an interesting sub-problem.
--
-- Transferable special cases:
-- 1. The (2, 3, 5) case and similar small-generator triples: proofs for
--    these transfer to any triple with generators ≥ 2, because the
--    density and covering arguments depend on having at least 3
--    independent exponential growth directions.
-- 2. Coprime-pair results (Frobenius/Chicken-McNugget type): the fact
--    that {a^i · b^j} covers all residues mod sufficiently large moduli
--    when gcd(a,b) = 1 is a reusable covering lemma that transfers to
--    the 3-generator case.
-- 3. Antichain constructions: any proof that a 2-generator set contains
--    rich antichains (e.g., elements of the form a^i · b^j where
--    i and j are "incomparable" in a suitable sense) transfers to the
--    3-generator case by fixing the third exponent.
--
-- The reformulated obstruction is: the generating set must have at least
-- 3 multiplicatively independent generators ≥ 2 to guarantee d-completeness.
-- With fewer independent generators, the divisibility structure is too
-- "chain-like" (totally ordered) to build enough antichain sums.
-- ============================================================================

end Erdos123