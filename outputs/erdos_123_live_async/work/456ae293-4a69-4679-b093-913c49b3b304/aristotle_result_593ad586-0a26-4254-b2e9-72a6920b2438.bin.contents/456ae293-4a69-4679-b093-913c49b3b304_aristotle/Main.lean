-- erdos-123 focus: d-completeness, divisibility antichains, and reusable covering lemmas
import Mathlib

noncomputable section

namespace Erdos123

open Filter
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-!
## Analysis: Removing Pairwise Coprimality

### The modified statement (without coprimality) is FALSE.

**Counterexample:** `a = b = c = 2`.

- `PowTripleSet 2 2 2 = {2^n | n ∈ ℕ}`, since `2^i * 2^j * 2^k = 2^(i+j+k)`.
- Powers of 2 form a **total order** under divisibility: for any two elements,
  the smaller divides the larger.
- Therefore, any `IsDivisionAntichain` subset has at most **one** element.
- Sums of singleton subsets of `{2^n}` are just individual powers of 2.
- Most natural numbers are NOT powers of 2, so this is not `d`-complete.

### Blocker

The pairwise coprimality assumption is **essential** to producing enough
"incomparable" elements in the multiplicative semigroup. When the generators
share common factors, the generated set collapses toward a chain (or near-chain)
under divisibility, destroying the antichain structure needed for d-completeness.

### Which special cases transfer?

Even with coprimality, Erdős Problem 123 remains open in full generality.
However, some partial results are known or tractable:

1. **Two-generator case (one generator trivial):** When one generator equals 1
   (effectively a two-generator semigroup `{a^i * b^j}`), d-completeness for
   coprime `a, b > 1` follows from results on smooth numbers and additive
   representations. This does NOT transfer when `gcd(a,b) > 1`, since then
   `{a^i * b^j}` is contained in `{d^n | n ∈ ℕ}` for `d = gcd(a,b)` (a chain).

2. **Dense antichain supply:** The key structural property is that the set
   `PowTripleSet a b c` contains enough pairwise non-dividing elements.
   With coprimality, elements `a^i * b^j * c^k` with different exponent
   "profiles" are typically incomparable under divisibility. This transfers
   to any triple where the generators are multiplicatively independent
   (no generator is a perfect power of another), which is strictly weaker
   than pairwise coprimality but strictly stronger than no assumption at all.

3. **The obstruction reformulated:** The real obstruction is the "divisibility
   dimension" of the semigroup. With pairwise coprime generators, the
   semigroup has divisibility dimension 3 (the exponent vectors `(i,j,k)` are
   the unique factorizations, and divisibility = coordinatewise ≤). With
   `a = b = c = 2`, the dimension collapses to 1. The correct reformulation
   is: d-completeness holds when the semigroup has divisibility dimension ≥ 2,
   i.e., when the generators are not all powers of a single base.

Below we formalize the counterexample showing the modified statement is false.
-/

/-
PROBLEM
============================================================
Part 1: The modified (no coprimality) statement is FALSE
============================================================

`PowTripleSet 2 2 2` consists exactly of powers of 2.

PROVIDED SOLUTION
Both sides are sets of natural numbers. Show extensionally that n ∈ PowTripleSet 2 2 2 iff ∃ m, n = 2^m. Forward: if n = 2^i * 2^j * 2^k, then n = 2^(i+j+k). Backward: if n = 2^m, take i=m, j=0, k=0.
-/
lemma powTripleSet_222_eq : PowTripleSet 2 2 2 = {n | ∃ m : ℕ, n = 2 ^ m} := by
  ext;
  exact ⟨ fun ⟨ i, j, k, h ⟩ => ⟨ i + j + k, by rw [ h ] ; ring ⟩, fun ⟨ m, h ⟩ => ⟨ m, 0, 0, by rw [ h ] ; ring ⟩ ⟩

/-
PROBLEM
Any two distinct powers of 2 satisfy a divisibility relation
    (the smaller divides the larger), so no antichain has more than one element.

PROVIDED SOLUTION
Suppose s has card ≥ 2. Then there exist distinct x, y ∈ s. By hypothesis, x = 2^a and y = 2^b for some a, b. Since x ≠ y, a ≠ b. WLOG a < b, then x = 2^a divides y = 2^b (since 2^a | 2^b when a ≤ b). This contradicts IsDivisionAntichain. Use Finset.one_lt_card to extract two distinct elements, then derive the contradiction.
-/
lemma pow2_antichain_card_le_one (s : Finset ℕ)
    (hs : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (ha : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  exact Finset.card_le_one.mpr fun x hx y hy => Classical.not_not.1 fun h => ha hx hy h ( by obtain ⟨ m, rfl ⟩ := hs x hx; obtain ⟨ n, rfl ⟩ := hs y hy; exact pow_dvd_pow _ <| le_of_not_ge fun hmn => ha hy hx ( Ne.symm h ) <| pow_dvd_pow _ hmn )

/-
PROBLEM
A singleton antichain-sum over powers of 2 is itself a power of 2.

PROVIDED SOLUTION
By pow2_antichain_card_le_one, s.card ≤ 1. Since s is nonempty, s.card = 1. So s = {x} for some x. Then s.sum id = x. By hs, ∃ m, x = 2^m. Use Finset.card_eq_one to get the singleton.
-/
lemma antichain_sum_pow2 (s : Finset ℕ)
    (hs : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (ha : IsDivisionAntichain s)
    (hne : s.Nonempty) :
    ∃ m : ℕ, s.sum id = 2 ^ m := by
  -- By pow2_antichain_card_le_one, s has at most one element.
  have h_card_le_one : s.card ≤ 1 := by
    exact pow2_antichain_card_le_one s hs ha
  have h_card_eq_one : s.card = 1 := by
    exact le_antisymm h_card_le_one ( Finset.card_pos.mpr hne )
  obtain ⟨x, hx⟩ := Finset.card_eq_one.mp h_card_eq_one
  aesop ( simp_config := { decide := true } ) ; -- This gives the_singleton result.

/-
PROBLEM
Not every sufficiently large natural number is a power of 2.

PROVIDED SOLUTION
We need to show ¬ (∀ᶠ n : ℕ in atTop, ∃ m, n = 2^m). The filter atTop means ∃ N, ∀ n ≥ N, ∃ m, n = 2^m. But for any N, take n = 2^k + 1 for large enough k (so n ≥ N). This n is odd and > 1, so it's not a power of 2. More precisely, 3 is not a power of 2, and for any N we can find n ≥ N that is 3 mod 4 (e.g., n = 4*N + 3). Alternatively, use that between consecutive powers of 2, there exist non-powers-of-2. Simplest: show that 3 is not a power of 2, and use Filter.Eventually.exists or show directly that for any N, N+3 or similar is ≥ N and not a power of 2. Actually the simplest approach: unfold the filter condition to get ∃ N, ∀ n ≥ N, ... and then instantiate with n being any non-power-of-2 ≥ N, like 3 * 2^k for appropriate k, or just n = max N 3 if 3 isn't a power of 2.
-/
lemma not_eventually_pow2 :
    ¬ (∀ᶠ n : ℕ in atTop, ∃ m : ℕ, n = 2 ^ m) := by
  simp;
  intro n;
  use 2 * n + 3;
  exact ⟨ by linarith, fun x hx => by have := congr_arg Even hx; norm_num [ Nat.even_add, Nat.even_pow ] at this; aesop ⟩

/-
PROBLEM
`PowTripleSet 2 2 2` is NOT d-complete.

PROVIDED SOLUTION
Unfold IsDComplete. Assume for contradiction that it holds. Then ∀ᶠ n in atTop, ∃ s with s ⊆ PowTripleSet 2 2 2, antichain s, sum s = n. By powTripleSet_222_eq, elements of s are powers of 2. By antichain_sum_pow2, the sum is a power of 2 (or s is empty in which case sum = 0 = 2^0... wait 0 isn't 2^0). If s is empty, sum = 0, but we need s nonempty... Actually if s is empty, sum id = 0. We need to handle this. For the eventually statement, for large n (n > 0), if s exists with sum = n > 0, then s is nonempty. So for n > 0, the sum is a power of 2. This means ∀ᶠ n in atTop, ∃ m, n = 2^m. But not_eventually_pow2 contradicts this.
-/
theorem powTripleSet_222_not_dComplete :
    ¬ IsDComplete (PowTripleSet 2 2 2) := by
  unfold IsDComplete;
  simp +zetaDelta at *;
  -- For any natural number x, choose x_1 to be an odd number greater than x.
  intro x
  use 2 * x + 3;
  refine' ⟨ by linarith, fun s hs hs' hs'' => _ ⟩;
  -- Since $s$ is a subset of $\{2^i \mid i \in \mathbb{N}\}$, each element in $s$ is a power of 2.
  have hs_powers_of_two : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m := by
    intro x hx; specialize hs hx; rcases hs with ⟨ i, j, k, rfl ⟩ ; exact ⟨ i + j + k, by ring ⟩ ;
  -- Since $s$ is a subset of $\{2^i \mid i \in \mathbb{N}\}$, the sum of elements in $s$ is also a power of 2.
  have hs_sum_powers_of_two : ∃ m : ℕ, s.sum id = 2 ^ m := by
    apply antichain_sum_pow2 s hs_powers_of_two hs';
    exact Finset.nonempty_of_ne_empty ( by rintro rfl; norm_num at hs'' );
  rcases hs_sum_powers_of_two with ⟨ m, hm ⟩ ; rcases m with ( _ | _ | m ) <;> simp_all +arith +decide [ Nat.pow_succ' ] ; omega;

/-
PROBLEM
The modified Erdős 123 statement (without pairwise coprimality) is FALSE.

PROVIDED SOLUTION
Introduce the hypothesis. Specialize with a=2, b=2, c=2 and the three proofs that 1 < 2. This gives IsDComplete (PowTripleSet 2 2 2). But powTripleSet_222_not_dComplete says ¬ IsDComplete (PowTripleSet 2 2 2). Contradiction.
-/
theorem erdos_123_no_coprimality_false :
    ¬ (∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      IsDComplete (PowTripleSet a b c)) := by
  grind +suggestions

