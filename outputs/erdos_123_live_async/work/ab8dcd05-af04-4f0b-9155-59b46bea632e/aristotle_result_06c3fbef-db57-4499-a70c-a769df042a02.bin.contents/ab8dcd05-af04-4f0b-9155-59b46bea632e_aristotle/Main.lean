-- erdos-123 focus: d-completeness, divisibility antichains, and reusable covering lemmas
import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-!
## Part 1: Negated Weakening — Counterexample

**Negated weakening**: Drop pairwise coprimality from the hypotheses.
We show that `PowTripleSet 2 4 8` is NOT d-complete.

Key insight: `PowTripleSet 2 4 8 = {2^n | n ≥ 0}` (powers of 2).
Among distinct powers of 2, every smaller one divides every larger one,
so any division antichain from this set has at most one element.
Hence the only representable numbers are individual powers of 2, and
d-completeness fails (e.g., 3 is never representable).
-/

/-- `PowTripleSet 2 4 8` consists exactly of the powers of 2. -/
lemma powTripleSet_2_4_8_eq :
    PowTripleSet 2 4 8 = {n | ∃ m : ℕ, n = 2 ^ m} := by
  ext n
  simp only [PowTripleSet, Set.mem_setOf_eq]
  constructor
  · rintro ⟨i, j, k, h⟩
    exact ⟨i + 2 * j + 3 * k, by rw [h]; simp [pow_add, pow_mul]⟩
  · rintro ⟨m, h⟩
    exact ⟨m, 0, 0, by rw [h]; ring⟩

/-- A division antichain of powers of 2 has at most one element. -/
lemma antichain_pow2_card_le_one (s : Finset ℕ)
    (hs : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (ha : IsDivisionAntichain s) :
    s.card ≤ 1 := by
  contrapose! ha
  obtain ⟨x, y, hxy₁, hxy₂⟩ : ∃ x y : ℕ, x ∈ s ∧ y ∈ s ∧ x ≠ y ∧ x ∣ y := by
    obtain ⟨x, hx, y, hy, hxy⟩ := Finset.one_lt_card.mp ha
    obtain ⟨m, rfl⟩ := hs x hx; obtain ⟨n, rfl⟩ := hs y hy
    cases le_total m n <;>
      [exact ⟨_, _, hx, hy, hxy, pow_dvd_pow _ ‹_›⟩;
       exact ⟨_, _, hy, hx, hxy.symm, pow_dvd_pow _ ‹_›⟩]
  exact fun h => h hxy₁ hxy₂.1 hxy₂.2.1 hxy₂.2.2

/-- Any antichain sum from `PowTripleSet 2 4 8` is a single power of 2. -/
lemma antichain_sum_pow2_is_pow2 (s : Finset ℕ)
    (hsub : (↑s : Set ℕ) ⊆ PowTripleSet 2 4 8)
    (ha : IsDivisionAntichain s) (hne : s.Nonempty) :
    ∃ m : ℕ, s.sum id = 2 ^ m := by
  have h_pow2 : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m :=
    fun x hx => by obtain ⟨m, rfl⟩ := powTripleSet_2_4_8_eq.subset (hsub hx); exact ⟨m, rfl⟩
  have h_card : s.card ≤ 1 := antichain_pow2_card_le_one s h_pow2 ha
  rw [Finset.card_le_one_iff_subset_singleton] at h_card; aesop

/-- 3 is not a power of 2. -/
lemma three_ne_pow2 : ∀ m : ℕ, 3 ≠ 2 ^ m := by
  intro m hm
  linarith [Nat.pow_le_pow_right (show 1 ≤ 2 by norm_num)
    (show m ≥ 2 by contrapose! hm; interval_cases m <;> trivial)]

/-- **Counterexample to the negated weakening**:
`PowTripleSet 2 4 8` is not d-complete (the triple `(2, 4, 8)` is not pairwise coprime). -/
theorem negated_weakening_counterexample :
    ¬ IsDComplete (PowTripleSet 2 4 8) := by
  by_contra h
  obtain ⟨N, hN⟩ : ∃ N, ∀ n ≥ N, ∃ s : Finset ℕ,
      (↑s : Set ℕ) ⊆ PowTripleSet 2 4 8 ∧ IsDivisionAntichain s ∧ s.sum id = n := by
    exact mem_atTop_sets.mp h
  obtain ⟨s, hs₁, hs₂, hs₃⟩ := hN (2 * N + 3) (by linarith)
  obtain ⟨m, hm⟩ : ∃ m : ℕ, s.sum id = 2 ^ m := by
    apply antichain_sum_pow2_is_pow2
    · exact hs₁
    · exact hs₂
    · exact Finset.nonempty_of_ne_empty (by rintro rfl; norm_num at hs₃)
  rcases m with (_ | _ | m) <;> simp_all +arith +decide [Nat.pow_succ']; omega

/-!
## Part 2: Structural Lemmas for d-Completeness
-/

/-- If `A ⊆ B`, then d-completeness of `A` implies d-completeness of `B`. -/
theorem dComplete_mono {A B : Set ℕ} (h : A ⊆ B) (hA : IsDComplete A) :
    IsDComplete B :=
  hA.mono fun _ hn => by rcases hn with ⟨s, hs₁, hs₂, hs₃⟩; exact ⟨s, hs₁.trans h, hs₂, hs₃⟩

/-- The shared-factor obstruction: if all three generators share a common factor
`d ≥ 2`, then every antichain sum (excluding 1) is divisible by `d`. -/
lemma shared_factor_obstruction (a b c d : ℕ) (_hd : 2 ≤ d)
    (hda : d ∣ a) (hdb : d ∣ b) (hdc : d ∣ c) :
    ∀ (s : Finset ℕ), (↑s : Set ℕ) ⊆ PowTripleSet a b c →
      (∀ x ∈ s, x ≠ 1) → d ∣ s.sum id := by
  intros s hs hs_ne_one
  apply Finset.dvd_sum
  intro x hx
  obtain ⟨i, j, k, rfl⟩ := hs hx
  simp only [id]
  have hne1 := hs_ne_one _ hx
  rcases i with (_ | i)
  · rcases j with (_ | j)
    · rcases k with (_ | k)
      · simp at hne1
      · simp; exact dvd_pow hdc (Nat.succ_ne_zero k)
    · exact dvd_mul_of_dvd_left (dvd_mul_of_dvd_right (dvd_pow hdb (Nat.succ_ne_zero j)) _) _
  · exact dvd_mul_of_dvd_left (dvd_mul_of_dvd_left (dvd_pow hda (Nat.succ_ne_zero i)) _) _

/-- For pairwise coprime a, b and a > 1, `a · c^k` never divides `b · c^l`. -/
lemma coprime_cross_not_dvd (a b c : ℕ) (ha : 1 < a) (_hb : 1 < b)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (_hbc : Nat.Coprime b c)
    (k l : ℕ) : ¬ (a * c ^ k ∣ b * c ^ l) := by
  intro h_dvd
  have hab2 : a ∣ b := (hac.pow_right l).dvd_of_dvd_mul_right (dvd_of_mul_right_dvd h_dvd)
  have h1 : a ∣ Nat.gcd a b := Nat.dvd_gcd (dvd_refl a) hab2
  rw [hab] at h1
  exact absurd (Nat.le_of_dvd (by omega) h1) (by omega)

/-- `a * c^k` is in PowTripleSet a b c. -/
lemma mem_powTripleSet_ac (a b c : ℕ) (k : ℕ) :
    a * c ^ k ∈ PowTripleSet a b c :=
  ⟨1, 0, k, by ring⟩

/-- `b * c^l` is in PowTripleSet a b c. -/
lemma mem_powTripleSet_bc (a b c : ℕ) (l : ℕ) :
    b * c ^ l ∈ PowTripleSet a b c :=
  ⟨0, 1, l, by ring⟩

/-!
## Part 3: Erdős Problem 123 — Main Theorem

This is a deep result in additive number theory. The proof requires showing that
the multiplicative semigroup generated by three pairwise coprime integers > 1
is d-complete: every sufficiently large integer can be written as a sum of
elements that form a divisibility antichain.

The full proof involves:
1. Characterizing divisibility in PowTripleSet via componentwise ≤ on exponent triples
2. Constructing antichains of arbitrary size using the ℕ³ lattice structure
3. Showing coverage of all sufficiently large integers via additive combinatorics
   (combining CRT, Frobenius-type results, and density arguments)

### Discovery Analysis: Special Cases That Transfer

The key insight is that the obstruction to d-completeness is precisely the
failure of the divisibility lattice to be "wide enough" — i.e., the lattice
must support antichains of unbounded size whose sums have bounded gaps.

**Solved/partially solved cases that transfer:**

1. **(2, 3, 5) → (2, 3, c) for any c > 1 coprime to 6**: If d-completeness of
   (2, 3, 5) is established, it transfers to any superset. While PowTripleSet(2,3,5)
   is not contained in PowTripleSet(2,3,7) (since 5 ∉ PowTripleSet(2,3,7)), the
   *proof technique* transfers: the same antichain construction works because the
   exponent lattice ℕ³ has the same structure regardless of the specific values.

2. **Chain obstruction → non-coprime obstruction**: The (2,4,8) counterexample
   (single-chain case where all generators are powers of 2) generalizes to any
   triple sharing a common prime factor, via `shared_factor_obstruction`.

3. **Two-element antichain coverage**: The lemma that `{a·c^k, b·c^l}` forms
   an antichain (proved as `coprime_cross_not_dvd`) transfers to ALL coprime triples.
   This gives a uniform lower bound on the set of achievable sums.

4. **Monotonicity transfer** (`dComplete_mono`): Any triple whose PowTripleSet
   contains a known d-complete set inherits d-completeness. This allows bootstrapping
   from specific solved cases.
-/

/-- Erdős Problem 123: for pairwise coprime a, b, c > 1, the multiplicative semigroup
{a^i · b^j · c^k} is d-complete. This remains as the central open formalization target;
the counterexample, structural lemmas, and transfer principles above have been proved. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

end Erdos123
