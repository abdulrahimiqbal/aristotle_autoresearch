-- erdos family workspace
-- focus: extremal constructions, additive structure, and parameter boundary behavior
-- erdos-123 focus: d-completeness, divisibility antichains, and reusable covering lemmas
import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-!
## Part I: Parameter-Extreme Counterexample

We show that when the coprimality condition fails, d-completeness can fail.
Concretely, `PowTripleSet 2 2 2 = {2^n | n ∈ ℕ}` is NOT d-complete because
any divisibility antichain in powers of 2 has at most one element, so the
only achievable sums are 0 and individual powers of 2. In particular, odd
numbers ≥ 3 are never representable.

This witnesses that the `PairwiseCoprime3` hypothesis is essential and cannot
be dropped, establishing an independence boundary for the parameter extreme.
-/

/-- Every element of `PowTripleSet 2 2 2` is a power of 2. -/
lemma powTripleSet_222_subset :
    PowTripleSet 2 2 2 ⊆ {n : ℕ | ∃ m : ℕ, n = 2 ^ m} := by
  rintro n ⟨i, j, k, rfl⟩; exact ⟨i + j + k, by ring⟩

/-- Every power of 2 belongs to `PowTripleSet 2 2 2`. -/
lemma pow2_subset_powTripleSet_222 :
    {n : ℕ | ∃ m : ℕ, n = 2 ^ m} ⊆ PowTripleSet 2 2 2 := by
  rintro n ⟨m, rfl⟩; exact ⟨m, 0, 0, by ring⟩

/-- Any divisibility antichain consisting of powers of 2 has at most one element. -/
lemma antichain_of_pow2_card_le_one (s : Finset ℕ)
    (hs : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (ha : IsDivisionAntichain s) : s.card ≤ 1 := by
  by_contra h_contra
  obtain ⟨x, hx, y, hy, hxy⟩ := Finset.one_lt_card.1 (lt_of_not_ge h_contra)
  obtain ⟨m₁, rfl⟩ := hs x hx
  obtain ⟨m₂, rfl⟩ := hs y hy
  rcases lt_trichotomy m₁ m₂ with (h | rfl | h) <;>
    simp_all +decide [Nat.pow_dvd_pow_iff]
  · exact ha hx hy (by aesop) (pow_dvd_pow _ h.le)
  · exact ha hy hx (Ne.symm <| by aesop) (pow_dvd_pow _ h.le)

/-- If a finset of naturals has card ≤ 1 and each element is a power of 2,
    then the sum is either 0 or a power of 2. -/
lemma sum_of_pow2_antichain (s : Finset ℕ)
    (hs : ∀ x ∈ s, ∃ m : ℕ, x = 2 ^ m)
    (hc : s.card ≤ 1) :
    s.sum id = 0 ∨ ∃ m : ℕ, s.sum id = 2 ^ m := by
  cases hc.eq_or_lt <;> simp_all +decide [Finset.card_le_one_iff_subset_singleton]
  rw [Finset.card_eq_one] at *; aesop

/-- 3 is not zero and not a power of 2. -/
lemma three_not_zero_or_pow2 : ¬(3 = 0 ∨ ∃ m : ℕ, 3 = 2 ^ m) := by
  norm_num
  intro x hx
  linarith [Nat.pow_le_pow_right (show 1 ≤ 2 by norm_num)
    (show x ≥ 2 by contrapose! hx; interval_cases x <;> trivial)]

/-- **Parameter-extreme counterexample**: `PowTripleSet 2 2 2` is NOT d-complete.
    This shows the `PairwiseCoprime3` hypothesis is necessary. -/
theorem counterexample_not_d_complete_222 :
    ¬ IsDComplete (PowTripleSet 2 2 2) := by
  unfold IsDComplete
  simp +zetaDelta at *
  intro x
  use 2 * x + 3
  refine' ⟨by linarith, fun s hs hs' hs'' => _⟩
  have h_sum : s.sum id = 0 ∨ ∃ m : ℕ, s.sum id = 2 ^ m := by
    apply sum_of_pow2_antichain
    · exact fun x hx => by rcases hs hx with ⟨i, j, k, rfl⟩; exact ⟨i + j + k, by ring⟩
    · apply antichain_of_pow2_card_le_one
      · exact fun x hx => by rcases hs hx with ⟨i, j, k, rfl⟩; exact ⟨i + j + k, by ring⟩
      · assumption
  rcases h_sum with (h | ⟨m, hm⟩) <;> simp_all +arith +decide [Finset.sum_eq_zero_iff]
  have := congr_arg Even hm
  norm_num [Nat.even_add, Nat.even_pow] at this
  rcases m with (_ | _ | m) <;> simp_all +arith +decide

/-!
## Part II: Additional Counterexamples and Transfer Principles

We provide further counterexamples at the parameter boundary and establish
the monotonicity transfer principle that allows lifting partial results.
-/

/-- Monotonicity: d-completeness is preserved under set enlargement. -/
theorem d_complete_mono {A B : Set ℕ} (hAB : A ⊆ B) (hA : IsDComplete A) :
    IsDComplete B := by
  exact hA.mono fun n hn => by
    rcases hn with ⟨s, hs₁, hs₂, hs₃⟩; exact ⟨s, hs₁.trans hAB, hs₂, hs₃⟩

/-- Two-generator set embeds into any triple containing those generators. -/
lemma powPairSet_subset_powTripleSet (a b c : ℕ) :
    {n : ℕ | ∃ i j : ℕ, n = a ^ i * b ^ j} ⊆ PowTripleSet a b c := by
  exact fun n hn => by obtain ⟨i, j, rfl⟩ := hn; exact ⟨i, j, 0, by ring⟩

/-- `1 ∈ PowTripleSet a b c` for any `a, b, c`. -/
lemma one_mem_powTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c := by
  exact ⟨0, 0, 0, by norm_num⟩

/-- Every generator belongs to its own PowTripleSet. -/
lemma gen_mem_powTripleSet_left (a b c : ℕ) (ha : 0 < a) : a ∈ PowTripleSet a b c := by
  exact ⟨1, 0, 0, by simp +decide⟩

/-- The set `PowTripleSet a b c` is closed under multiplication by generators. -/
lemma mul_mem_powTripleSet {a b c n : ℕ} (hn : n ∈ PowTripleSet a b c) :
    a * n ∈ PowTripleSet a b c := by
  obtain ⟨i, j, k, rfl⟩ := hn
  exact ⟨i + 1, j, k, by ring⟩

/-
PROBLEM
**Counterexample (a = b)**: When two generators coincide,
    `PowTripleSet a a c` collapses to a two-generator set.
    If furthermore `a = c`, it collapses to `{a^n}` which is totally ordered
    by divisibility and hence not d-complete (provided `a > 1`).

PROVIDED SOLUTION
PowTripleSet a a a = {a^(i+j+k) : i,j,k ∈ ℕ} = {a^n : n ∈ ℕ}. Since a > 1, powers of a are totally ordered by divisibility (a^m | a^n iff m ≤ n). So any antichain has at most one element, meaning antichain sums are either 0 or a single power of a. For any N, take n = a^N + 1 (not a power of a and not 0), which gives a number ≥ N with no antichain sum representation.

More precisely: show PowTripleSet a a a ⊆ {n | ∃ m, n = a^m} (by (i,j,k) ↦ i+j+k), then use the same argument as counterexample_not_d_complete_222 generalized from 2 to a. Any antichain in {a^m} has card ≤ 1, sums are 0 or a^m, but we can find numbers that are neither.

To show not all large numbers are representable: for any threshold N, consider a^N + 1. This is ≥ N (since a ≥ 2 so a^N ≥ N). It is not 0, and not a power of a (since a^N < a^N + 1 < a^(N+1) for a ≥ 2). So it has no representation.
-/
theorem counterexample_not_d_complete_aaa (a : ℕ) (ha : 1 < a) :
    ¬ IsDComplete (PowTripleSet a a a) := by
  -- Any antichain in the set of powers of $a$ has cardinality at most 1.
  have antichain_card_le_one (s : Finset ℕ) (hs : ∀ x ∈ s, ∃ m : ℕ, x = a ^ m) (ha : IsDivisionAntichain s) : s.card ≤ 1 := by
    have h_antichain_card : ∀ x y : ℕ, x ∈ s → y ∈ s → x ≠ y → ¬ (x ∣ y ∨ y ∣ x) := by
      exact?;
    exact Finset.card_le_one.mpr fun x hx y hy => Classical.not_not.1 fun hxy => h_antichain_card x y hx hy hxy <| by obtain ⟨ m, rfl ⟩ := hs x hx; obtain ⟨ n, rfl ⟩ := hs y hy; exact if hm : m ≤ n then Or.inl <| pow_dvd_pow _ hm else Or.inr <| pow_dvd_pow _ <| le_of_not_ge hm;
  -- Any sum of elements in the set of powers of $a$ is either 0 or a power of $a$.
  have sum_of_pow_a_antichain (s : Finset ℕ) (hs : ∀ x ∈ s, ∃ m : ℕ, x = a ^ m) (hc : s.card ≤ 1) : s.sum id = 0 ∨ ∃ m : ℕ, s.sum id = a ^ m := by
    cases hc.eq_or_lt <;> simp_all +decide [ Finset.card_le_one_iff_subset_singleton ];
    rw [ Finset.card_eq_one ] at * ; aesop;
  -- Therefore, there are infinitely many numbers that cannot be represented as a sum of elements in the set of powers of $a$.
  have not_all_large_numbers_representable : ∀ N, ∃ n ≥ N, ¬∃ m : ℕ, n = a ^ m ∨ n = 0 := by
    intro N;
    use a^(N+1) + 1;
    refine' ⟨ _, _ ⟩;
    · exact Nat.le_succ_of_le ( Nat.le_of_lt ( Nat.recOn N ( by norm_num; linarith ) fun n ihn => by rw [ pow_succ' ] ; nlinarith ) );
    · rintro ⟨ m, hm | hm ⟩ <;> norm_num at hm;
      have := congr_arg ( · % a ) hm ; norm_num [ Nat.add_mod, Nat.pow_mod, Nat.mod_eq_of_lt ha ] at this;
      rcases m with ( _ | _ | m ) <;> norm_num at *;
      linarith;
  contrapose! not_all_large_numbers_representable;
  obtain ⟨ N, hN ⟩ := Filter.eventually_atTop.mp not_all_large_numbers_representable;
  use N;
  intro n hn; obtain ⟨ s, hs₁, hs₂, hs₃ ⟩ := hN n hn; specialize sum_of_pow_a_antichain s ( fun x hx => by
    obtain ⟨ i, j, k, rfl ⟩ := hs₁ hx; exact ⟨ i + j + k, by ring ⟩ ; ) ( antichain_card_le_one s ( fun x hx => by
    obtain ⟨ i, j, k, rfl ⟩ := hs₁ hx; exact ⟨ i + j + k, by ring ⟩ ; ) hs₂ ) ; aesop;

/-
PROBLEM
In `PowTripleSet a b c` with pairwise coprime generators, divisibility
    between elements is equivalent to componentwise ≤ on exponents.

PROVIDED SOLUTION
Direction →: If a^i₁ * b^j₁ * c^k₁ | a^i₂ * b^j₂ * c^k₂, we need i₁ ≤ i₂, j₁ ≤ j₂, k₁ ≤ k₂.

Since a, b, c are pairwise coprime, use the fact that for a prime p dividing a (but not b or c), the p-adic valuation of a^i₁ * b^j₁ * c^k₁ is i₁ * v_p(a), and similarly i₂ * v_p(a) for the other side. Since divisibility implies v_p of LHS ≤ v_p of RHS, we get i₁ ≤ i₂. Similarly for j and k.

Alternatively, more elementarily: Since a^i₁ | a^i₂ * b^j₂ * c^k₂ and gcd(a, b) = gcd(a, c) = 1, we have gcd(a^i₁, b^j₂ * c^k₂) = 1, so a^i₁ | a^i₂, which gives i₁ ≤ i₂ (since a > 1). Similarly for j₁ ≤ j₂ and k₁ ≤ k₂.

Direction ←: If i₁ ≤ i₂, j₁ ≤ j₂, k₁ ≤ k₂, then a^i₁ | a^i₂, b^j₁ | b^j₂, c^k₁ | c^k₂, so the product divides.

Key Mathlib lemmas: Nat.Coprime.pow_dvd_of_pow_dvd, Nat.pow_dvd_pow, Nat.Coprime.coprime_dvd_left, Nat.Coprime.pow_pow.
-/
lemma dvd_iff_exponents_le {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (hbc : Nat.Coprime b c)
    (i₁ j₁ k₁ i₂ j₂ k₂ : ℕ) :
    a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ ↔
      i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
  refine' ⟨ fun h => _, fun h => _ ⟩;
  · have h_div_a : a ^ i₁ ∣ a ^ i₂ := by
      have h_a : a ^ i₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
        exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_right _ _ ) _ ) h;
      exact ( Nat.Coprime.dvd_of_dvd_mul_right ( show Nat.Coprime ( a ^ i₁ ) ( b ^ j₂ * c ^ k₂ ) from by exact Nat.Coprime.mul_right ( Nat.Coprime.pow _ _ hab ) ( Nat.Coprime.pow _ _ hac ) ) ) ( by simpa only [ mul_assoc ] using h_a )
    have h_div_b : b ^ j₁ ∣ b ^ j₂ := by
      have h_div_b : b ^ j₁ ∣ a ^ i₂ * b ^ j₂ := by
        obtain ⟨ k, hk ⟩ := h;
        exact Nat.Coprime.dvd_of_dvd_mul_right ( show Nat.Coprime ( b ^ j₁ ) ( c ^ k₂ ) from Nat.Coprime.pow _ _ <| by apply_rules [ Nat.Coprime.symm ] ) <| hk.symm ▸ dvd_mul_of_dvd_left ( dvd_mul_of_dvd_left ( dvd_mul_left _ _ ) _ ) _;
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ h_div_b;
      exact hab.symm.pow _ _
    have h_div_c : c ^ k₁ ∣ c ^ k₂ := by
      have := dvd_of_mul_left_dvd h;
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ this;
      rw [ Nat.coprime_mul_iff_right ];
      exact ⟨ Nat.Coprime.pow _ _ <| Nat.Coprime.symm <| by aesop, Nat.Coprime.pow _ _ <| Nat.Coprime.symm <| by aesop ⟩;
    exact ⟨ Nat.le_of_not_lt fun hi => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans ha ) _ ) ( pow_lt_pow_right₀ ha hi ) h_div_a, Nat.le_of_not_lt fun hj => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hb ) _ ) ( pow_lt_pow_right₀ hb hj ) h_div_b, Nat.le_of_not_lt fun hk => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hc ) _ ) ( pow_lt_pow_right₀ hc hk ) h_div_c ⟩;
  · exact mul_dvd_mul ( mul_dvd_mul ( pow_dvd_pow _ h.1 ) ( pow_dvd_pow _ h.2.1 ) ) ( pow_dvd_pow _ h.2.2 )

/-!
## Part III: Main Conjecture

Erdős Problem 123 for arbitrary pairwise coprime triples with each entry `> 1`
remains an **open problem** in additive/multiplicative number theory. The
counterexample above (`PowTripleSet 2 2 2`) shows the coprimality hypotheses
are necessary. The `dvd_iff_exponents_le` lemma reduces the antichain condition
to incomparability of exponent vectors, which is the natural reformulation.

### Discovery: Transfer of Special Cases

The key observation is that once the divisibility characterization
(`dvd_iff_exponents_le`) is established, the following special cases transfer:

1. **Two-generator case → three-generator case** via `d_complete_mono` and
   `powPairSet_subset_powTripleSet`: proving `{a^i · b^j}` is d-complete
   for coprime `a, b > 1` immediately yields d-completeness of any
   `PowTripleSet a b c` (since the triple-set is a superset).

2. **Specific triples → general triples**: A proof for `(2, 3, 5)` would
   transfer to any `(a, b, c)` where `PowTripleSet 2 3 5 ⊆ PowTripleSet a b c`,
   which occurs when `{2, 3, 5} ⊆ PowTripleSet a b c`.

3. **The obstruction reformulation**: d-completeness fails iff the exponent
   lattice `ℕ³` has too few antichains of bounded sum (in the value domain).
   Coprimality ensures the value map `(i,j,k) ↦ aⁱbʲcᵏ` is injective with
   well-separated images, giving enough room for antichain sum coverage.
-/

/-- **Erdős Problem 123** (open conjecture): Every pairwise coprime triple `(a,b,c)`
    with each entry `> 1` generates a d-complete set.

    This remains an open problem. The counterexample `counterexample_not_d_complete_222`
    shows the coprimality hypothesis is necessary, and `dvd_iff_exponents_le` provides
    the structural reduction to exponent-vector incomparability. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

