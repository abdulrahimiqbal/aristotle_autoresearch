# Analysis Summary

The reformulation as d-completeness of PowTripleSet is structurally clean but
the core mathematical difficulty persists. A key discovery is that the
two-generator analogue (PowPairSet) is NOT d-complete in general due to
residue obstructions. Three generators are essential: the 2D antichain
structure in the (j,k)-plane overcomes the residue barriers that block
the 1D (two-generator) case. See ANALYSIS.md for full details.
-/

-- erdos family workspace
-- focus: extremal constructions, additive structure, and parameter boundary behavior
-- erdos-123 focus: d-completeness, divisibility antichains, and reusable covering lemmas
-- equivalent view: the set {a^k b^l c^m : k, l, m >= 0} is d-complete
import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-! ## Structural lemmas about PowTripleSet -/

lemma one_mem_PowTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c :=
  ⟨0, 0, 0, by simp⟩

lemma pow_mem_PowTripleSet_a (a b c : ℕ) (i : ℕ) : a ^ i ∈ PowTripleSet a b c :=
  ⟨i, 0, 0, by simp⟩

lemma pow_mem_PowTripleSet_b (a b c : ℕ) (j : ℕ) : b ^ j ∈ PowTripleSet a b c :=
  ⟨0, j, 0, by simp⟩

lemma pow_mem_PowTripleSet_c (a b c : ℕ) (k : ℕ) : c ^ k ∈ PowTripleSet a b c :=
  ⟨0, 0, k, by simp⟩

lemma mul_mem_PowTripleSet (a b c : ℕ) {n m : ℕ}
    (hn : n ∈ PowTripleSet a b c) (hm : m ∈ PowTripleSet a b c) :
    n * m ∈ PowTripleSet a b c := by
  rcases hn with ⟨i₁, j₁, k₁, rfl⟩
  rcases hm with ⟨i₂, j₂, k₂, rfl⟩
  exact ⟨i₁ + i₂, j₁ + j₂, k₁ + k₂, by ring⟩

/-- For pairwise coprime a, b, c, divisibility in PowTripleSet corresponds to
componentwise ≤ on exponents. This is the key structural lemma that reduces
divisibility questions to arithmetic on exponent triples. -/
lemma dvd_iff_exponents_le {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ} :
    a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ ↔
      i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
  constructor
  · intro hdiv
    have hdiv_a : a ^ i₁ ∣ a ^ i₂ := by
      refine' Nat.Coprime.dvd_of_dvd_mul_right _ _
      exact b ^ j₂ * c ^ k₂
      · rw [Nat.coprime_mul_iff_right]
        exact ⟨Nat.Coprime.pow _ _ hcop.1, Nat.Coprime.pow _ _ hcop.2.1⟩
      · exact dvd_trans (dvd_mul_of_dvd_left (dvd_mul_right _ _) _)
          (by simpa only [mul_assoc] using hdiv)
    have hdiv_b : b ^ j₁ ∣ b ^ j₂ := by
      have hdiv_b : b ^ j₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ :=
        dvd_trans (dvd_mul_of_dvd_left (dvd_mul_left _ _) _) hdiv
      have hcop_bac : Nat.Coprime (b ^ j₁) (a ^ i₂ * c ^ k₂) := by
        apply_mod_cast Nat.Coprime.mul_right <;>
          apply_rules [Nat.Coprime.pow, hcop.1.symm, hcop.2.1.symm, hcop.2.2]
      exact hcop_bac.dvd_of_dvd_mul_left <| by convert hdiv_b using 1; ring
    have hdiv_c : c ^ k₁ ∣ c ^ k₂ := by
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ _
      exact a ^ i₂ * b ^ j₂
      · exact Nat.Coprime.mul_right (Nat.Coprime.pow _ _ <| hcop.2.1.symm)
          (Nat.Coprime.pow _ _ <| hcop.2.2.symm)
      · exact dvd_trans (dvd_mul_left _ _) hdiv
    exact ⟨Nat.le_of_not_lt fun hi => Nat.not_dvd_of_pos_of_lt
        (pow_pos (zero_lt_one.trans ha) _) (pow_lt_pow_right₀ ha hi) hdiv_a,
      Nat.le_of_not_lt fun hj => Nat.not_dvd_of_pos_of_lt
        (pow_pos (zero_lt_one.trans hb) _) (pow_lt_pow_right₀ hb hj) hdiv_b,
      Nat.le_of_not_lt fun hk => Nat.not_dvd_of_pos_of_lt
        (pow_pos (zero_lt_one.trans hc) _) (pow_lt_pow_right₀ hc hk) hdiv_c⟩
  · exact fun h => mul_dvd_mul (mul_dvd_mul (pow_dvd_pow _ h.1) (pow_dvd_pow _ h.2.1))
      (pow_dvd_pow _ h.2.2)

/-- Singleton sets are trivially division antichains. -/
lemma isDivisionAntichain_singleton (n : ℕ) :
    IsDivisionAntichain {n} := by
  intro x y hx hy hne
  simp at hx hy
  exact absurd (hy ▸ hx) hne

/-- Elements at the same "level" (i + j + k = L) form a divisibility antichain,
provided a, b, c are pairwise coprime and > 1. If two elements have the same
level sum but different exponent triples, neither divides the other. -/
lemma same_level_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ}
    (hL : i₁ + j₁ + k₁ = i₂ + j₂ + k₂)
    (hne : (i₁, j₁, k₁) ≠ (i₂, j₂, k₂)) :
    ¬ (a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂) := by
  intro hdiv
  obtain ⟨hi, hj, hk⟩ := (dvd_iff_exponents_le ha hb hc hcop).1 hdiv
  apply hne; ext <;> simp_all <;> omega

/-- d-completeness is monotone: if A ⊆ B and A is d-complete, then B is d-complete.
This enables modular proof strategies where we identify d-complete subsets. -/
lemma IsDComplete.mono {A B : Set ℕ} (hAB : A ⊆ B) (hA : IsDComplete A) :
    IsDComplete B := by
  unfold IsDComplete at *
  apply hA.mono
  intro n ⟨s, hs1, hs2, hs3⟩
  exact ⟨s, hs1.trans hAB, hs2, hs3⟩

/-- Elements with exponent triples forming a staircase in ℕ³ are pairwise
incomparable. If the first coordinates strictly increase while the second
coordinates strictly decrease, neither element divides the other. -/
lemma staircase_antichain {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ}
    (hi : i₁ < i₂) (hj : j₂ < j₁) :
    ¬ (a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂) := by
  contrapose! hi with h
  have := dvd_iff_exponents_le ha hb hc hcop |>.1 h
  linarith

/-! ## Key structural lemma: cross-type incomparability

Elements with all-zero first exponent ("BC-plane") are incomparable with
elements having positive first exponent and zero second/third exponents
("A-axis"), as long as the BC-plane elements have j+k ≥ 1. This is the
basis for the main construction: combine a pure power a^I with BC-plane
antichain elements to build a larger antichain. -/

/-- An element b^j · c^k with j + k ≥ 1 is incomparable with a^I for I ≥ 1. -/
lemma bc_incomparable_with_power_a {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hcop : PairwiseCoprime3 a b c)
    {I j k : ℕ} (hI : 0 < I) (hjk : 0 < j + k) :
    ¬ (a ^ I * b ^ 0 * c ^ 0 ∣ a ^ 0 * b ^ j * c ^ k) ∧
    ¬ (a ^ 0 * b ^ j * c ^ k ∣ a ^ I * b ^ 0 * c ^ 0) := by
  constructor
  · intro h_div
    have h_exp_a : I ≤ 0 := (dvd_iff_exponents_le ha hb hc hcop).1 h_div |>.1
    linarith
  · intro h
    have h_exp : j ≤ 0 ∧ k ≤ 0 :=
      (dvd_iff_exponents_le ha hb hc hcop).1 h |> fun h => ⟨h.2.1, h.2.2⟩
    linarith

/-! ## Main theorem

The proof requires showing that for three pairwise coprime generators > 1,
the antichain sums from PowTripleSet eventually cover all integers. The key
insight is that the 2D antichain structure in the (j,k)-plane provides
enough flexibility to cover all residue classes, unlike the two-generator
case where residue obstructions can arise.

NOTE: The two-generator analogue PowPairSet(m,n) = {m^i · n^j} is NOT
d-complete in general. For example, PowPairSet(4,3) cannot achieve residue
2 mod 4 as any antichain sum. Three generators are essential. -/

/-- Erdős Problem 123: for pairwise coprime a, b, c > 1 the set
{a^i · b^j · c^k : i, j, k ≥ 0} is d-complete. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

end Erdos123
