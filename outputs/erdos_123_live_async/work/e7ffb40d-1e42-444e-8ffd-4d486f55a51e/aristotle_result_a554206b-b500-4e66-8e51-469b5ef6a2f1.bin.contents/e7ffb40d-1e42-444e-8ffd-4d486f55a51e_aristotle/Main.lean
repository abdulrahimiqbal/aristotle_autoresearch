import Mathlib

noncomputable section

namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- Original d-complete definition (with antichain). Retained for reference. -/
def IsDComplete_with_antichain (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-- A set is `d`-complete if all sufficiently large integers admit a
representation as a sum of distinct elements from it.
**Perturbation applied**: the antichain constraint has been dropped. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ s.sum id = n

-- ============================================================
-- Structural lemmas
-- ============================================================

/-- Weakening: IsDComplete is implied by the antichain version. -/
theorem isDComplete_of_antichain {A : Set ℕ} (h : IsDComplete_with_antichain A) :
    IsDComplete A := by
  apply Filter.Eventually.mono h
  intro n ⟨s, hsub, _, hsum⟩
  exact ⟨s, hsub, hsum⟩

/-- IsDComplete is monotone: if A ⊆ B and A is d-complete, so is B. -/
theorem isDComplete_mono {A B : Set ℕ} (hAB : A ⊆ B) (hA : IsDComplete A) :
    IsDComplete B := by
  exact hA.mono fun n hn => by obtain ⟨s, hs₁, hs₂⟩ := hn; exact ⟨s, hs₁.trans hAB, hs₂⟩

/-- 1 belongs to PowTripleSet a b c (take i=j=k=0). -/
lemma one_mem_powTripleSet (a b c : ℕ) : 1 ∈ PowTripleSet a b c :=
  ⟨0, 0, 0, by norm_num⟩

/-- Any power of a alone belongs to PowTripleSet. -/
lemma pow_a_mem (a b c : ℕ) (i : ℕ) : a ^ i ∈ PowTripleSet a b c :=
  ⟨i, 0, 0, by norm_num⟩

/-- Any power of b alone belongs to PowTripleSet. -/
lemma pow_b_mem (a b c : ℕ) (j : ℕ) : b ^ j ∈ PowTripleSet a b c :=
  ⟨0, j, 0, by norm_num⟩

/-- Any power of c alone belongs to PowTripleSet. -/
lemma pow_c_mem (a b c : ℕ) (k : ℕ) : c ^ k ∈ PowTripleSet a b c :=
  ⟨0, 0, k, by simp⟩

/-- General membership in PowTripleSet. -/
lemma mem_powTripleSet_iff (a b c n : ℕ) :
    n ∈ PowTripleSet a b c ↔ ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k :=
  Iff.rfl

/-- Products of members of PowTripleSet are again in PowTripleSet. -/
lemma mul_mem_powTripleSet {a b c m n : ℕ}
    (hm : m ∈ PowTripleSet a b c) (hn : n ∈ PowTripleSet a b c) :
    m * n ∈ PowTripleSet a b c := by
  rcases hm with ⟨i, j, k, rfl⟩
  rcases hn with ⟨i₂, j₂, k₂, rfl⟩
  exact ⟨i + i₂, j + j₂, k + k₂, by ring⟩

/-
PROBLEM
============================================================
Symmetry of PowTripleSet
============================================================

PowTripleSet is symmetric in its first two arguments.

PROVIDED SOLUTION
Show set equality by extensionality. For any n: n ∈ PowTripleSet a b c ↔ ∃ i j k, n = a^i * b^j * c^k ↔ ∃ j i k, n = b^j * a^i * c^k (swap i,j and use commutativity of multiplication: a^i * b^j = b^j * a^i) ↔ n ∈ PowTripleSet b a c. Use ext, constructor, rintro, and mul_comm.
-/
lemma powTripleSet_swap12 (a b c : ℕ) : PowTripleSet a b c = PowTripleSet b a c := by
  unfold PowTripleSet;
  grind

/-
PROBLEM
PowTripleSet is symmetric in its last two arguments.

PROVIDED SOLUTION
Same as swap12 but swap j and k: a^i * b^j * c^k = a^i * c^k * b^j by commutativity of multiplication. Use ext, constructor, rintro, and ring or mul_comm.
-/
lemma powTripleSet_swap23 (a b c : ℕ) : PowTripleSet a b c = PowTripleSet a c b := by
  ext n;
  exact ⟨ fun ⟨ i, j, k, h ⟩ ↦ ⟨ i, k, j, by linarith ⟩, fun ⟨ i, k, j, h ⟩ ↦ ⟨ i, j, k, by linarith ⟩ ⟩

/-
PROBLEM
============================================================
Brown's Completeness Criterion
============================================================

**Brown's Completeness Criterion** (finite version).

PROVIDED SOLUTION
By induction on n. Base case n=0: f 0 = 1, so m = 1, take s = {0}. Inductive step: for n+1, if m ≤ partial_sum(n), use IH (with range mono). Otherwise, let m' = m - f(n+1). Since f(n+1) ≤ 1 + partial_sum(n) and m ≤ partial_sum(n+1) = partial_sum(n) + f(n+1), we get 0 ≤ m' ≤ partial_sum(n). If m' = 0, take s = {n+1}. If m' ≥ 1, use IH to get s with Σ_s f = m', then return insert (n+1) s (n+1 ∉ s since s ⊆ range(n+1)).
-/
theorem brown_completeness_criterion (f : ℕ → ℕ) (hf0 : f 0 = 1)
    (hf_pos : ∀ n, 0 < f n)
    (hf_gap : ∀ n, f (n + 1) ≤ 1 + ∑ i ∈ Finset.range (n + 1), f i) :
    ∀ m n : ℕ, 1 ≤ m → m ≤ ∑ i ∈ Finset.range (n + 1), f i →
      ∃ s : Finset ℕ, s ⊆ Finset.range (n + 1) ∧ ∑ i ∈ s, f i = m := by
  -- We proceed by induction on $n$.
  intro m n hm1 hmn
  induction' n with k ih generalizing m;
  · exact ⟨ { 0 }, by norm_num, by norm_num [ * ] at *; linarith ⟩;
  · -- Consider two cases: $m \leq \sum_{i=0}^{k} f(i)$ and $m > \sum_{i=0}^{k} f(i)$.
    by_cases h_case : m ≤ ∑ i ∈ Finset.range (k + 1), f i;
    · exact Exists.elim ( ih m hm1 h_case ) fun s hs => ⟨ s, Finset.Subset.trans hs.1 ( Finset.range_mono ( Nat.le_succ _ ) ), hs.2 ⟩;
    · -- Since $m > \sum_{i=0}^{k} f(i)$, we have $m - f(k+1) \leq \sum_{i=0}^{k} f(i)$.
      have h_diff : m - f (k + 1) ≤ ∑ i ∈ Finset.range (k + 1), f i := by
        simp_all +decide [ Finset.sum_range_succ ];
      by_cases h_diff_pos : 1 ≤ m - f (k + 1);
      · obtain ⟨ s, hs₁, hs₂ ⟩ := ih _ h_diff_pos h_diff; use Insert.insert ( k + 1 ) s; simp_all +decide [ Finset.sum_insert, Finset.subset_iff ] ;
        exact ⟨ fun x hx => Nat.le_succ_of_le ( hs₁ hx ), by rw [ Finset.sum_insert ( Finset.notMem_mono ( show s ⊆ Finset.range ( k + 1 ) from fun x hx => Finset.mem_range_succ_iff.mpr ( hs₁ hx ) ) ( by norm_num ) ), hs₂, add_tsub_cancel_of_le ( by linarith [ Nat.sub_add_cancel ( show f ( k + 1 ) ≤ m from le_of_lt ( Nat.lt_of_sub_pos h_diff_pos ) ) ] ) ] ⟩;
      · use {k + 1};
        grind

/-
PROBLEM
============================================================
Special case: (2, b, c) for any b, c
============================================================

For any b, c, PowTripleSet 2 b c is d-complete via binary
representation (which only uses powers of 2).

PROVIDED SOLUTION
Apply Filter.Eventually.of_forall. For any n, use n.bitIndices.toFinset.image (2 ^ ·) as the witness finset. Elements are powers of 2 hence in PowTripleSet 2 b c via pow_a_mem. The sum equals n by Finset.twoPowSum_toFinset_bitIndices. The image preserves sums since 2^· is injective (Nat.pow_right_injective with 1 < 2). Use Finset.sum_image.
-/
theorem powTripleSet_2bc_dComplete (b c : ℕ) :
    IsDComplete (PowTripleSet 2 b c) := by
  refine' Filter.eventually_atTop.mpr ⟨ 2, fun n hn => _ ⟩;
  -- Consider the binary representation of $n$.
  obtain ⟨s, hs⟩ : ∃ s : Finset ℕ, (↑s : Set ℕ) ⊆ Finset.range (Nat.log 2 n + 1) ∧ (∑ i ∈ s, 2 ^ i) = n := by
    have h_binary : ∃ s : Finset ℕ, (∑ i ∈ s, 2 ^ i) = n := by
      exact ⟨ n.bitIndices.toFinset, by simp ⟩;
    obtain ⟨ s, hs ⟩ := h_binary;
    exact ⟨ s, fun x hx => Finset.mem_range.mpr ( Nat.lt_succ_of_le ( Nat.le_log_of_pow_le ( by norm_num ) ( hs ▸ Finset.single_le_sum ( fun x _ => Nat.zero_le ( 2 ^ x ) ) hx ) ) ), hs ⟩;
  use s.image (fun i => 2 ^ i);
  simp +zetaDelta at *;
  exact ⟨ fun x hx => ⟨ x, 0, 0, by aesop ⟩, by rw [ Finset.sum_image <| by aesop ] ; aesop ⟩

-- ============================================================
-- Density of smooth numbers (key infrastructure for general case)
-- ============================================================

/-- For coprime a, b ≥ 2, a^p ≠ b^q for all positive p, q. -/
theorem pow_ne_pow_of_coprime {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hab : Nat.Coprime a b) (hab' : a ≠ b) :
    ∀ p q : ℕ, 0 < p → 0 < q → a ^ p ≠ b ^ q := by
  exact fun p q hp hq h =>
    absurd (Nat.Prime.dvd_of_dvd_pow (Nat.minFac_prime ha.ne') <|
      dvd_trans (Nat.minFac_dvd a) <| h ▸ dvd_pow_self _ hp.ne')
      (fun h' => absurd (Nat.dvd_gcd (Nat.minFac_dvd a) h') <| by aesop)

/-
PROBLEM
For coprime a, b > 1, log(a)/log(b) is irrational.

PROVIDED SOLUTION
By contradiction. If Real.log a / Real.log b = p/q for integers p, q with q > 0, then q * Real.log a = p * Real.log b, so Real.log (a^q) = Real.log (b^p). Since a > 1 and b > 1, the log function is injective on (1, ∞), so a^q = b^p. But this contradicts pow_ne_pow_of_coprime (which says a^q ≠ b^p for coprime a, b > 1, a ≠ b, with q, p > 0). Note: if p = 0, then log(a^q) = 0, so a^q = 1, contradicting a > 1 and q > 0. Similarly q > 0 is needed.
-/
theorem irrational_log_ratio {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hab : Nat.Coprime a b) (hab' : a ≠ b) :
    Irrational (Real.log a / Real.log b) := by
  -- Assume for contradiction that $\frac{\log a}{\log b}$ is rational.
  by_contra h_not_irrational
  obtain ⟨p, q, hq_pos, h_eq⟩ : ∃ p q : ℕ, q > 0 ∧ Real.log a / Real.log b = p / q := by
    obtain ⟨q, hq⟩ : ∃ q : ℚ, Real.log a / Real.log b = q := by
      simpa [ eq_comm ] using Classical.not_not.1 h_not_irrational;
    exact ⟨ q.num.natAbs, q.den, Nat.cast_pos.mpr q.pos, by simpa [ abs_of_nonneg ( Rat.num_nonneg.mpr ( show 0 ≤ q by exact_mod_cast hq ▸ div_nonneg ( Real.log_nonneg ( by norm_cast; linarith ) ) ( Real.log_nonneg ( by norm_cast; linarith ) ) ) ), Rat.cast_def ] using hq ⟩;
  -- Then we have $a^q = b^p$.
  have h_exp : a ^ q = b ^ p := by
    rw [ div_eq_div_iff ( ne_of_gt <| Real.log_pos <| mod_cast hb ) ( ne_of_gt <| Nat.cast_pos.mpr hq_pos ) ] at h_eq;
    rw [ ← @Nat.cast_inj ℝ ] ; push_cast ; rw [ ← Real.exp_log ( by positivity : 0 < ( a : ℝ ) ), ← Real.exp_log ( by positivity : 0 < ( b : ℝ ) ), ← Real.exp_nat_mul, ← Real.exp_nat_mul ] ; norm_num ; linarith;
  apply_fun fun x => x.factorization at h_exp;
  simp_all +decide [ Nat.factorization_pow, ne_of_gt ( zero_lt_one.trans ha ), ne_of_gt ( zero_lt_one.trans hb ) ];
  obtain ⟨ x, hx ⟩ := Nat.exists_prime_and_dvd ( ne_of_gt ha ) ; obtain ⟨ y, hy ⟩ := Nat.exists_prime_and_dvd ( ne_of_gt hb ) ; replace h_exp := congr_arg ( fun z => z x ) h_exp ; simp_all +decide [ Nat.factorization_eq_zero_iff, Nat.coprime_iff_gcd_eq_one ] ;
  simp_all +decide [ Nat.factorization_eq_zero_of_not_dvd ( show ¬ x ∣ b from fun h => hx.1.not_dvd_one <| hab ▸ Nat.dvd_gcd hx.2 h ) ];
  exact absurd ( h_exp.resolve_left hq_pos.ne' ) ( Finsupp.mem_support_iff.mp ( by aesop ) )

/-- **Close pair existence**: For coprime a, b ≥ 2, there exist positive
integers p, q with b^q < a^p ≤ 2 · b^q.

This follows from Dirichlet's approximation theorem applied to
log(a)/log(b) with the irrationality ensuring a non-degenerate
approximation. -/
theorem exists_close_pair {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hab : Nat.Coprime a b) :
    ∃ p q : ℕ, 0 < p ∧ b ^ q < a ^ p ∧ a ^ p ≤ 2 * b ^ q := by
  sorry

/-- For coprime a, b ≥ 2, the multiplicative semigroup {a^i · b^j : i,j ∈ ℕ}
is "eventually dense on a multiplicative scale": for any sufficiently large M,
there exists an element in (M, 2·M].

This is the **key gap bound** for Brown's criterion. Given the close pair
(p, q) with a^p ∈ (b^q, 2·b^q], for any element e = a^i · b^j with j ≥ q,
the element e' = a^{i+p} · b^{j-q} satisfies e < e' ≤ 2e. -/
theorem powPair_eventually_dense {a b : ℕ} (ha : 1 < a) (hb : 1 < b)
    (hab : Nat.Coprime a b) :
    ∃ N₀ : ℕ, ∀ M : ℕ, N₀ ≤ M →
      ∃ i j : ℕ, M < a ^ i * b ^ j ∧ a ^ i * b ^ j ≤ 2 * M := by
  sorry

-- ============================================================
-- Main theorem (perturbed version, antichain dropped)
-- ============================================================

/-- Erdős Problem 123, perturbed: the antichain constraint is dropped.
Every sufficiently large integer is a sum of distinct elements of
PowTripleSet a b c when a, b, c > 1 are pairwise coprime.

**Proof outline**:
- If any of a, b, c equals 2, PowTripleSet contains {2^i : i ∈ ℕ},
  and d-completeness follows from binary representation.
- If all of a, b, c ≥ 3, d-completeness requires the density of smooth
  numbers (`powPair_eventually_dense`) combined with Brown's criterion.
  This case depends on the unproved density lemma. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  intro a b c ha hb hc hcop
  -- Case split: if any of a, b, c = 2, use binary representation
  by_cases ha2 : a = 2
  · subst ha2; exact powTripleSet_2bc_dComplete b c
  by_cases hb2 : b = 2
  · subst hb2
    rw [powTripleSet_swap12]
    exact powTripleSet_2bc_dComplete a c
  by_cases hc2 : c = 2
  · subst hc2
    rw [powTripleSet_swap23, powTripleSet_swap12]
    exact powTripleSet_2bc_dComplete a b
  -- All of a, b, c ≥ 3: requires density of smooth numbers (the blocker)
  sorry

end Erdos123