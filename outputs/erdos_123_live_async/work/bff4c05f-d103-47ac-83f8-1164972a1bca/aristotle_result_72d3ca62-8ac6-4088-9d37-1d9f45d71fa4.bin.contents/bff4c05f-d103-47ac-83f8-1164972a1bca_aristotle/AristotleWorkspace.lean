namespace Erdos123

open Filter Finset
open scoped BigOperators Pointwise

/-- The multiplicative semigroup generated by `a`, `b`, and `c`. -/
def PowTripleSet (a b c : ℕ) : Set ℕ :=
  {n | ∃ i j k : ℕ, n = a ^ i * b ^ j * c ^ k}

/-- Pairwise coprimality for a triple of natural numbers. -/
def PairwiseCoprime3 (a b c : ℕ) : Prop :=
  Nat.Coprime a b ∧ Nat.Coprime a c ∧ Nat.Coprime b c

/-- No distinct chosen summand divides another. -/
def IsDivisionAntichain (s : Finset ℕ) : Prop :=
  ∀ ⦃x y : ℕ⦄, x ∈ s → y ∈ s → x ≠ y → ¬ x ∣ y

/-- A set is `d`-complete if all sufficiently large integers admit such an
antichain sum representation. -/
def IsDComplete (A : Set ℕ) : Prop :=
  ∀ᶠ n : ℕ in atTop, ∃ s : Finset ℕ,
    (↑s : Set ℕ) ⊆ A ∧ IsDivisionAntichain s ∧ s.sum id = n

/-! ## Structural lemmas about `PowTripleSet` -/

/-- `1` belongs to `PowTripleSet a b c` for any positive `a b c`. -/
lemma one_mem_PowTripleSet {a b c : ℕ} (ha : 0 < a) (hb : 0 < b) (hc : 0 < c) :
    (1 : ℕ) ∈ PowTripleSet a b c := by
  exact ⟨0, 0, 0, by norm_num⟩

/-- Every power of `a` belongs to `PowTripleSet a b c`. -/
lemma pow_a_mem {a b c : ℕ} (hb : 0 < b) (hc : 0 < c) (i : ℕ) :
    a ^ i ∈ PowTripleSet a b c := by
  exact ⟨i, 0, 0, by ring⟩

/-- Every power of `b` belongs to `PowTripleSet a b c`. -/
lemma pow_b_mem {a b c : ℕ} (ha : 0 < a) (hc : 0 < c) (j : ℕ) :
    b ^ j ∈ PowTripleSet a b c := by
  exact ⟨0, j, 0, by simp +decide⟩

/-- Every power of `c` belongs to `PowTripleSet a b c`. -/
lemma pow_c_mem {a b c : ℕ} (ha : 0 < a) (hb : 0 < b) (k : ℕ) :
    c ^ k ∈ PowTripleSet a b c := by
  exact ⟨0, 0, k, by ring⟩

/-
PROBLEM
Two elements `a^i₁ * b^j₁ * c^k₁` and `a^i₂ * b^j₂ * c^k₂` satisfy a
divisibility relation iff the exponents are coordinatewise ≤.

PROVIDED SOLUTION
Forward: Use coprimality to separate the prime factors. Since gcd(a,b)=gcd(a,c)=gcd(b,c)=1, the divisibility a^i₁ * b^j₁ * c^k₁ ∣ a^i₂ * b^j₂ * c^k₂ implies a^i₁ ∣ a^i₂ (using Nat.Coprime.dvd_of_dvd_mul_right with coprimality of a^i₁ and b^j₂ * c^k₂), and similarly for the other exponents. Then use pow_dvd_pow_iff (for a > 1, a^i ∣ a^j ↔ i ≤ j). Backward: straightforward mul_dvd_mul and pow_dvd_pow.
-/
lemma dvd_iff_exponents_le {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (hbc : Nat.Coprime b c)
    {i₁ j₁ k₁ i₂ j₂ k₂ : ℕ} :
    a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ ↔
      i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ := by
  constructor <;> intro H;
  · -- Since $a$, $b$, and $c$ are pairwise coprime, we can apply the fundamental theorem of arithmetic to each prime factor.
    have h_factor_a : a ^ i₁ ∣ a ^ i₂ := by
      have h_div_a : a ^ i₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ := by
        exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_right _ _ ) _ ) H;
      exact ( Nat.Coprime.dvd_of_dvd_mul_right ( show Nat.Coprime ( a ^ i₁ ) ( b ^ j₂ * c ^ k₂ ) from Nat.Coprime.mul_right ( Nat.Coprime.pow _ _ <| by aesop ) ( Nat.Coprime.pow _ _ <| by aesop ) ) <| by simpa only [ mul_assoc ] using h_div_a )
    have h_factor_b : b ^ j₁ ∣ b ^ j₂ := by
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ _;
      exact a ^ i₂ * c ^ k₂;
      · rw [ Nat.coprime_mul_iff_right ];
        exact ⟨ hab.symm.pow _ _, hbc.pow _ _ ⟩;
      · exact dvd_trans ( dvd_mul_of_dvd_left ( dvd_mul_left _ _ ) _ ) ( dvd_trans H ( by ring_nf; norm_num ) )
    have h_factor_c : c ^ k₁ ∣ c ^ k₂ := by
      refine' Nat.Coprime.dvd_of_dvd_mul_left _ _;
      exact a ^ i₂ * b ^ j₂;
      · exact Nat.Coprime.mul_right ( Nat.Coprime.pow _ _ <| by simpa [ Nat.coprime_comm ] using hac ) ( Nat.Coprime.pow _ _ <| by simpa [ Nat.coprime_comm ] using hbc );
      · exact dvd_trans ( dvd_mul_left _ _ ) H;
    exact ⟨ Nat.le_of_not_lt fun hi => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans ha ) _ ) ( pow_lt_pow_right₀ ha hi ) h_factor_a, Nat.le_of_not_lt fun hj => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hb ) _ ) ( pow_lt_pow_right₀ hb hj ) h_factor_b, Nat.le_of_not_lt fun hk => Nat.not_dvd_of_pos_of_lt ( pow_pos ( zero_lt_one.trans hc ) _ ) ( pow_lt_pow_right₀ hc hk ) h_factor_c ⟩;
  · exact mul_dvd_mul ( mul_dvd_mul ( pow_dvd_pow _ H.1 ) ( pow_dvd_pow _ H.2.1 ) ) ( pow_dvd_pow _ H.2.2 )

/-- Elements from `PowTripleSet` are positive. -/
lemma PowTripleSet_pos {a b c n : ℕ} (ha : 0 < a) (hb : 0 < b) (hc : 0 < c)
    (hn : n ∈ PowTripleSet a b c) : 0 < n := by
  obtain ⟨i, j, k, rfl⟩ := hn; positivity

/-
PROBLEM
Two elements of `PowTripleSet a b c` are comparable under divisibility
iff their exponent triples are coordinatewise comparable. In particular,
elements with incomparable exponent triples form a divisibility antichain.

PROVIDED SOLUTION
Unfold IsDivisionAntichain. Take x, y in the image with x ≠ y. Get preimages p₁, p₂. If x ∣ y, then by dvd_iff_exponents_le, p₁ ≤ p₂ coordinate-wise, contradicting hs (since p₁ ≠ p₂ by injectivity from exponent_map_injective, or more directly by the hypothesis). Use contrapositive: if x ∣ y, show x = y, contradicting the hypothesis.
-/
lemma antichain_of_incomparable_exponents {a b c : ℕ}
    (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (hbc : Nat.Coprime b c)
    (s : Finset (ℕ × ℕ × ℕ))
    (hs : ∀ p ∈ s, ∀ q ∈ s, p ≠ q →
      ¬(p.1 ≤ q.1 ∧ p.2.1 ≤ q.2.1 ∧ p.2.2 ≤ q.2.2)) :
    IsDivisionAntichain (s.image (fun p => a ^ p.1 * b ^ p.2.1 * c ^ p.2.2)) := by
  intro x hx y hy hxy;
  contrapose! hs;
  rw [ Finset.mem_image ] at y hy;
  rcases y with ⟨ p, hp, rfl ⟩ ; rcases hy with ⟨ q, hq, rfl ⟩ ; use p, hp, q, hq;
  exact ⟨ by aesop_cat, dvd_iff_exponents_le ha hb hc hab hac hbc |>.1 hs |>.1, dvd_iff_exponents_le ha hb hc hab hac hbc |>.1 hs |>.2.1, dvd_iff_exponents_le ha hb hc hab hac hbc |>.1 hs |>.2.2 ⟩

/-
PROBLEM
The exponent map `(i, j, k) ↦ a^i * b^j * c^k` is injective when `a, b, c`
are pairwise coprime and each > 1.

PROVIDED SOLUTION
Suppose a^i₁ * b^j₁ * c^k₁ = a^i₂ * b^j₂ * c^k₂. Then both directions of divisibility hold, so by dvd_iff_exponents_le, we get i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ AND i₂ ≤ i₁ ∧ j₂ ≤ j₁ ∧ k₂ ≤ k₁. Hence i₁ = i₂, j₁ = j₂, k₁ = k₂, so the triples are equal.
-/
lemma exponent_map_injective {a b c : ℕ} (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (hbc : Nat.Coprime b c) :
    Function.Injective (fun p : ℕ × ℕ × ℕ => a ^ p.1 * b ^ p.2.1 * c ^ p.2.2) := by
  norm_num [ Function.Injective ];
  intros i₁ j₁ k₁ i₂ j₂ k₂ h_eq
  have h_div : i₁ ≤ i₂ ∧ j₁ ≤ j₂ ∧ k₁ ≤ k₂ ∧ i₂ ≤ i₁ ∧ j₂ ≤ j₁ ∧ k₂ ≤ k₁ := by
    have h_div : a ^ i₁ * b ^ j₁ * c ^ k₁ ∣ a ^ i₂ * b ^ j₂ * c ^ k₂ ∧ a ^ i₂ * b ^ j₂ * c ^ k₂ ∣ a ^ i₁ * b ^ j₁ * c ^ k₁ := by
      aesop;
    have := dvd_iff_exponents_le ha hb hc hab hac hbc |>.1 h_div.1; have := dvd_iff_exponents_le ha hb hc hab hac hbc |>.1 h_div.2; aesop;
  exact ⟨ by linarith, by linarith, by linarith ⟩

/-
PROBLEM
`PowTripleSet` is closed under multiplication.

PROVIDED SOLUTION
If m = a^i₁ * b^j₁ * c^k₁ and n = a^i₂ * b^j₂ * c^k₂, then m * n = a^(i₁+i₂) * b^(j₁+j₂) * c^(k₁+k₂), which is in PowTripleSet. Use pow_add and ring.
-/
lemma PowTripleSet_mul_closed {a b c : ℕ} {m n : ℕ}
    (hm : m ∈ PowTripleSet a b c) (hn : n ∈ PowTripleSet a b c) :
    m * n ∈ PowTripleSet a b c := by
  -- By definition of $PowTripleSet$, we can write $m$ and $n$ as $a^{i₁} b^{j₁} c^{k₁}$ and $a^{i₂} b^{j₂} c^{k₂}$ respectively.
  obtain ⟨i₁, j₁, k₁, hm⟩ := hm
  obtain ⟨i₂, j₂, k₂, hn⟩ := hn;
  exact ⟨ i₁ + i₂, j₁ + j₂, k₁ + k₂, by rw [ hm, hn ] ; ring ⟩

/-
PROBLEM
Any product `a^i * b^j * c^k` is in `PowTripleSet`.

PROVIDED SOLUTION
By definition, a^i * b^j * c^k ∈ PowTripleSet a b c since we can take the exponents (i, j, k).
-/
lemma product_mem {a b c : ℕ} (i j k : ℕ) :
    a ^ i * b ^ j * c ^ k ∈ PowTripleSet a b c := by
  exact ⟨ i, j, k, rfl ⟩

/-
PROBLEM
Elements `a^i₁ * c^k₁` (with `i₁ ≥ 1`) and `b^j₂ * c^k₂` (with `j₂ ≥ 1`)
from `PowTripleSet` are always incomparable under divisibility when `a, b, c` are
pairwise coprime and > 1. This is a key structural fact enabling cross-family antichains.

PROVIDED SOLUTION
We need to show a^i₁ * c^k₁ does not divide b^j₂ * c^k₂ (simplifying b^0=1 and a^0=1). By dvd_iff_exponents_le, this would require i₁ ≤ 0, but i₁ > 0 by hypothesis. So the divisibility fails. More directly: if a^i₁ * 1 * c^k₁ ∣ 1 * b^j₂ * c^k₂, then by dvd_iff_exponents_le we'd need i₁ ≤ 0, contradicting hi₁.
-/
lemma cross_family_incomparable {a b c : ℕ}
    (ha : 1 < a) (hb : 1 < b) (hc : 1 < c)
    (hab : Nat.Coprime a b) (hac : Nat.Coprime a c) (hbc : Nat.Coprime b c)
    {i₁ k₁ j₂ k₂ : ℕ} (hi₁ : 0 < i₁) (hj₂ : 0 < j₂) :
    ¬(a ^ i₁ * b ^ 0 * c ^ k₁ ∣ a ^ 0 * b ^ j₂ * c ^ k₂) := by
  intro h;
  have := dvd_iff_exponents_le ha hb hc hab hac hbc |>.1 h; aesop;

/-! ## Main theorem -/

/-- **Erdős Problem 123** (d-completeness of multiplicative triples).

For pairwise coprime integers `a, b, c > 1`, the multiplicative semigroup
`{a^i * b^j * c^k : i, j, k ∈ ℕ}` is d-complete: every sufficiently large
integer can be written as a sum of distinct elements from this set such that
no summand divides another.

**Status**: This is a well-known open problem in combinatorial number theory,
originally posed by Erdős. The structural lemmas above (divisibility
characterization, antichain construction, cross-family incomparability) provide
the key building blocks. The full proof requires showing that the "antichain
subset sums" from the 3D exponent lattice eventually cover all integers, which
involves deep arguments about additive representation via multiplicatively
structured sets. -/
theorem erdos_123_d_complete_sequences :
    ∀ a b c : ℕ, 1 < a → 1 < b → 1 < c →
      PairwiseCoprime3 a b c →
      IsDComplete (PowTripleSet a b c) := by
  sorry

end Erdos123