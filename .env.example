# Aristotle Research Orchestrator - Environment Configuration

# Enable LLM Synthesis for creative conjecture generation
# When enabled, the system uses Kimi K2.5 (or your configured LLM) to synthesize
# verified discoveries and propose new experiments and conjectures.
# This follows the ethos of "verification via discovery" - LLM hypotheses are
# grounded in 100% verified Aristotle data.
RESEARCH_ORCHESTRATOR_LLM_SYNTHESIS=true

# LLM Command Configuration (optional)
# The system uses the 'kimi' command by default, but you can override it.
# The command must accept a prompt on stdin and return JSON.
# Example: RESEARCH_ORCHESTRATOR_LLM_CMD="kimi --json"
# RESEARCH_ORCHESTRATOR_LLM_CMD=kimi

# Dashboard Configuration (optional)
# For local dashboard development
DASHBOARD_DEBUG=true
DASHBOARD_PORT=5000

# Aristotle CLI Configuration (for live provider)
# Set your Aristotle API key if using the aristotle-cli provider
# ARISTOTLE_API_KEY=your_api_key_here
